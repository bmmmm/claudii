#!/bin/bash
# claudii — Claude Interaction Intelligence CLI
# Usage: claudii <command> [args]

set -euo pipefail

CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
VERSION="0.1.0"

usage() {
  cat <<EOF
claudii v$VERSION — Claude Interaction Intelligence

Usage: claudii <command> [args]

Shell-Statusleiste (RPROMPT — zeigt Model-Health außerhalb von Claude):
  status              Aktuellen Model-Status anzeigen
  status on|off       RPROMPT-Statusleiste ein-/ausschalten
  status 5m|15m|30m   Refresh-Intervall setzen (Standard: 15m)
  toggle              Status-Cache leeren und sofort neu abrufen

Claude-interne Statusleiste (zeigt Kontext, Kosten, Tokens IN Claude):
  sessionline         Zeigt ob die interne Statusleiste konfiguriert ist
  sessionline on      Aktiviert die Statusleiste in ~/.claude/settings.json
  sessionline off     Deaktiviert die Statusleiste

Sonstiges:
  restart             Plugin neu laden (source ~/.zshrc, bleibt im Verzeichnis)
  debug               Aktuellen Debug-Level anzeigen
  debug <level>       Debug-Level setzen (off|error|warn|info|debug)
  config              Alle Einstellungen anzeigen
  config get <key>    Wert lesen (Punkt-Notation)
  config set <key> <value>  Wert setzen
  config reset        Auf Defaults zurücksetzen
  search              Claude im Search-Modus starten
  help                Diese Hilfe
  version             Version anzeigen

Beispiele:
  claudii sessionline on            # interne Statusleiste aktivieren
  claudii status 5m                 # alle 5min Status-Check
  claudii toggle                    # Status sofort neu abrufen
  claudii debug info                # Debug-Ausgaben aktivieren
  claudii config get aliases.cl.model
EOF
}

case "${1:-}" in
  status)
    case "${2:-}" in
      on)
        CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
        CONFIG="$CONFIG_DIR/config.json"
        [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
        [[ -f "$CONFIG" ]] || cp "$CLAUDII_HOME/config/defaults.json" "$CONFIG"
        tmp=$(jq '.statusline.enabled = true' "$CONFIG")
        echo "$tmp" > "$CONFIG"
        echo -e "\033[0;32mStatus-Anzeige aktiviert\033[0m"
        ;;
      off)
        CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
        CONFIG="$CONFIG_DIR/config.json"
        [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
        [[ -f "$CONFIG" ]] || cp "$CLAUDII_HOME/config/defaults.json" "$CONFIG"
        tmp=$(jq '.statusline.enabled = false' "$CONFIG")
        echo "$tmp" > "$CONFIG"
        echo -e "\033[0;33mStatus-Anzeige deaktiviert\033[0m"
        ;;
      *m|*[0-9])
        # Accept: 5m, 15m, 30m, 300 (seconds)
        interval="${2:-}"
        if [[ "$interval" == *m ]]; then
          seconds=$(( ${interval%m} * 60 ))
        else
          seconds="$interval"
        fi
        if ! [[ "$seconds" =~ ^[0-9]+$ ]] || (( seconds < 30 )); then
          echo "Ungültiges Intervall: $interval (mindestens 30s)"
          exit 1
        fi
        CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
        CONFIG="$CONFIG_DIR/config.json"
        [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
        [[ -f "$CONFIG" ]] || cp "$CLAUDII_HOME/config/defaults.json" "$CONFIG"
        tmp=$(jq ".status.cache_ttl = $seconds" "$CONFIG")
        echo "$tmp" > "$CONFIG"
        echo "Refresh-Intervall: ${interval} (${seconds}s)"
        ;;
      "")
        "$CLAUDII_HOME/bin/claudii-status"
        exit_code=$?
        if [[ $exit_code -eq 0 ]]; then
          echo -e "\033[0;32m✓ Alle Modelle verfügbar\033[0m"
        fi
        ;;
      *)
        echo "Unbekannte status-Option: ${2}"
        echo "Usage: claudii status [on|off|5m|15m|30m]"
        exit 1
        ;;
    esac
    ;;

  config)
    # Source zsh config functions in bash-compatible way
    CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
    CONFIG="$CONFIG_DIR/config.json"
    DEFAULTS="$CLAUDII_HOME/config/defaults.json"
    [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
    [[ -f "$CONFIG" ]] || cp "$DEFAULTS" "$CONFIG"

    case "${2:-}" in
      get)
        key="${3:?Usage: claudii config get <key>}"
        jq_path=".$(echo "$key" | sed 's/\././g')"
        val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$CONFIG" 2>/dev/null)
        if [[ -z "$val" ]]; then
          val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$DEFAULTS" 2>/dev/null)
        fi
        echo "$val"
        ;;
      set)
        key="${3:?Usage: claudii config set <key> <value>}"
        value="${4:?Usage: claudii config set <key> <value>}"
        jq_path=".$(echo "$key" | sed 's/\././g')"
        if [[ "$value" =~ ^[0-9]+$ ]] || [[ "$value" == "true" ]] || [[ "$value" == "false" ]]; then
          tmp=$(jq "$jq_path = $value" "$CONFIG")
        else
          tmp=$(jq "$jq_path = \"$value\"" "$CONFIG")
        fi
        echo "$tmp" > "$CONFIG"
        echo "Set $key = $value"
        ;;
      reset)
        cp "$DEFAULTS" "$CONFIG"
        echo "Config reset to defaults"
        ;;
      *)
        echo "User config: $CONFIG"
        echo ""
        jq '.' "$CONFIG"
        ;;
    esac
    ;;

  search)
    search_dir=$(jq -r '.search.dir // "~/claude-search"' "${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json" 2>/dev/null || echo "~/claude-search")
    search_dir="${search_dir/#\~/$HOME}"
    model=$(jq -r '.aliases.clq.model // "sonnet"' "${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json" 2>/dev/null || echo "sonnet")
    effort=$(jq -r '.aliases.clq.effort // "medium"' "${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json" 2>/dev/null || echo "medium")
    cd "$search_dir"
    exec claude --model "$model" --effort "$effort"
    ;;

  toggle)
    # Force-refresh: delete stale cache and re-fetch immediately
    rm -f "${TMPDIR:-/tmp}/claudii-status-models"
    rm -f "${TMPDIR:-/tmp}/claudii-status-cache.xml"
    echo -e "\033[0;36mRefreshing model status...\033[0m"
    "$CLAUDII_HOME/bin/claudii-status"
    exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
      echo -e "\033[0;32m✓ Alle Modelle verfügbar\033[0m"
    fi
    ;;

  install-sessionline)
    SETTINGS="${HOME}/.claude/settings.json"
    if [[ ! -f "$SETTINGS" ]]; then
      echo "Error: $SETTINGS not found"
      exit 1
    fi
    if jq -e '.statusLine' "$SETTINGS" >/dev/null 2>&1; then
      echo "statusLine already configured in $SETTINGS"
    else
      tmp=$(jq '. + {"statusLine": {"type": "command", "command": "claudii-sessionline"}}' "$SETTINGS")
      echo "$tmp" > "$SETTINGS"
      echo "Added statusLine to $SETTINGS"
    fi
    echo "Restart Claude Code to activate."
    ;;

  debug)
    CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
    CONFIG="$CONFIG_DIR/config.json"
    DEFAULTS="$CLAUDII_HOME/config/defaults.json"
    [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
    [[ -f "$CONFIG" ]] || cp "$DEFAULTS" "$CONFIG"
    if [[ -z "${2:-}" ]]; then
      current=$(jq -r 'if (.debug.level | type) != "null" then .debug.level else "off" end' "$CONFIG")
      echo "debug level: $current"
      echo "Valid levels: off, error, warn, info, debug"
    else
      level="${2}"
      case "$level" in
        off|error|warn|info|debug)
          tmp=$(jq ".debug.level = \"$level\"" "$CONFIG")
          echo "$tmp" > "$CONFIG"
          echo "Debug level: $level"
          ;;
        *)
          echo "Unbekannter Level: $level"
          echo "Valid levels: off, error, warn, info, debug"
          exit 1
          ;;
      esac
    fi
    ;;

  "")
    usage
    ;;

  version)
    echo "claudii v$VERSION"
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    echo "Unknown command: $1"
    usage
    exit 1
    ;;
esac
