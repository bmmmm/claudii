#!/bin/bash
# claudii — Claude Interaction Intelligence CLI
# Usage: claudii <command> [args]
#
# Thin dispatcher — command logic lives in lib/cmd/*.sh

set -euo pipefail

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
source "$CLAUDII_HOME/lib/visual.sh"
source "$CLAUDII_HOME/lib/spinner.sh"
VERSION="0.11.0"

# TTY detection — 1 if stdout is a terminal, 0 if piped
_TTY=0
[ -t 1 ] && _TTY=1

# Explicit output format flag (--json / --tsv), parsed before alias expansion
_FORMAT=""
_args_filtered=()
for _arg in "$@"; do
  case "$_arg" in
    --json) _FORMAT="json" ;;
    --tsv)  _FORMAT="tsv"  ;;
    *)      _args_filtered+=("$_arg") ;;
  esac
done
set -- "${_args_filtered[@]+"${_args_filtered[@]}"}"
unset _args_filtered _arg

# Returns 0 (true) when output should be plain (no ANSI colors):
# either piped without an explicit format flag, or an explicit --json/--tsv flag is set.
_plain() { [[ "$_TTY" -eq 0 ]] || [[ -n "$_FORMAT" ]]; }

command -v jq >/dev/null 2>&1 || {
  echo "claudii: jq nicht gefunden. Install: brew install jq" >&2; exit 1
}

# ── Shared helpers (used by lib/cmd/*.sh) ──────────────────────────────────

# Resolve project path (cwd) for a given session_id from JSONL transcript.
_session_project_path() {
  local sid="$1"
  [[ -z "$sid" ]] && return
  local jsonl=""
  for _d in "$HOME/.claude/projects"/*/; do
    [[ -f "${_d}${sid}.jsonl" ]] && jsonl="${_d}${sid}.jsonl" && break
  done
  [[ -z "$jsonl" ]] && return
  local cwd
  cwd=$(grep -m5 '"cwd"' "$jsonl" 2>/dev/null | head -1 | grep -o '"cwd":"[^"]*"' | sed 's/"cwd":"//; s/"$//' || true)
  [[ -z "$cwd" ]] && return
  local short="${cwd/#$HOME/\~}"
  if (( ${#short} > 40 )); then
    short="...${short: -37}"
  fi
  echo "$short"
}

# Extract session name from rename entries in JSONL transcript.
_session_name() {
  local sid="$1"
  [[ -z "$sid" ]] && return
  local jsonl=""
  for _d in "$HOME/.claude/projects"/*/; do
    [[ -f "${_d}${sid}.jsonl" ]] && jsonl="${_d}${sid}.jsonl" && break
  done
  [[ -z "$jsonl" ]] && return
  grep -o '"Session renamed to: [^"\\]*"' "$jsonl" 2>/dev/null \
    | tail -1 \
    | sed 's/^"Session renamed to: //; s/"$//' \
    | sed $'s/\033\\[[0-9;]*m//g' \
    | sed 's/\\033\[[0-9;]*m//g; s/\\e\[[0-9;]*m//g; s/\\033//g; s/\\e//g' \
    | LC_ALL=C tr -cd '[:print:]' \
    | cut -c1-60 \
    | tr -d '\n' || true
}

# Extract session fingerprint: top-5 files accessed via tool_input.file_path in JSONL.
# Returns "name(N) name(N) ..." or empty if no JSONL / no tool calls found.
_session_fingerprint() {
  local sid="$1"
  [[ -z "$sid" ]] && return
  local jsonl=""
  for _d in "$HOME/.claude/projects"/*/; do
    [[ -f "${_d}${sid}.jsonl" ]] && jsonl="${_d}${sid}.jsonl" && break
  done
  [[ -z "$jsonl" ]] && return
  local result
  result=$(grep -o '"file_path":"[^"]*"' "$jsonl" 2>/dev/null \
    | sed 's/"file_path":"//; s/"$//' \
    | while IFS= read -r fp; do basename "$fp"; done \
    | sort | uniq -c | sort -rn | head -5 \
    | awk '{printf "%s(%s) ", $2, $1}' \
    | sed 's/ $//' || true)
  echo "$result"
}

# Extract last user message from JSONL (max 80 chars), or empty if not found.
_session_last_user_message() {
  local sid="$1"
  [[ -z "$sid" ]] && return
  local jsonl=""
  for _d in "$HOME/.claude/projects"/*/; do
    [[ -f "${_d}${sid}.jsonl" ]] && jsonl="${_d}${sid}.jsonl" && break
  done
  [[ -z "$jsonl" ]] && return
  local msg
  msg=$(grep '"role":"user"' "$jsonl" 2>/dev/null \
    | tail -1 \
    | grep -o '"text":"[^"]*"' \
    | head -1 \
    | sed 's/"text":"//; s/"$//' \
    | cut -c1-80 || true)
  echo "$msg"
}

# Config helper — sets CONFIG, CONFIG_DIR, DEFAULTS in calling scope
_cfg_init() {
  CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
  CONFIG="$CONFIG_DIR/config.json"
  DEFAULTS="$CLAUDII_HOME/config/defaults.json"
  [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
  [[ -f "$CONFIG" ]] || cp "$DEFAULTS" "$CONFIG"
  _claudii_theme_load
}

# Validate config key — alphanumeric, dots, hyphens, underscores only (prevents jq injection)
_validate_key() { [[ "$1" =~ ^[a-zA-Z0-9._-]+$ ]] || { echo "Invalid key: $1" >&2; return 1; }; }

# Config value lookup — user config first, falls back to defaults.json
# Builds a properly quoted jq path so hyphenated keys (e.g. session-dashboard.enabled)
# are accessed as ."session-dashboard"."enabled" rather than the invalid .session-dashboard.enabled
_cfgget() {
  local key="$1" val _jp="" _seg
  _validate_key "$key" || return 1
  # Split on '.' and quote each segment: "a.b-c.d" → ."a"."b-c"."d"
  local _IFS_OLD="$IFS"
  IFS='.' read -ra _cfgget_segs <<< "$key"
  IFS="$_IFS_OLD"
  for _seg in "${_cfgget_segs[@]}"; do
    _jp+='."'"$_seg"'"'
  done
  val=$(jq -r "${_jp} // empty" "$CONFIG" 2>/dev/null)
  [[ -z "$val" ]] && val=$(jq -r "${_jp} // empty" "$DEFAULTS" 2>/dev/null)
  echo "$val"
}

usage() {
  local d="${CLAUDII_CLR_DIM}›${CLAUDII_CLR_RESET}"  # dim separator
  printf '\n'
  printf "  ${CLAUDII_CLR_CYAN}claudii${CLAUDII_CLR_RESET} ${CLAUDII_CLR_ACCENT}v%s${CLAUDII_CLR_RESET} — Claude Interaction Intelligence\n" "$VERSION"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}aliases${CLAUDII_CLR_RESET}\n"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "cl"  "sonnet" "high"   "default"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clo" "opus"   "high"   "complex tasks"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clm" "opus"   "max"    "max effort"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clq" "sonnet" "medium" "search  (claudii search ['query'])"
  printf "    %-5s  %-21s  $d %s\n"      "clh" ""                 "this alias table + current model status"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}Display Layers${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "on | off"                        "enable/disable all layers"
  printf "    %-33s $d %s\n" "claudestatus [on|off]"           "ClaudeStatus RPROMPT toggle"
  printf "    %-33s $d %s\n" "session-dashboard [on|off]"      "Session Dashboard above-prompt toggle"
  printf "    %-33s $d %s\n" "cc-statusline [on|off]"          "CC-Statusline inside Claude toggle"
  printf "    %-33s $d %s\n" "layers"                          "component overview with status"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}Sessions & Cost${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "sessions (se)"                   "list all active sessions"
  printf "    %-33s $d %s\n" "sessions-inactive (si)"          "list all inactive sessions"
  printf "    %-33s $d %s\n" "cost (c)"                        "aggregate session costs"
  printf "    %-33s $d %s\n" "trends (t)"                      "weekly/daily cost history"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}Watch${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "watch [start|stop|status|test|volume|sound]" "rate-limit reset notifications"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}Config${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "config [get|set|reset|export|import]" "manage configuration"
  printf "    %-33s $d %s\n" "agents"                          "configured agents (alias→skill)"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}System${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "status (s) [5m|15m|30m]"        "live model check · refresh interval"
  printf "    %-33s $d %s\n" "doctor (d)"                      "installation health check"
  printf "    %-33s $d %s\n" "update"                          "update to latest version"
  printf "    %-33s $d %s\n" "version"                         "show version number"
  printf "    %-33s $d %s\n" "changelog"                       "release notes for current version"
  printf "    %-33s $d %s\n" "restart"                         "reload plugin"
  printf "    %-33s $d %s\n" "search ['query']"                "launch Claude in search mode"
  printf '\n'
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}man claudii${CLAUDII_CLR_RESET}  full reference\n"
  printf '\n'
}

# ── Parse session cache file into _PSC_* variables ──────────────────────────
_parse_session_cache() {
  _PSC_model= _PSC_ctx_pct= _PSC_cost= _PSC_rate_5h= _PSC_rate_7d=
  _PSC_reset_5h= _PSC_reset_7d= _PSC_session_id= _PSC_ppid=
  _PSC_worktree= _PSC_agent= _PSC_cache_pct= _PSC_rate_7d_start=
  _PSC_model_id= _PSC_burn_eta= _PSC_rate_5h_start= _PSC_project_path=
  while IFS='=' read -r _k _v; do
    case "$_k" in
      model)          _PSC_model="$_v" ;;
      ctx_pct)        _PSC_ctx_pct="$_v" ;;
      cost)           _PSC_cost="$_v" ;;
      rate_5h)        _PSC_rate_5h="$_v" ;;
      rate_7d)        _PSC_rate_7d="$_v" ;;
      reset_5h)       _PSC_reset_5h="$_v" ;;
      reset_7d)       _PSC_reset_7d="$_v" ;;
      session_id)     _PSC_session_id="$_v" ;;
      ppid)           _PSC_ppid="$_v" ;;
      worktree)       _PSC_worktree="$_v" ;;
      agent)          _PSC_agent="$_v" ;;
      cache_pct)      _PSC_cache_pct="$_v" ;;
      rate_7d_start)  _PSC_rate_7d_start="$_v" ;;
      model_id)       _PSC_model_id="$_v" ;;
      burn_eta)       _PSC_burn_eta="$_v" ;;
      rate_5h_start)  _PSC_rate_5h_start="$_v" ;;
      project_path)   _PSC_project_path="$_v" ;;
    esac
  done < "$1"
  if stat -f %m "$1" >/dev/null 2>&1; then
    _PSC_mtime=$(stat -f %m "$1")
  else
    _PSC_mtime=$(stat -c %Y "$1")
  fi
  _PSC_age=$(( $(date +%s) - _PSC_mtime ))
  # Active = Claude Code process (ppid) is still running AND file is < 24h old.
  # The 24h cap guards against PID recycling (OS reuses PIDs of long-dead processes).
  _PSC_is_active=0
  if [[ "$_PSC_ppid" =~ ^[0-9]+$ ]] && [[ "$_PSC_ppid" != "0" ]] \
      && (( _PSC_age < 86400 )) && kill -0 "$_PSC_ppid" 2>/dev/null; then
    _PSC_is_active=1
  fi
}

# ── Render context bar (8 blocks) into _CTX_BAR ─────────────────────────────
_render_ctx_bar() {
  local _pct=${1:-0}
  local _filled=$(( _pct * 8 / 100 ))
  [[ $_filled -gt 8 ]] && _filled=8
  local _empty=$(( 8 - _filled ))
  local _clr
  if   [[ $_pct -ge 90 ]]; then _clr=$CLAUDII_CLR_RED
  elif [[ $_pct -ge 70 ]]; then _clr=$CLAUDII_CLR_YELLOW
  else                          _clr=$CLAUDII_CLR_GREEN
  fi
  local _bar="" i
  for ((i=0; i<_filled; i++)); do _bar+="$CLAUDII_SYM_BAR_FULL"; done
  for ((i=0; i<_empty;  i++)); do _bar+="$CLAUDII_SYM_BAR_EMPTY"; done
  _CTX_BAR="${_clr}${_bar}${CLAUDII_CLR_RESET}"
}

# ── Render age into _AGE_STR ─────────────────────────────────────────────────
_render_age() {
  local _s=${1:-0}
  if   [[ $_s -lt 60    ]]; then _AGE_STR="${_s}s ago"
  elif [[ $_s -lt 3600  ]]; then _AGE_STR="$(( _s / 60 ))m ago"
  elif [[ $_s -lt 86400 ]]; then _AGE_STR="$(( _s / 3600 ))h ago"
  else                           _AGE_STR="$(( _s / 86400 ))d ago"
  fi
}

# ── Source command modules ──────────────────────────────────────────────────
source "$CLAUDII_HOME/lib/cmd/system.sh"
source "$CLAUDII_HOME/lib/cmd/sessions.sh"
source "$CLAUDII_HOME/lib/cmd/display.sh"
source "$CLAUDII_HOME/lib/cmd/config.sh"

# ── Shorthand aliases — expand before main case statement ───────────────────
case "${1:-}" in
  s)     set -- status             "${@:2}" ;;
  se)    set -- sessions           "${@:2}" ;;
  ss)    set -- sessions           "${@:2}" ;;
  si)    set -- sessions-inactive  "${@:2}" ;;
  about) set -- changelog          "${@:2}" ;;
  c)     set -- cost               "${@:2}" ;;
  t)     set -- trends             "${@:2}" ;;
  d)     set -- doctor             "${@:2}" ;;
esac

# ── Main dispatcher ─────────────────────────────────────────────────────────
case "${1:-}" in
  # System commands
  on)                  _cmd_on                ;;
  off)                 _cmd_off               ;;
  claudestatus)        _cmd_claudestatus "$@"        ;;
  session-dashboard)   _cmd_session_dashboard "$@"   ;;
  dashboard)           _cmd_session_dashboard "$@"   ;; # deprecated alias
  status)              _cmd_status "$@"       ;;
  cc-statusline)       _cmd_cc_statusline "$@" ;;
  sessionline)         exec "$0" cc-statusline "${@:2}" ;;
  install-sessionline) exec "$0" cc-statusline on ;;
  update)              _cmd_update            ;;
  watch)               _cmd_watch "$@"        ;;
  doctor)              _cmd_doctor            ;;

  # Session commands
  cost)                _cmd_cost              ;;
  sessions)
    if [[ "${2:-}" == "--resume" && -n "${3:-}" ]]; then
      exec claude --resume "$3"
    fi
    _cmd_sessions "$@"
    ;;
  sessions-inactive)   _cmd_sessions_inactive ;;
  "")                  _cmd_default           ;;

  # Display commands
  trends)              _cmd_trends            ;;
  layers)              _cmd_layers            ;;
  components)          exec "$0" layers "${@:2}" ;;
  version)             _cmd_version           ;;
  changelog)           _cmd_changelog         ;;
  42)                  _cmd_42                ;;

  # Config commands
  config)              _cmd_config "$@"       ;;
  agents)              _cmd_agents            ;;
  search)              _cmd_search "$@"       ;;

  # Help
  help|--help|-h)      usage                  ;;

  # Unknown
  *)
    echo "Unknown command: $1 — run 'claudii help' for available commands" >&2
    usage; exit 1
    ;;
esac
