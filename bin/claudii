#!/bin/bash
# claudii — Claude Interaction Intelligence CLI
# Usage: claudii <command> [args]

set -euo pipefail

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
VERSION="0.1.0"

command -v jq >/dev/null 2>&1 || {
  echo "claudii: jq nicht gefunden. Install: brew install jq" >&2; exit 1
}

# Config helper — sets CONFIG, CONFIG_DIR, DEFAULTS in calling scope
_cfg_init() {
  CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
  CONFIG="$CONFIG_DIR/config.json"
  DEFAULTS="$CLAUDII_HOME/config/defaults.json"
  [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
  [[ -f "$CONFIG" ]] || cp "$DEFAULTS" "$CONFIG"
}

# Validate config key — alphanumeric, dots, underscores only (prevents jq injection)
_validate_key() { [[ "$1" =~ ^[a-zA-Z0-9._]+$ ]] || { echo "Invalid key: $1" >&2; return 1; }; }

# Config value lookup — user config first, falls back to defaults.json
_cfgget() {
  local key="$1" val
  _validate_key "$key" || return 1
  val=$(jq -r ".$key // empty" "$CONFIG" 2>/dev/null)
  [[ -z "$val" ]] && val=$(jq -r ".$key // empty" "$DEFAULTS" 2>/dev/null)
  echo "$val"
}

usage() {
  printf '\n'
  printf '  \033[0;36mclaudii\033[0m \033[38;5;213mv%s\033[0m — Claude Interaction Intelligence\n' "$VERSION"
  printf '\n'
  printf '  \033[38;5;213mClaudeStatus\033[0m\n'
  printf '    status [on|off|5m|15m|30m]    live model check · RPROMPT on/off · refresh\n'
  printf '    show model [add|rm|<names>]    models shown in RPROMPT\n'
  printf '\n'
  printf '  \033[38;5;213maliases\033[0m\n'
  printf '    %-5s  %-7s  %-6s  %s\n' "cl"  "sonnet" "high"   "default"
  printf '    %-5s  %-7s  %-6s  %s\n' "clo" "opus"   "high"   "complex tasks"
  printf '    %-5s  %-7s  %-6s  %s\n' "clm" "opus"   "max"    "max effort"
  printf "    %-5s  %-7s  %-6s  %s\n" "clq" "sonnet" "medium" "search  (claudii search ['query'])"
  printf '    %-5s  %-7s  %-6s  %s\n' "clh" ""       ""       "alias table + live status"
  printf '\n'
  printf "  \033[38;5;213mClaude Code Status Line  (by wynandw87)\033[0m\n"
  printf "    sessionline [on|off]           context · cost · tokens · rate limits\n"
  printf '\n'
  printf '  \033[38;5;213mtools\033[0m\n'
  printf '    config [get|set|reset|export|import]\n'
  printf '    debug  [off|error|warn|info|debug]\n'
  printf "    metrics · restart · update · about\n"
  printf '\n'
  printf '  \033[38;5;213mman claudii\033[0m  full reference\n'
  printf '\n'
}

case "${1:-}" in
  status)
    _cfg_init
    case "${2:-}" in
      on)
        echo "$(jq '.statusline.enabled = true' "$CONFIG")" > "$CONFIG"
        echo -e "\033[0;32mStatus-Anzeige aktiviert\033[0m"
        ;;
      off)
        echo "$(jq '.statusline.enabled = false' "$CONFIG")" > "$CONFIG"
        echo -e "\033[0;33mStatus-Anzeige deaktiviert\033[0m"
        ;;
      *m|*[0-9])
        interval="${2:-}"
        [[ "$interval" == *m ]] && seconds=$(( ${interval%m} * 60 )) || seconds="$interval"
        if ! [[ "$seconds" =~ ^[0-9]+$ ]] || (( seconds < 30 )); then
          echo "Ungültiges Intervall: $interval (mindestens 30s)"; exit 1
        fi
        echo "$(jq --argjson v "$seconds" '.status.cache_ttl = $v' "$CONFIG")" > "$CONFIG"
        echo "Refresh-Intervall: ${interval} (${seconds}s)"
        ;;
      "")
        rm -f "${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}/status-models"
        "$CLAUDII_HOME/bin/claudii-status"
        exit_code=$?
        [[ $exit_code -eq 0 ]] && echo -e "\033[0;32m✓ Alle Modelle verfügbar\033[0m"
        ;;
      *)
        echo "Unbekannte status-Option: ${2}"
        echo "Usage: claudii status [on|off|5m|15m|30m]"; exit 1
        ;;
    esac
    ;;

  show)
    _cfg_init
    case "${2:-}" in
      model)
        case "${3:-}" in
          add)
            model="${4:?Usage: claudii show model add <model>}"
            current=$(_cfgget statusline.models)
            if echo "$current" | tr ',' '\n' | grep -qx "$model"; then
              echo "$model ist bereits in der Liste: $current"
            else
              new_models="${current},${model}"
              echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
              echo -e "\033[0;32mModelle: $new_models\033[0m"
            fi
            ;;
          rm|remove)
            model="${4:?Usage: claudii show model rm <model>}"
            current=$(_cfgget statusline.models)
            new_models=$(echo "$current" | tr ',' '\n' | grep -vx "$model" | tr '\n' ',' | sed 's/,$//')
            if [[ "$new_models" == "$current" ]]; then
              echo "$model nicht gefunden in: $current"; exit 1
            fi
            echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
            echo -e "\033[0;32mModelle: ${new_models:-keine}\033[0m"
            ;;
          "")
            current=$(_cfgget statusline.models)
            echo "Angezeigte Modelle: $current"
            ;;
          *)
            # All remaining args are model names to set directly
            new_models=$(IFS=,; echo "${*:3}")
            echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
            echo -e "\033[0;32mModelle: $new_models\033[0m"
            ;;
        esac
        ;;
      ""|*)
        echo "Usage: claudii show model [add|rm|<model> ...]"
        ;;
    esac
    ;;

  sessionline)
    SETTINGS="${HOME}/.claude/settings.json"
    case "${2:-}" in
      on)
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Fehler: $SETTINGS nicht gefunden — ist Claude Code installiert?"; exit 1
        fi
        if jq -e '.statusLine.command == "claudii-sessionline"' "$SETTINGS" >/dev/null 2>&1; then
          echo -e "\033[0;36mSessionline bereits aktiv\033[0m"
        else
          echo "$(jq '. + {"statusLine": {"type": "command", "command": "claudii-sessionline"}}' "$SETTINGS")" > "$SETTINGS"
          echo -e "\033[0;32mSessionline aktiviert\033[0m  → Claude Code neu starten zum Aktivieren"
        fi
        ;;
      off)
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Fehler: $SETTINGS nicht gefunden"; exit 1
        fi
        if jq -e '.statusLine' "$SETTINGS" >/dev/null 2>&1; then
          echo "$(jq 'del(.statusLine)' "$SETTINGS")" > "$SETTINGS"
          echo -e "\033[0;33mSessionline deaktiviert\033[0m  → Claude Code neu starten"
        else
          echo "Sessionline war nicht konfiguriert"
        fi
        ;;
      "")
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Sessionline: nicht konfiguriert  ($SETTINGS fehlt)"
        elif jq -e '.statusLine.command == "claudii-sessionline"' "$SETTINGS" >/dev/null 2>&1; then
          echo -e "Sessionline: \033[0;32maktiv\033[0m  ($SETTINGS)"
        elif jq -e '.statusLine' "$SETTINGS" >/dev/null 2>&1; then
          other=$(jq -r '.statusLine.command // .statusLine' "$SETTINGS")
          echo -e "Sessionline: \033[0;33mandere Konfiguration\033[0m  ($other)"
        else
          echo "Sessionline: nicht konfiguriert"
          echo "  → claudii sessionline on  zum Aktivieren"
        fi
        ;;
      *)
        echo "Usage: claudii sessionline [on|off]"; exit 1
        ;;
    esac
    ;;

  # Backwards compatibility
  install-sessionline)
    exec "$0" sessionline on
    ;;

  config)
    _cfg_init
    case "${2:-}" in
      get)
        key="${3:?Usage: claudii config get <key>}"
        _validate_key "$key" || exit 1
        jq_path=".$(echo "$key" | sed 's/\././g')"
        val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$CONFIG" 2>/dev/null)
        [[ -z "$val" ]] && val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$DEFAULTS" 2>/dev/null)
        echo "$val"
        ;;
      set)
        key="${3:?Usage: claudii config set <key> <value>}"
        _validate_key "$key" || exit 1
        value="${4:?Usage: claudii config set <key> <value>}"
        jq_path=".$(echo "$key" | sed 's/\././g')"
        if [[ "$value" =~ ^[0-9]+$ ]] || [[ "$value" == "true" ]] || [[ "$value" == "false" ]]; then
          echo "$(jq --argjson v "$value" "$jq_path = \$v" "$CONFIG")" > "$CONFIG"
        else
          echo "$(jq --arg v "$value" "$jq_path = \$v" "$CONFIG")" > "$CONFIG"
        fi
        echo "Set $key = $value"
        ;;
      reset)
        cp "$DEFAULTS" "$CONFIG"
        echo "Config reset to defaults"
        ;;
      export)
        file="${3:-}"
        if [[ -n "$file" ]]; then
          cp "$CONFIG" "$file"
          echo "Config exportiert nach $file"
        else
          cat "$CONFIG"
        fi
        ;;
      import)
        file="${3:?Usage: claudii config import <file>}"
        [[ -f "$file" ]] || { echo "Datei nicht gefunden: $file"; exit 1; }
        jq '.' "$file" >/dev/null 2>&1 || { echo "Kein gültiges JSON: $file"; exit 1; }
        cp "$CONFIG" "${CONFIG}.bak"
        cp "$file" "$CONFIG"
        echo "Config importiert aus $file  (Backup: ${CONFIG}.bak)"
        ;;
      *)
        echo "User config: $CONFIG"
        echo ""
        jq '.' "$CONFIG"
        ;;
    esac
    ;;

  debug)
    _cfg_init
    if [[ -z "${2:-}" ]]; then
      current=$(jq -r 'if (.debug.level | type) != "null" then .debug.level else "off" end' "$CONFIG")
      echo "debug level: $current"
      echo "Valid levels: off, error, warn, info, debug"
    else
      case "${2}" in
        off|error|warn|info|debug)
          echo "$(jq ".debug.level = \"${2}\"" "$CONFIG")" > "$CONFIG"
          echo "Debug level: ${2}"
          ;;
        *)
          echo "Unbekannter Level: ${2}"
          echo "Valid levels: off, error, warn, info, debug"; exit 1
          ;;
      esac
    fi
    ;;

  search)
    _cfg_init
    search_dir=$(_cfgget search.dir)
    search_dir="${search_dir/#\~/$HOME}"
    model=$(_cfgget aliases.clq.model)
    effort=$(_cfgget aliases.clq.effort)
    cd "$search_dir"
    exec claude --model "$model" --effort "$effort" "${@:2}"
    ;;

  "")
    usage
    ;;

  version)
    echo "claudii v$VERSION"
    ;;

  about)
    printf '\n'
    printf '  \033[0;36mclaudii\033[0m \033[38;5;213mv%s\033[0m\n' "$VERSION"
    printf '  \033[38;5;213m──────────────────────────────────────\033[0m\n'
    printf '  Claude Interaction Intelligence\n'
    printf '\n'
    printf '  zsh plugin + CLI for Claude Code power users.\n'
    printf '\n'
    printf '  \033[0;32m◆\033[0m  ClaudeStatus — model health monitoring in RPROMPT\n'
    printf '  \033[0;32m◆\033[0m  Claude Code Status Line — context · cost · tokens\n'
    printf '  \033[0;32m◆\033[0m  Auto-fallback · debug logging · zsh autocomplete\n'
    printf '\n'
    printf '  \033[38;5;213mhttps://github.com/bmmmm/claudii\033[0m\n'
    printf '  \033[38;5;213mClaude Code Status Line by wynandw87\033[0m\n'
    printf '\n'
    ;;

  42)
    printf '\n'
    printf '  \033[0;36m✦  The answer is 42.\033[0m\n'
    printf '\n'
    printf '  It was also the number of times Opus was down\n'
    printf '  while this tool was being built.\n'
    printf '\n'
    printf '  \033[38;5;213m(We monitor all three now. You'\''re welcome.)\033[0m\n'
    printf '\n'
    ;;

  update)
    if ! git -C "$CLAUDII_HOME" rev-parse --git-dir >/dev/null 2>&1; then
      printf 'claudii: not a git repo — install via:\n'
      printf '  git clone https://github.com/bmmmm/claudii\n'; exit 1
    fi
    git -C "$CLAUDII_HOME" pull --ff-only
    printf '\033[0;32m✓ Updated. Run: claudii restart\033[0m\n'
    ;;

  metrics)
    echo "claudii metrics ist eine zsh-Shell-Funktion."
    echo "Führe sie direkt im Terminal aus (nicht als Subprozess)."
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    echo "Unknown command: $1"
    usage; exit 1
    ;;
esac
