#!/bin/bash
# claudii — Claude Interaction Intelligence CLI
# Usage: claudii <command> [args]

set -euo pipefail

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
VERSION="0.3.0"

command -v jq >/dev/null 2>&1 || {
  echo "claudii: jq nicht gefunden. Install: brew install jq" >&2; exit 1
}

# Config helper — sets CONFIG, CONFIG_DIR, DEFAULTS in calling scope
_cfg_init() {
  CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
  CONFIG="$CONFIG_DIR/config.json"
  DEFAULTS="$CLAUDII_HOME/config/defaults.json"
  [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
  [[ -f "$CONFIG" ]] || cp "$DEFAULTS" "$CONFIG"
}

# Validate config key — alphanumeric, dots, underscores only (prevents jq injection)
_validate_key() { [[ "$1" =~ ^[a-zA-Z0-9._]+$ ]] || { echo "Invalid key: $1" >&2; return 1; }; }

# Config value lookup — user config first, falls back to defaults.json
_cfgget() {
  local key="$1" val
  _validate_key "$key" || return 1
  val=$(jq -r ".$key // empty" "$CONFIG" 2>/dev/null)
  [[ -z "$val" ]] && val=$(jq -r ".$key // empty" "$DEFAULTS" 2>/dev/null)
  echo "$val"
}

usage() {
  local d="\033[38;5;240m›\033[0m"  # dim separator
  printf '\n'
  printf '  \033[0;36mclaudii\033[0m \033[38;5;213mv%s\033[0m — Claude Interaction Intelligence\n' "$VERSION"
  printf '\n'
  printf '  \033[38;5;213maliases\033[0m\n'
  printf "    %-5s  %-7s  %-6s  $d %s\n" "cl"  "sonnet" "high"   "default"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clo" "opus"   "high"   "complex tasks"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clm" "opus"   "max"    "max effort"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clq" "sonnet" "medium" "search  (claudii search ['query'])"
  printf "    %-5s  %-21s  $d %s\n"      "clh" ""                 "alias table + live status"
  printf '\n'
  printf '  \033[38;5;213mClaudeStatus\033[0m                              RPROMPT\n'
  printf "    %-33s $d %s\n" "on | off"                    "enable/disable"
  printf "    %-33s $d %s\n" "status [5m|15m|30m]"         "live model check · refresh interval"
  printf "    %-33s $d %s\n" "show model [add|rm|<names>]" "select which models to monitor"
  printf '\n'
  printf "  \033[38;5;213mSessionline\033[0m                               inside Claude\n"
  printf "    %-33s $d %s\n" "sessionline [on|off]"        "context · cost · tokens · rate limits"
  printf "    %-33s $d %s\n" "sessions"                    "active sessions · costs · rate limits"
  printf '\n'
  printf '  \033[38;5;213mtools\033[0m\n'
  printf '    config [get|set|reset|export|import]\n'
  printf "    doctor · cost · debug · metrics · restart · components · about\n"
  printf '\n'
  printf '  \033[38;5;213mman claudii\033[0m  full reference\n'
  printf '\n'
}

case "${1:-}" in
  on)
    _cfg_init
    echo "$(jq '.statusline.enabled = true' "$CONFIG")" > "$CONFIG"
    echo -e "\033[0;32mClaudeStatus aktiviert\033[0m"
    ;;
  off)
    _cfg_init
    echo "$(jq '.statusline.enabled = false' "$CONFIG")" > "$CONFIG"
    echo -e "\033[0;33mClaudeStatus deaktiviert\033[0m"
    ;;
  status)
    _cfg_init
    case "${2:-}" in
      *m|*[0-9])
        interval="${2:-}"
        [[ "$interval" == *m ]] && seconds=$(( ${interval%m} * 60 )) || seconds="$interval"
        if ! [[ "$seconds" =~ ^[0-9]+$ ]] || (( seconds < 30 )); then
          echo "Ungültiges Intervall: $interval (mindestens 30s)"; exit 1
        fi
        echo "$(jq --argjson v "$seconds" '.status.cache_ttl = $v' "$CONFIG")" > "$CONFIG"
        echo "Refresh-Intervall: ${interval} (${seconds}s)"
        ;;
      "")
        rm -f "${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}/status-models"
        "$CLAUDII_HOME/bin/claudii-status"
        exit_code=$?
        [[ $exit_code -eq 0 ]] && echo -e "\033[0;32m✓ Alle Modelle verfügbar\033[0m"
        ;;
      *)
        echo "Unbekannte status-Option: ${2}"
        echo "Usage: claudii status [5m|15m|30m]"; exit 1
        ;;
    esac
    ;;

  show)
    _cfg_init
    case "${2:-}" in
      model)
        case "${3:-}" in
          add)
            model="${4:?Usage: claudii show model add <model>}"
            current=$(_cfgget statusline.models)
            if echo "$current" | tr ',' '\n' | grep -qx "$model"; then
              echo "$model ist bereits in der Liste: $current"
            else
              new_models="${current},${model}"
              echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
              echo -e "\033[0;32mModelle: $new_models\033[0m"
            fi
            ;;
          rm|remove)
            model="${4:?Usage: claudii show model rm <model>}"
            current=$(_cfgget statusline.models)
            new_models=$(echo "$current" | tr ',' '\n' | grep -vx "$model" | tr '\n' ',' | sed 's/,$//')
            if [[ "$new_models" == "$current" ]]; then
              echo "$model nicht gefunden in: $current"; exit 1
            fi
            echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
            echo -e "\033[0;32mModelle: ${new_models:-keine}\033[0m"
            ;;
          "")
            current=$(_cfgget statusline.models)
            echo "Angezeigte Modelle: $current"
            ;;
          *)
            # All remaining args are model names to set directly
            new_models=$(IFS=,; echo "${*:3}")
            echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
            echo -e "\033[0;32mModelle: $new_models\033[0m"
            ;;
        esac
        ;;
      ""|*)
        echo "Usage: claudii show model [add|rm|<model> ...]"
        ;;
    esac
    ;;

  sessionline)
    SETTINGS="${HOME}/.claude/settings.json"
    case "${2:-}" in
      on)
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Fehler: $SETTINGS nicht gefunden — ist Claude Code installiert?"; exit 1
        fi
        if jq -e '.statusLine.command == "claudii-sessionline"' "$SETTINGS" >/dev/null 2>&1; then
          echo -e "\033[0;36mSessionline bereits aktiv\033[0m"
        else
          echo "$(jq '. + {"statusLine": {"type": "command", "command": "claudii-sessionline"}}' "$SETTINGS")" > "$SETTINGS"
          echo -e "\033[0;32mSessionline aktiviert\033[0m  → Claude Code neu starten zum Aktivieren"
        fi
        ;;
      off)
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Fehler: $SETTINGS nicht gefunden"; exit 1
        fi
        if jq -e '.statusLine' "$SETTINGS" >/dev/null 2>&1; then
          echo "$(jq 'del(.statusLine)' "$SETTINGS")" > "$SETTINGS"
          echo -e "\033[0;33mSessionline deaktiviert\033[0m  → Claude Code neu starten"
        else
          echo "Sessionline war nicht konfiguriert"
        fi
        ;;
      "")
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Sessionline: nicht konfiguriert  ($SETTINGS fehlt)"
        elif jq -e '.statusLine.command == "claudii-sessionline"' "$SETTINGS" >/dev/null 2>&1; then
          echo -e "Sessionline: \033[0;32maktiv\033[0m  ($SETTINGS)"
        elif jq -e '.statusLine' "$SETTINGS" >/dev/null 2>&1; then
          other=$(jq -r '.statusLine.command // .statusLine' "$SETTINGS")
          echo -e "Sessionline: \033[0;33mandere Konfiguration\033[0m  ($other)"
        else
          echo "Sessionline: nicht konfiguriert"
          echo "  → claudii sessionline on  zum Aktivieren"
        fi
        ;;
      *)
        echo "Usage: claudii sessionline [on|off]"; exit 1
        ;;
    esac
    ;;

  # Backwards compatibility
  install-sessionline)
    exec "$0" sessionline on
    ;;

  config)
    _cfg_init
    case "${2:-}" in
      get)
        key="${3:?Usage: claudii config get <key>}"
        _validate_key "$key" || exit 1
        jq_path=".$(echo "$key" | sed 's/\././g')"
        val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$CONFIG" 2>/dev/null)
        [[ -z "$val" ]] && val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$DEFAULTS" 2>/dev/null)
        echo "$val"
        ;;
      set)
        key="${3:?Usage: claudii config set <key> <value>}"
        _validate_key "$key" || exit 1
        value="${4:?Usage: claudii config set <key> <value>}"
        jq_path=".$(echo "$key" | sed 's/\././g')"
        if [[ "$value" =~ ^[0-9]+$ ]] || [[ "$value" == "true" ]] || [[ "$value" == "false" ]]; then
          echo "$(jq --argjson v "$value" "$jq_path = \$v" "$CONFIG")" > "$CONFIG"
        else
          echo "$(jq --arg v "$value" "$jq_path = \$v" "$CONFIG")" > "$CONFIG"
        fi
        echo "Set $key = $value"
        ;;
      reset)
        cp "$DEFAULTS" "$CONFIG"
        echo "Config reset to defaults"
        ;;
      export)
        file="${3:-}"
        if [[ -n "$file" ]]; then
          cp "$CONFIG" "$file"
          echo "Config exportiert nach $file"
        else
          cat "$CONFIG"
        fi
        ;;
      import)
        file="${3:?Usage: claudii config import <file>}"
        [[ -f "$file" ]] || { echo "Datei nicht gefunden: $file"; exit 1; }
        jq '.' "$file" >/dev/null 2>&1 || { echo "Kein gültiges JSON: $file"; exit 1; }
        cp "$CONFIG" "${CONFIG}.bak"
        cp "$file" "$CONFIG"
        echo "Config importiert aus $file  (Backup: ${CONFIG}.bak)"
        ;;
      *)
        echo "User config: $CONFIG"
        echo ""
        jq '.' "$CONFIG"
        ;;
    esac
    ;;

  debug)
    _cfg_init
    if [[ -z "${2:-}" ]]; then
      current=$(jq -r 'if (.debug.level | type) != "null" then .debug.level else "off" end' "$CONFIG")
      echo "debug level: $current"
      echo "Valid levels: off, error, warn, info, debug"
    else
      case "${2}" in
        off|error|warn|info|debug)
          echo "$(jq ".debug.level = \"${2}\"" "$CONFIG")" > "$CONFIG"
          echo "Debug level: ${2}"
          ;;
        *)
          echo "Unbekannter Level: ${2}"
          echo "Valid levels: off, error, warn, info, debug"; exit 1
          ;;
      esac
    fi
    ;;

  cost)
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    shopt -s nullglob
    session_files=("$cache_dir"/session-*)
    shopt -u nullglob

    if [[ ${#session_files[@]} -eq 0 ]]; then
      echo "No session data found. Start a Claude session first."
      exit 0
    fi

    now=$(date +%s)
    cutoff=$(( now - 86400 ))

    # Associative arrays for per-model totals
    declare -A today_cost today_count alltime_cost alltime_count

    for f in "${session_files[@]}"; do
      [[ -f "$f" ]] || continue

      # Read key=value pairs
      cost="" model=""
      while IFS='=' read -r key val; do
        case "$key" in
          cost)  cost="$val"  ;;
          model) model="$val" ;;
        esac
      done < "$f"

      [[ -z "$model" ]] && continue
      [[ -z "$cost" ]]  && cost="0"

      # Normalize model name to short form
      case "$model" in
        *[Oo]pus*)   short="Opus"   ;;
        *[Ss]onnet*) short="Sonnet" ;;
        *[Hh]aiku*)  short="Haiku"  ;;
        *)           short="$model" ;;
      esac

      # Get mtime
      if stat -f%m "$f" >/dev/null 2>&1; then
        mtime=$(stat -f%m "$f")
      else
        mtime=$(stat -c%Y "$f")
      fi

      # Accumulate all-time
      alltime_cost[$short]=$(printf '%.4f' \
        "$(echo "${alltime_cost[$short]:-0} + $cost" | bc -l 2>/dev/null || echo "${alltime_cost[$short]:-0}")")
      alltime_count[$short]=$(( ${alltime_count[$short]:-0} + 1 ))

      # Accumulate today (mtime within last 24h)
      if (( mtime >= cutoff )); then
        today_cost[$short]=$(printf '%.4f' \
          "$(echo "${today_cost[$short]:-0} + $cost" | bc -l 2>/dev/null || echo "${today_cost[$short]:-0}")")
        today_count[$short]=$(( ${today_count[$short]:-0} + 1 ))
      fi
    done

    cyan='\033[0;36m'
    reset='\033[0m'
    line='  ─────────────────'

    _print_section() {
      local -n _costs=$1 _counts=$2
      local total=0 has_data=0
      for m in "${!_costs[@]}"; do
        c="${_costs[$m]}"
        n="${_counts[$m]}"
        printf "    %-10s ${cyan}\$%s${reset}  (%s session%s)\n" \
          "$m" "$(printf '%.2f' "$c")" "$n" "$( (( n != 1 )) && echo 's' || true)"
        total=$(echo "$total + $c" | bc -l)
        has_data=1
      done
      if (( has_data )); then
        printf '%s\n' "$line"
        printf "    %-10s ${cyan}\$%s${reset}\n" "Total" "$(printf '%.2f' "$total")"
      else
        printf "    (none)\n"
      fi
    }

    printf '\n'
    printf '  \033[38;5;213mToday\033[0m\n'
    _print_section today_cost today_count
    printf '\n'
    printf '  \033[38;5;213mAll time\033[0m\n'
    _print_section alltime_cost alltime_count
    printf '\n'
    ;;

  search)
    _cfg_init
    search_dir=$(_cfgget search.dir)
    search_dir="${search_dir/#\~/$HOME}"
    model=$(_cfgget aliases.clq.model)
    effort=$(_cfgget aliases.clq.effort)
    cd "$search_dir"
    exec claude --model "$model" --effort "$effort" "${@:2}"
    ;;

  "")
    usage
    ;;

  version)
    echo "claudii v$VERSION"
    ;;

  about)
    printf '\n'
    printf '  \033[0;36mclaudii\033[0m \033[38;5;213mv%s\033[0m\n' "$VERSION"
    printf '  \033[38;5;213m──────────────────────────────────────\033[0m\n'
    printf '  Claude Interaction Intelligence\n'
    printf '\n'
    printf '  zsh plugin + CLI for Claude Code power users.\n'
    printf '\n'
    printf '  \033[0;32m◆\033[0m  ClaudeStatus — model health in RPROMPT\n'
    printf '  \033[0;32m◆\033[0m  SessionBar — session data above prompt\n'
    printf '  \033[0;32m◆\033[0m  Sessionline — info-dense line inside Claude Code\n'
    printf '  \033[0;32m◆\033[0m  Auto-fallback · debug logging · zsh autocomplete\n'
    printf '\n'
    printf '  \033[38;5;240mclaudii components  — component overview\033[0m\n'
    printf '  \033[38;5;213mhttps://github.com/bmmmm/claudii\033[0m\n'
    printf '\n'
    ;;

  components)
    local_cache="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    _cfg_init

    printf '\n'
    printf '  \033[0;36mclaudii components\033[0m\n'
    printf '  \033[38;5;213m──────────────────────────────────────────────────────────\033[0m\n'
    printf '\n'

    # ClaudeStatus
    cs_enabled=$(_cfgget statusline.enabled)
    cs_models=$(_cfgget statusline.models)
    cs_ttl=$(_cfgget status.cache_ttl)
    cs_cache="$local_cache/status-models"
    if [[ "$cs_enabled" == "true" ]]; then
      cs_state="\033[0;32mon\033[0m"
    else
      cs_state="\033[0;33moff\033[0m"
    fi
    printf '  \033[1;36mClaudeStatus\033[0m                              Shell RPROMPT\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Model health indicators from status.claude.com\n'
    printf '  Example:  [Opus \033[0;32m✓\033[0m Sonnet \033[0;32m✓\033[0m Haiku \033[0;32m✓\033[0m] 13m\n'
    printf '\n'
    printf '  Status:   %b\n' "$cs_state"
    printf '  Models:   %s\n' "$cs_models"
    printf '  TTL:      %ss\n' "$cs_ttl"
    if [[ -f "$cs_cache" ]]; then
      printf '  Cache:    %s\n' "$cs_cache"
    else
      printf '  Cache:    \033[38;5;240m(not yet created)\033[0m\n'
    fi
    printf '  Commands: claudii on/off · status · show model\n'
    printf '\n'

    # SessionBar
    sb_count=0
    for _sf in "$local_cache"/session-*; do
      [[ -f "$_sf" ]] && sb_count=$((sb_count + 1))
    done 2>/dev/null
    printf '  \033[1;36mSessionBar\033[0m                                Shell, above prompt\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Session data from cache (model, context, cost, rate limits)\n'
    printf '  Example:  \033[1mOpus\033[0m \033[0;32m████████\033[0m\033[38;5;240m░░\033[0m 76%% \033[38;5;240m│\033[0m \033[0;36m$0.07\033[0m \033[38;5;240m│\033[0m 5h:17%% reset 43min\n'
    printf '\n'
    printf '  Source:   Sessionline writes cache, SessionBar reads it\n'
    printf '  Sessions: %d cache file(s)\n' "$sb_count"
    printf '  Dedup:    only prints when data changes\n'
    printf '\n'

    # Sessionline
    settings_file="$HOME/.claude/settings.json"
    if [[ -f "$settings_file" ]] && command -v jq >/dev/null 2>&1; then
      sl_cmd=$(jq -r '.statusLine // empty' "$settings_file" 2>/dev/null)
      if [[ -n "$sl_cmd" && "$sl_cmd" == *claudii* ]]; then
        sl_state="\033[0;32maktiv\033[0m"
      else
        sl_state="\033[38;5;240mnicht konfiguriert\033[0m"
      fi
    else
      sl_state="\033[38;5;240m~/.claude/settings.json nicht gefunden\033[0m"
    fi
    printf '  \033[1;36mSessionline\033[0m                               Inside Claude Code\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Info-dense status line rendered inside Claude Code CLI\n'
    printf '  Shows model, context bar, cost, tokens, rate limits, lines, duration\n'
    printf '\n'
    printf '  Status:   %b\n' "$sl_state"
    printf '  API:      Claude Code statusLine (stdin JSON)\n'
    printf '  Handler:  bin/claudii-sessionline (bash+jq)\n'
    printf '  Commands: claudii sessionline on/off\n'
    printf '\n'

    # Data flow
    printf '  \033[1;36mData Flow\033[0m\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Claude Code \033[38;5;240m─JSON→\033[0m \033[1mSessionline\033[0m \033[38;5;240m─cache→\033[0m \033[1mSessionBar\033[0m\n'
    printf '  status.claude.com \033[38;5;240m─bg→\033[0m \033[1mClaudeStatus\033[0m (RPROMPT)\n'
    printf '\n'
    ;;

  42)
    printf '\n'
    printf '  \033[0;36m✦  The answer is 42.\033[0m\n'
    printf '\n'
    printf '  It was also the number of times Opus was down\n'
    printf '  while this tool was being built.\n'
    printf '\n'
    printf '  \033[38;5;213m(We monitor all three now. You'\''re welcome.)\033[0m\n'
    printf '\n'
    ;;

  sessions)
    _cfg_init
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    now=$(date +%s)
    active=0 stale=0 total_cost=0
    latest_5h="" latest_7d="" latest_reset=""

    printf '\n'
    for sf in "$cache_dir"/session-*; do
      [[ -f "$sf" ]] || continue
      mt=$(stat -f%m "$sf" 2>/dev/null || stat -c%Y "$sf" 2>/dev/null || echo 0)
      age=$(( now - mt ))

      content=$(<"$sf" 2>/dev/null) || continue
      s_model="" s_ctx="" s_cost="" s_5h="" s_7d="" s_reset="" s_sid=""
      [[ $'\n'"$content" == *$'\n'model=* ]] && s_model="${content#*model=}" && s_model="${s_model%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'ctx_pct=* ]] && s_ctx="${content#*ctx_pct=}" && s_ctx="${s_ctx%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'cost=* ]] && s_cost="${content#*cost=}" && s_cost="${s_cost%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'rate_5h=* ]] && s_5h="${content#*rate_5h=}" && s_5h="${s_5h%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'rate_7d=* ]] && s_7d="${content#*rate_7d=}" && s_7d="${s_7d%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'reset_5h=* ]] && s_reset="${content#*reset_5h=}" && s_reset="${s_reset%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'session_id=* ]] && s_sid="${content#*session_id=}" && s_sid="${s_sid%%$'\n'*}"

      # Accumulate cost
      if [[ -n "$s_cost" && "$s_cost" != "0" ]]; then
        total_cost=$(echo "$total_cost + $s_cost" | bc 2>/dev/null || echo "$total_cost")
      fi

      # Track freshest rate limits
      if [[ -n "$s_5h" ]] && (( age < 300 )); then
        latest_5h="$s_5h"; latest_7d="$s_7d"; latest_reset="$s_reset"
      fi

      # Display
      local status_icon age_str
      if (( age < 300 )); then
        status_icon="\033[0;32m●\033[0m"
        (( active++ ))
      else
        status_icon="\033[0;90m○\033[0m"
        (( stale++ ))
      fi
      if (( age < 60 )); then age_str="${age}s"
      elif (( age < 3600 )); then age_str="$(( age / 60 ))m"
      elif (( age < 86400 )); then age_str="$(( age / 3600 ))h"
      else age_str="$(( age / 86400 ))d"; fi

      line="  ${status_icon} \033[1m${s_model:-?}\033[0m"
      [[ -n "$s_ctx" ]] && line+="  ${s_ctx}%"
      [[ -n "$s_cost" && "$s_cost" != "0" ]] && line+="  \033[36m\$$(printf '%.2f' "$s_cost")\033[0m"
      [[ -n "$s_5h" ]] && line+="  5h:${s_5h%.*}%"
      line+="  \033[2m${age_str} ago\033[0m"
      [[ -n "$s_sid" ]] && line+="  \033[2m${s_sid:0:8}\033[0m"
      printf "${line}\n"
    done

    # Summary
    printf '\n'
    total_fmt=$(printf '$%.2f' "$total_cost")
    printf "  \033[38;5;213m%d aktiv, %d beendet, %s total\033[0m" "$active" "$stale" "$total_fmt"
    if [[ -n "$latest_5h" ]]; then
      reset_str=""
      if [[ -n "$latest_reset" && "$latest_reset" != "0" ]]; then
        remaining=$(( latest_reset - now ))
        (( remaining > 0 )) && reset_str=" (Reset in $(( remaining / 60 ))min)"
      fi
      printf "  \033[2m5h:%s%% 7d:%s%%%s\033[0m" "${latest_5h%.*}" "${latest_7d%.*}" "$reset_str"
    fi
    printf '\n\n'
    ;;

  update)
    if ! git -C "$CLAUDII_HOME" rev-parse --git-dir >/dev/null 2>&1; then
      printf 'claudii: not a git repo — install via:\n'
      printf '  git clone https://github.com/bmmmm/claudii\n'; exit 1
    fi
    git -C "$CLAUDII_HOME" pull --ff-only
    printf '\033[0;32m✓ Updated. Run: claudii restart\033[0m\n'
    ;;

  doctor)
    _cfg_init
    local ok="\033[0;32m✓\033[0m"
    local warn="\033[0;33m⚠\033[0m"
    local fail="\033[0;31m✗\033[0m"
    printf '\n'
    printf '  \033[0;36mclaudii doctor\033[0m\n\n'

    # 1. Claude Code
    if command -v claude >/dev/null 2>&1; then
      claude_ver=$(claude --version 2>/dev/null | head -1 || echo "unknown")
      printf "  $ok Claude Code %s\n" "$claude_ver"
    else
      printf "  $fail Claude Code not found  →  install from https://claude.ai/download\n"
    fi

    # 2. jq
    if command -v jq >/dev/null 2>&1; then
      jq_ver=$(jq --version 2>/dev/null || echo "unknown")
      printf "  $ok jq %s\n" "$jq_ver"
    else
      printf "  $fail jq not installed  →  brew install jq\n"
    fi

    # 3. Sessionline config
    settings="${HOME}/.claude/settings.json"
    if [[ ! -f "$settings" ]]; then
      printf "  $warn Sessionline not configured  →  claudii sessionline on\n"
    elif jq -e '.statusLine.command == "claudii-sessionline"' "$settings" >/dev/null 2>&1; then
      printf "  $ok Sessionline configured\n"
    elif jq -e '.statusLine' "$settings" >/dev/null 2>&1; then
      other=$(jq -r '.statusLine.command // "unknown"' "$settings")
      printf "  $warn Sessionline: other command (%s)  →  claudii sessionline on\n" "$other"
    else
      printf "  $warn Sessionline not configured  →  claudii sessionline on\n"
    fi

    # 4. Cache directory
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    if [[ -d "$cache_dir" ]]; then
      cache_count=$(ls -1 "$cache_dir" 2>/dev/null | wc -l | tr -d ' ')
      printf "  $ok Cache directory exists (%s files)\n" "$cache_count"
    else
      printf "  $warn Cache directory missing  →  it will be created on first status check\n"
    fi

    # 5. Completions — check if _claudii exists in the completions dir
    comp_dir="$CLAUDII_HOME/completions"
    if [[ -f "$comp_dir/_claudii" ]]; then
      printf "  $ok Completions file present (%s)\n" "$comp_dir"
    else
      printf "  $fail Completions not found  →  add to .zshrc: fpath+=(%s)\n" "$comp_dir"
    fi

    # 6. Plugin loaded
    if [[ -n "${CLAUDII_HOME:-}" ]]; then
      printf "  $ok Plugin loaded (CLAUDII_HOME=%s)\n" "$CLAUDII_HOME"
    else
      printf "  $warn CLAUDII_HOME not set  →  source claudii.plugin.zsh in .zshrc\n"
    fi

    # 7. Version
    printf "  $ok claudii v%s\n" "$VERSION"

    # 8. Updates (git only, non-fatal)
    if git -C "$CLAUDII_HOME" rev-parse --git-dir >/dev/null 2>&1; then
      git -C "$CLAUDII_HOME" fetch --quiet origin main 2>/dev/null || true
      local_ref=$(git -C "$CLAUDII_HOME" rev-parse HEAD 2>/dev/null)
      remote_ref=$(git -C "$CLAUDII_HOME" rev-parse origin/main 2>/dev/null || echo "")
      if [[ -z "$remote_ref" ]]; then
        printf "  $warn Update check failed (no remote/network)\n"
      elif [[ "$local_ref" == "$remote_ref" ]]; then
        printf "  $ok Up to date\n"
      else
        behind=$(git -C "$CLAUDII_HOME" rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
        printf "  $warn %s commit(s) behind origin/main  →  claudii update\n" "$behind"
      fi
    else
      printf "  $warn Not a git repo — skipping update check\n"
    fi

    printf '\n'
    ;;

  metrics)
    echo "claudii metrics ist eine zsh-Shell-Funktion."
    echo "Führe sie direkt im Terminal aus (nicht als Subprozess)."
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    echo "Unknown command: $1"
    usage; exit 1
    ;;
esac
