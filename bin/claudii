#!/bin/bash
# claudii — Claude Interaction Intelligence CLI
# Usage: claudii <command> [args]

set -euo pipefail

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
VERSION="0.5.0"

# TTY detection — 1 if stdout is a terminal, 0 if piped
_TTY=0
[ -t 1 ] && _TTY=1

# Explicit output format flag (--json / --tsv), parsed before alias expansion
_FORMAT=""
_args_filtered=()
for _arg in "$@"; do
  case "$_arg" in
    --json) _FORMAT="json" ;;
    --tsv)  _FORMAT="tsv"  ;;
    *)      _args_filtered+=("$_arg") ;;
  esac
done
set -- "${_args_filtered[@]+"${_args_filtered[@]}"}"
unset _args_filtered _arg

# Returns 0 (true) when output should be plain (no ANSI colors):
# either piped without an explicit format flag, or an explicit --json/--tsv flag is set.
_plain() { [[ "$_TTY" -eq 0 ]] || [[ -n "$_FORMAT" ]]; }

command -v jq >/dev/null 2>&1 || {
  echo "claudii: jq nicht gefunden. Install: brew install jq" >&2; exit 1
}

# Config helper — sets CONFIG, CONFIG_DIR, DEFAULTS in calling scope
_cfg_init() {
  CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
  CONFIG="$CONFIG_DIR/config.json"
  DEFAULTS="$CLAUDII_HOME/config/defaults.json"
  [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
  [[ -f "$CONFIG" ]] || cp "$DEFAULTS" "$CONFIG"
}

# Validate config key — alphanumeric, dots, underscores only (prevents jq injection)
_validate_key() { [[ "$1" =~ ^[a-zA-Z0-9._]+$ ]] || { echo "Invalid key: $1" >&2; return 1; }; }

# Config value lookup — user config first, falls back to defaults.json
_cfgget() {
  local key="$1" val
  _validate_key "$key" || return 1
  val=$(jq -r ".$key // empty" "$CONFIG" 2>/dev/null)
  [[ -z "$val" ]] && val=$(jq -r ".$key // empty" "$DEFAULTS" 2>/dev/null)
  echo "$val"
}

usage() {
  local d="\033[38;5;240m›\033[0m"  # dim separator
  printf '\n'
  printf '  \033[0;36mclaudii\033[0m \033[38;5;213mv%s\033[0m — Claude Interaction Intelligence\n' "$VERSION"
  printf '\n'
  printf '  \033[38;5;213maliases\033[0m\n'
  printf "    %-5s  %-7s  %-6s  $d %s\n" "cl"  "sonnet" "high"   "default"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clo" "opus"   "high"   "complex tasks"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clm" "opus"   "max"    "max effort"
  printf "    %-5s  %-7s  %-6s  $d %s\n" "clq" "sonnet" "medium" "search  (claudii search ['query'])"
  printf "    %-5s  %-21s  $d %s\n"      "clh" ""                 "alias table + live status"
  printf '\n'
  printf '  \033[38;5;213mClaudeStatus\033[0m                              RPROMPT\n'
  printf "    %-33s $d %s\n" "on | off"                    "enable/disable"
  printf "    %-33s $d %s\n" "status [5m|15m|30m]"         "live model check · refresh interval"
  printf "    %-33s $d %s\n" "show model [add|rm|<names>]" "select which models to monitor"
  printf '\n'
  printf "  \033[38;5;213mSessionline\033[0m                               inside Claude\n"
  printf "    %-33s $d %s\n" "sessionline [on|off]"        "context · cost · tokens · rate limits"
  printf "    %-33s $d %s\n" "sessions"                    "active sessions · costs · rate limits"
  printf '\n'
  printf '  \033[38;5;213mtools\033[0m\n'
  printf '    config [get|set|reset|export|import]\n'
  printf "    doctor · cost · stats · trends · debug · metrics · restart · components · about\n"
  printf "    continue [--launch|--resume]  — session handoff\n"
  printf "    agents  — list ~/.claude/agents/*.md (clorch, cle)\n"
  printf "    watch [start|stop|status]  — rate-limit reset notifications\n"
  printf '\n'
  printf '  \033[38;5;213mshortcuts\033[0m\n'
  printf "  s=status  ss=sessions  c=cost  t=trends  d=doctor\n"
  printf '\n'
  printf '  \033[38;5;213mman claudii\033[0m  full reference\n'
  printf '\n'
}

# Shorthand aliases — expand before main case statement
case "${1:-}" in
  s)  set -- status    "${@:2}" ;;
  ss) set -- sessions  "${@:2}" ;;
  c)  set -- cost      "${@:2}" ;;
  t)  set -- trends    "${@:2}" ;;
  d)  set -- doctor    "${@:2}" ;;
esac

case "${1:-}" in
  on)
    _cfg_init
    echo "$(jq '.statusline.enabled = true' "$CONFIG")" > "$CONFIG"
    echo -e "\033[0;32mClaudeStatus aktiviert\033[0m"
    ;;
  off)
    _cfg_init
    echo "$(jq '.statusline.enabled = false' "$CONFIG")" > "$CONFIG"
    echo -e "\033[0;33mClaudeStatus deaktiviert\033[0m"
    ;;
  status)
    _cfg_init
    case "${2:-}" in
      *m|*[0-9])
        interval="${2:-}"
        [[ "$interval" == *m ]] && seconds=$(( ${interval%m} * 60 )) || seconds="$interval"
        if ! [[ "$seconds" =~ ^[0-9]+$ ]] || (( seconds < 30 )); then
          echo "Ungültiges Intervall: $interval (mindestens 30s)"; exit 1
        fi
        echo "$(jq --argjson v "$seconds" '.status.cache_ttl = $v' "$CONFIG")" > "$CONFIG"
        echo "Refresh-Intervall: ${interval} (${seconds}s)"
        ;;
      "")
        rm -f "${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}/status-models"
        "$CLAUDII_HOME/bin/claudii-status"
        exit_code=$?
        if [[ "$_FORMAT" == "json" ]]; then
          cache_file="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}/status-models"
          if [[ -f "$cache_file" ]]; then
            jq -Rn '[inputs | select(length > 0) | split("=") | {"model": .[0], "status": .[1]}]' < "$cache_file"
          else
            echo "[]"
          fi
        else
          [[ $exit_code -eq 0 ]] && echo -e "\033[0;32m✓ Alle Modelle verfügbar\033[0m"
        fi
        ;;
      *)
        echo "Unbekannte status-Option: ${2}"
        echo "Usage: claudii status [5m|15m|30m]"; exit 1
        ;;
    esac
    ;;

  show)
    _cfg_init
    case "${2:-}" in
      model)
        case "${3:-}" in
          add)
            model="${4:?Usage: claudii show model add <model>}"
            current=$(_cfgget statusline.models)
            if echo "$current" | tr ',' '\n' | grep -qx "$model"; then
              echo "$model ist bereits in der Liste: $current"
            else
              new_models="${current},${model}"
              echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
              echo -e "\033[0;32mModelle: $new_models\033[0m"
            fi
            ;;
          rm|remove)
            model="${4:?Usage: claudii show model rm <model>}"
            current=$(_cfgget statusline.models)
            new_models=$(echo "$current" | tr ',' '\n' | grep -vx "$model" | tr '\n' ',' | sed 's/,$//')
            if [[ "$new_models" == "$current" ]]; then
              echo "$model nicht gefunden in: $current"; exit 1
            fi
            echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
            echo -e "\033[0;32mModelle: ${new_models:-keine}\033[0m"
            ;;
          "")
            current=$(_cfgget statusline.models)
            echo "Angezeigte Modelle: $current"
            ;;
          *)
            # All remaining args are model names to set directly
            new_models=$(IFS=,; echo "${*:3}")
            echo "$(jq --arg v "$new_models" '.statusline.models = $v' "$CONFIG")" > "$CONFIG"
            echo -e "\033[0;32mModelle: $new_models\033[0m"
            ;;
        esac
        ;;
      ""|*)
        echo "Usage: claudii show model [add|rm|<model> ...]"
        ;;
    esac
    ;;

  sessionline)
    SETTINGS="${HOME}/.claude/settings.json"
    case "${2:-}" in
      on)
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Fehler: $SETTINGS nicht gefunden — ist Claude Code installiert?"; exit 1
        fi
        if jq -e '.statusLine.command == "claudii-sessionline"' "$SETTINGS" >/dev/null 2>&1; then
          echo -e "\033[0;36mSessionline bereits aktiv\033[0m"
        else
          echo "$(jq '. + {"statusLine": {"type": "command", "command": "claudii-sessionline"}}' "$SETTINGS")" > "$SETTINGS"
          echo -e "\033[0;32mSessionline aktiviert\033[0m  → Claude Code neu starten zum Aktivieren"
        fi
        ;;
      off)
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Fehler: $SETTINGS nicht gefunden"; exit 1
        fi
        if jq -e '.statusLine' "$SETTINGS" >/dev/null 2>&1; then
          echo "$(jq 'del(.statusLine)' "$SETTINGS")" > "$SETTINGS"
          echo -e "\033[0;33mSessionline deaktiviert\033[0m  → Claude Code neu starten"
        else
          echo "Sessionline war nicht konfiguriert"
        fi
        ;;
      "")
        if [[ ! -f "$SETTINGS" ]]; then
          echo "Sessionline: nicht konfiguriert  ($SETTINGS fehlt)"
        elif jq -e '.statusLine.command == "claudii-sessionline"' "$SETTINGS" >/dev/null 2>&1; then
          echo -e "Sessionline: \033[0;32maktiv\033[0m  ($SETTINGS)"
        elif jq -e '.statusLine' "$SETTINGS" >/dev/null 2>&1; then
          other=$(jq -r '.statusLine.command // .statusLine' "$SETTINGS")
          echo -e "Sessionline: \033[0;33mandere Konfiguration\033[0m  ($other)"
        else
          echo "Sessionline: nicht konfiguriert"
          echo "  → claudii sessionline on  zum Aktivieren"
        fi
        ;;
      *)
        echo "Usage: claudii sessionline [on|off]"; exit 1
        ;;
    esac
    ;;

  # Backwards compatibility
  install-sessionline)
    exec "$0" sessionline on
    ;;

  config)
    _cfg_init
    case "${2:-}" in
      get)
        key="${3:?Usage: claudii config get <key>}"
        _validate_key "$key" || exit 1
        jq_path=".$(echo "$key" | sed 's/\././g')"
        val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$CONFIG" 2>/dev/null)
        [[ -z "$val" ]] && val=$(jq -r "if ($jq_path | type) != \"null\" then ($jq_path | tostring) else empty end" "$DEFAULTS" 2>/dev/null)
        echo "$val"
        ;;
      set)
        key="${3:?Usage: claudii config set <key> <value>}"
        _validate_key "$key" || exit 1
        value="${4:?Usage: claudii config set <key> <value>}"
        jq_path=".$(echo "$key" | sed 's/\././g')"
        if [[ "$value" =~ ^[0-9]+$ ]] || [[ "$value" == "true" ]] || [[ "$value" == "false" ]]; then
          echo "$(jq --argjson v "$value" "$jq_path = \$v" "$CONFIG")" > "$CONFIG"
        else
          echo "$(jq --arg v "$value" "$jq_path = \$v" "$CONFIG")" > "$CONFIG"
        fi
        echo "Set $key = $value"
        ;;
      reset)
        cp "$DEFAULTS" "$CONFIG"
        echo "Config reset to defaults"
        ;;
      export)
        file="${3:-}"
        if [[ -n "$file" ]]; then
          cp "$CONFIG" "$file"
          echo "Config exportiert nach $file"
        else
          cat "$CONFIG"
        fi
        ;;
      import)
        file="${3:?Usage: claudii config import <file>}"
        [[ -f "$file" ]] || { echo "Datei nicht gefunden: $file"; exit 1; }
        jq '.' "$file" >/dev/null 2>&1 || { echo "Kein gültiges JSON: $file"; exit 1; }
        cp "$CONFIG" "${CONFIG}.bak"
        cp "$file" "$CONFIG"
        echo "Config importiert aus $file  (Backup: ${CONFIG}.bak)"
        ;;
      *)
        echo "User config: $CONFIG"
        echo ""
        jq '.' "$CONFIG"
        ;;
    esac
    ;;

  debug)
    _cfg_init
    if [[ -z "${2:-}" ]]; then
      current=$(jq -r 'if (.debug.level | type) != "null" then .debug.level else "off" end' "$CONFIG")
      echo "debug level: $current"
      echo "Valid levels: off, error, warn, info, debug"
    else
      case "${2}" in
        off|error|warn|info|debug)
          echo "$(jq ".debug.level = \"${2}\"" "$CONFIG")" > "$CONFIG"
          echo "Debug level: ${2}"
          ;;
        *)
          echo "Unbekannter Level: ${2}"
          echo "Valid levels: off, error, warn, info, debug"; exit 1
          ;;
      esac
    fi
    ;;

  cost)
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    shopt -s nullglob
    session_files=("$cache_dir"/session-*)
    shopt -u nullglob

    if [[ ${#session_files[@]} -eq 0 ]]; then
      echo "No session data found. Start a Claude session first."
      exit 0
    fi

    now=$(date +%s)
    cutoff=$(( now - 86400 ))

    # Associative arrays for per-model totals
    declare -A today_cost today_count alltime_cost alltime_count

    for f in "${session_files[@]}"; do
      [[ -f "$f" ]] || continue

      # Read key=value pairs
      cost="" model=""
      while IFS='=' read -r key val; do
        case "$key" in
          cost)  cost="$val"  ;;
          model) model="$val" ;;
        esac
      done < "$f"

      [[ -z "$model" ]] && continue
      [[ -z "$cost" ]]  && cost="0"

      # Normalize model name to short form
      case "$model" in
        *[Oo]pus*)   short="Opus"   ;;
        *[Ss]onnet*) short="Sonnet" ;;
        *[Hh]aiku*)  short="Haiku"  ;;
        *)           short="$model" ;;
      esac

      # Get mtime
      if stat -f%m "$f" >/dev/null 2>&1; then
        mtime=$(stat -f%m "$f")
      else
        mtime=$(stat -c%Y "$f")
      fi

      # Accumulate all-time
      alltime_cost[$short]=$(printf '%.4f' \
        "$(echo "${alltime_cost[$short]:-0} + $cost" | bc -l 2>/dev/null || echo "${alltime_cost[$short]:-0}")")
      alltime_count[$short]=$(( ${alltime_count[$short]:-0} + 1 ))

      # Accumulate today (mtime within last 24h)
      if (( mtime >= cutoff )); then
        today_cost[$short]=$(printf '%.4f' \
          "$(echo "${today_cost[$short]:-0} + $cost" | bc -l 2>/dev/null || echo "${today_cost[$short]:-0}")")
        today_count[$short]=$(( ${today_count[$short]:-0} + 1 ))
      fi
    done

    if [[ "$_FORMAT" == "json" ]]; then
      # Build JSON with today + alltime breakdown
      today_obj="{}"
      alltime_obj="{}"
      for m in "${!today_cost[@]}"; do
        today_obj=$(echo "$today_obj" | jq --arg m "$m" --argjson c "${today_cost[$m]}" --argjson n "${today_count[$m]}" \
          '.[$m] = {cost: $c, sessions: $n}')
      done
      for m in "${!alltime_cost[@]}"; do
        alltime_obj=$(echo "$alltime_obj" | jq --arg m "$m" --argjson c "${alltime_cost[$m]}" --argjson n "${alltime_count[$m]}" \
          '.[$m] = {cost: $c, sessions: $n}')
      done
      jq -n --argjson today "$today_obj" --argjson alltime "$alltime_obj" \
        '{"today": $today, "alltime": $alltime}'
      exit 0
    elif [[ "$_FORMAT" == "tsv" ]]; then
      printf "period\tmodel\tcost\tsessions\n"
      for m in "${!today_cost[@]}"; do
        printf "today\t%s\t%s\t%s\n" "$m" "${today_cost[$m]}" "${today_count[$m]}"
      done
      for m in "${!alltime_cost[@]}"; do
        printf "alltime\t%s\t%s\t%s\n" "$m" "${alltime_cost[$m]}" "${alltime_count[$m]}"
      done
      exit 0
    fi

    cyan='\033[0;36m'
    reset='\033[0m'
    line='  ─────────────────'

    _print_section() {
      local -n _costs=$1 _counts=$2
      local total=0 has_data=0
      for m in "${!_costs[@]}"; do
        c="${_costs[$m]}"
        n="${_counts[$m]}"
        printf "    %-10s ${cyan}\$%s${reset}  (%s session%s)\n" \
          "$m" "$(printf '%.2f' "$c")" "$n" "$( (( n != 1 )) && echo 's' || true)"
        total=$(echo "$total + $c" | bc -l)
        has_data=1
      done
      if (( has_data )); then
        printf '%s\n' "$line"
        printf "    %-10s ${cyan}\$%s${reset}\n" "Total" "$(printf '%.2f' "$total")"
      else
        printf "    (none)\n"
      fi
    }

    printf '\n'
    printf '  \033[38;5;213mToday\033[0m\n'
    _print_section today_cost today_count
    printf '\n'
    printf '  \033[38;5;213mAll time\033[0m\n'
    _print_section alltime_cost alltime_count
    printf '\n'
    ;;

  stats)
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    shopt -s nullglob
    session_files=("$cache_dir"/session-*)
    shopt -u nullglob

    if [[ ${#session_files[@]} -eq 0 ]]; then
      echo "No session data found. Start a Claude session first."
      exit 0
    fi

    now=$(date +%s)
    cutoff=$(( now - 86400 ))

    # Associative arrays for per-model totals
    declare -A today_cost today_count alltime_cost alltime_count

    for f in "${session_files[@]}"; do
      [[ -f "$f" ]] || continue

      # Read key=value pairs
      cost="" model=""
      while IFS='=' read -r key val; do
        case "$key" in
          cost)  cost="$val"  ;;
          model) model="$val" ;;
        esac
      done < "$f"

      [[ -z "$model" ]] && continue
      [[ -z "$cost" ]]  && cost="0"

      # Normalize model name to short form
      case "$model" in
        *[Oo]pus*)   short="Opus"   ;;
        *[Ss]onnet*) short="Sonnet" ;;
        *[Hh]aiku*)  short="Haiku"  ;;
        *)           short="$model" ;;
      esac

      # Get mtime
      if stat -f%m "$f" >/dev/null 2>&1; then
        mtime=$(stat -f%m "$f")
      else
        mtime=$(stat -c%Y "$f")
      fi

      # Accumulate all-time
      alltime_cost[$short]=$(printf '%.4f' \
        "$(echo "${alltime_cost[$short]:-0} + $cost" | bc -l 2>/dev/null || echo "${alltime_cost[$short]:-0}")")
      alltime_count[$short]=$(( ${alltime_count[$short]:-0} + 1 ))

      # Accumulate today (mtime within last 24h)
      if (( mtime >= cutoff )); then
        today_cost[$short]=$(printf '%.4f' \
          "$(echo "${today_cost[$short]:-0} + $cost" | bc -l 2>/dev/null || echo "${today_cost[$short]:-0}")")
        today_count[$short]=$(( ${today_count[$short]:-0} + 1 ))
      fi
    done

    cyan='\033[0;36m'
    reset='\033[0m'
    line='  ─────────────────────────────────'

    # Count totals for section headers
    today_total_count=0
    for m in "${!today_count[@]}"; do
      today_total_count=$(( today_total_count + today_count[$m] ))
    done
    alltime_total_count=0
    for m in "${!alltime_count[@]}"; do
      alltime_total_count=$(( alltime_total_count + alltime_count[$m] ))
    done

    _stats_section() {
      local -n _costs=$1 _counts=$2
      local total=0 has_data=0
      for m in Opus Sonnet Haiku; do
        [[ -z "${_counts[$m]+x}" ]] && continue
        c="${_costs[$m]}"
        n="${_counts[$m]}"
        printf "    %-10s %2d session%s  ${cyan}\$%s${reset}\n" \
          "$m" "$n" "$( (( n != 1 )) && echo 's' || echo ' ')" "$(printf '%.2f' "$c")"
        total=$(echo "$total + $c" | bc -l)
        has_data=1
      done
      # Catch any unknown model names not in the ordered list above
      for m in "${!_counts[@]}"; do
        [[ "$m" == "Opus" || "$m" == "Sonnet" || "$m" == "Haiku" ]] && continue
        c="${_costs[$m]}"
        n="${_counts[$m]}"
        printf "    %-10s %2d session%s  ${cyan}\$%s${reset}\n" \
          "$m" "$n" "$( (( n != 1 )) && echo 's' || echo ' ')" "$(printf '%.2f' "$c")"
        total=$(echo "$total + $c" | bc -l)
        has_data=1
      done
      if (( has_data )); then
        printf '%s\n' "$line"
        local tot_count=0
        for m in "${!_counts[@]}"; do tot_count=$(( tot_count + _counts[$m] )); done
        printf "    %-10s %2d session%s  ${cyan}\$%s${reset}\n" \
          "Total" "$tot_count" "$( (( tot_count != 1 )) && echo 's' || echo ' ')" "$(printf '%.2f' "$total")"
      else
        printf "    (none)\n"
      fi
    }

    printf '\n'
    printf '  \033[0;36mclaudii stats\033[0m\n'
    printf '\n'
    printf '  \033[38;5;213mToday\033[0m (%d session%s)\n' \
      "$today_total_count" "$( (( today_total_count != 1 )) && echo 's' || true)"
    _stats_section today_cost today_count
    printf '\n'
    printf '  \033[38;5;213mAll time\033[0m (%d session%s)\n' \
      "$alltime_total_count" "$( (( alltime_total_count != 1 )) && echo 's' || true)"
    _stats_section alltime_cost alltime_count

    # Model split (all-time)
    if [[ ${#alltime_count[@]} -gt 0 ]]; then
      printf '\n'
      split_str=""
      for m in Opus Sonnet Haiku; do
        [[ -z "${alltime_count[$m]+x}" ]] && continue
        pct=$(printf '%.0f' "$(echo "${alltime_count[$m]} * 100 / $alltime_total_count" | bc -l)")
        [[ -n "$split_str" ]] && split_str+=" · "
        split_str+="${m} ${pct}%"
      done
      # Unknown models
      for m in "${!alltime_count[@]}"; do
        [[ "$m" == "Opus" || "$m" == "Sonnet" || "$m" == "Haiku" ]] && continue
        pct=$(printf '%.0f' "$(echo "${alltime_count[$m]} * 100 / $alltime_total_count" | bc -l)")
        [[ -n "$split_str" ]] && split_str+=" · "
        split_str+="${m} ${pct}%"
      done
      printf '  Model split: %s\n' "$split_str"
    fi
    printf '\n'
    ;;

  trends)
    # Flight Recorder — weekly/daily aggregates from persistent history
    history_file="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}/history.tsv"

    if [[ ! -f "$history_file" ]] || [[ ! -s "$history_file" ]]; then
      echo "No history data yet. Start a Claude session with sessionline enabled."
      exit 0
    fi

    # Strategy: bash does date conversions (portable macOS/GNU), awk does
    # all aggregation and formatting (no associative arrays needed in bash).
    now=$(date +%s)

    # Detect macOS vs GNU date
    if date -j -f '%s' "$now" '+%u' >/dev/null 2>&1; then
      _date_cmd="macos"
    else
      _date_cmd="gnu"
    fi

    # Precompute date boundaries
    if [[ "$_date_cmd" == "macos" ]]; then
      today_str=$(date -j -f '%s' "$now" '+%Y-%m-%d')
      today_dow=$(date -j -f '%s' "$now" '+%u')  # 1=Mon..7=Sun
      this_monday_ts=$(( now - (today_dow - 1) * 86400 ))
      this_monday_str=$(date -j -f '%s' "$this_monday_ts" '+%Y-%m-%d')
      last_monday_ts=$(( this_monday_ts - 7 * 86400 ))
      last_monday_str=$(date -j -f '%s' "$last_monday_ts" '+%Y-%m-%d')
      last_sunday_ts=$(( this_monday_ts - 86400 ))
      last_sunday_str=$(date -j -f '%s' "$last_sunday_ts" '+%Y-%m-%d')
      thirty_days_ago_ts=$(( now - 30 * 86400 ))
      thirty_days_ago_str=$(date -j -f '%s' "$thirty_days_ago_ts" '+%Y-%m-%d')
    else
      today_str=$(date -d "@$now" '+%Y-%m-%d')
      today_dow=$(date -d "@$now" '+%u')
      this_monday_ts=$(( now - (today_dow - 1) * 86400 ))
      this_monday_str=$(date -d "@$this_monday_ts" '+%Y-%m-%d')
      last_monday_ts=$(( this_monday_ts - 7 * 86400 ))
      last_monday_str=$(date -d "@$last_monday_ts" '+%Y-%m-%d')
      last_sunday_ts=$(( this_monday_ts - 86400 ))
      last_sunday_str=$(date -d "@$last_sunday_ts" '+%Y-%m-%d')
      thirty_days_ago_ts=$(( now - 30 * 86400 ))
      thirty_days_ago_str=$(date -d "@$thirty_days_ago_ts" '+%Y-%m-%d')
    fi

    # Build week_days string: "date:name,date:name,..." for Mon..Sun (up to today)
    _week_days=""
    for (( d=0; d<7; d++ )); do
      day_ts=$(( this_monday_ts + d * 86400 ))
      if [[ "$_date_cmd" == "macos" ]]; then
        _wd=$(date -j -f '%s' "$day_ts" '+%Y-%m-%d')
        _wn=$(date -j -f '%s' "$day_ts" '+%a')
      else
        _wd=$(date -d "@$day_ts" '+%Y-%m-%d')
        _wn=$(date -d "@$day_ts" '+%a')
      fi
      [[ -n "$_week_days" ]] && _week_days+=","
      _week_days+="${_wd}:${_wn}"
      [[ "$_wd" == "$today_str" ]] && break
    done

    # Step 1: Convert timestamps to YYYY-MM-DD + normalize model names
    # Use a while loop (portable across macOS/GNU date)
    _trends_augmented=$(
      while IFS=$'\t' read -r ts _t_model cost ctx rate sid; do
        [[ -z "$ts" || "$ts" == "timestamp" ]] && continue
        if [[ "$_date_cmd" == "macos" ]]; then
          _t_day=$(date -j -f '%s' "$ts" '+%Y-%m-%d' 2>/dev/null) || continue
        else
          _t_day=$(date -d "@$ts" '+%Y-%m-%d' 2>/dev/null) || continue
        fi
        # Normalize model name (opening parens prevent ) from closing $())
        case "$_t_model" in
          (*[Oo]pus*)   _t_short="Opus"   ;;
          (*[Ss]onnet*) _t_short="Sonnet" ;;
          (*[Hh]aiku*)  _t_short="Haiku"  ;;
          (*)           _t_short="$_t_model" ;;
        esac
        printf '%s\t%s\t%s\t%s\n' "$_t_day" "$_t_short" "$cost" "$sid"
      done < "$history_file"
    )

    # Step 2: awk does dedup, aggregation, and ALL output formatting
    # No bash associative arrays needed — awk handles everything
    echo "$_trends_augmented" | awk -F'\t' \
      -v today="$today_str" \
      -v this_mon="$this_monday_str" \
      -v last_mon="$last_monday_str" \
      -v last_sun="$last_sunday_str" \
      -v thirty="$thirty_days_ago_str" \
      -v week_days="$_week_days" \
      -v fmt="${_FORMAT:-}" \
      '
    {
      day = $1; model = $2; cost = $3 + 0; sid = $4
      if (sid == "") next

      # Dedup: take max cost per session_id
      key = sid
      if (!(key in max_cost) || cost > max_cost[key]) {
        max_cost[key] = cost
        sid_day[key] = day
        sid_model[key] = model
      }
    }
    END {
      # Aggregate deduplicated sessions by day
      for (key in max_cost) {
        day = sid_day[key]
        model = sid_model[key]
        cost = max_cost[key]

        day_cost[day] += cost
        day_sessions[day]++
        day_model_sessions[day, model]++

        # 30d model split
        if (day >= thirty) {
          model_sessions_30d[model]++
          total_sessions_30d++
        }
      }

      # Costliest day (30d)
      max_day_cost = 0; max_day = ""
      for (d in day_cost) {
        if (d >= thirty && day_cost[d] > max_day_cost) {
          max_day_cost = day_cost[d]
          max_day = d
        }
      }

      # This week + last week totals
      tw_cost = 0; tw_sessions = 0
      lw_cost = 0; lw_sessions = 0
      for (d in day_cost) {
        if (d >= this_mon) { tw_cost += day_cost[d]; tw_sessions += day_sessions[d] }
        if (d >= last_mon && d <= last_sun) { lw_cost += day_cost[d]; lw_sessions += day_sessions[d] }
      }

      # Parse week_days string into arrays: wd_date[0..n], wd_name[0..n]
      n_days = split(week_days, _wd_parts, ",")
      for (i = 1; i <= n_days; i++) {
        split(_wd_parts[i], _dn, ":")
        wd_date[i] = _dn[1]
        wd_name[i] = _dn[2]
      }

      # --- JSON output ---
      if (fmt == "json") {
        printf "{"

        # this_week array
        printf "\"this_week\":["
        for (i = 1; i <= n_days; i++) {
          d = wd_date[i]
          if (i > 1) printf ","
          printf "{\"date\":\"%s\",\"day\":\"%s\",\"cost\":%.2f,\"sessions\":%d}", \
            d, wd_name[i], (d in day_cost ? day_cost[d] : 0), (d in day_sessions ? day_sessions[d] : 0)
        }
        printf "],"

        printf "\"this_week_total\":%.2f,", tw_cost
        printf "\"last_week\":{\"cost\":%.2f,\"sessions\":%d},", lw_cost, lw_sessions

        # model_split_30d
        printf "\"model_split_30d\":{"
        first = 1
        for (m in model_sessions_30d) {
          pct = (total_sessions_30d > 0) ? int(model_sessions_30d[m] * 100 / total_sessions_30d + 0.5) : 0
          if (!first) printf ","
          printf "\"%s\":{\"sessions\":%d,\"percent\":%d}", m, model_sessions_30d[m], pct
          first = 0
        }
        printf "},"

        # costliest_day_30d
        if (max_day != "") {
          printf "\"costliest_day_30d\":{\"date\":\"%s\",\"cost\":%.2f}", max_day, max_day_cost
        } else {
          printf "\"costliest_day_30d\":null"
        }

        printf "}\n"
        exit
      }

      # --- Pretty output ---
      cyan  = "\033[0;36m"
      dim   = "\033[38;5;240m"
      pink  = "\033[38;5;213m"
      reset = "\033[0m"
      sep   = "  \342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200\342\224\200"

      printf "\n"
      printf "  %sclaudii trends%s\n\n", cyan, reset
      printf "  %sThis week%s (Mon\xe2\x80\x93Sun)\n", pink, reset

      for (i = 1; i <= n_days; i++) {
        d = wd_date[i]
        label = (d == today) ? "Today" : wd_name[i]

        if (!(d in day_cost) || day_cost[d] == 0) {
          printf "    %-7s %s$0.00%s  %s\342\200\224%s\n", label, dim, reset, dim, reset
        } else {
          # Build model detail
          detail = ""
          # Check known models in fixed order
          models_order[1] = "Opus"; models_order[2] = "Sonnet"; models_order[3] = "Haiku"
          for (mi = 1; mi <= 3; mi++) {
            m = models_order[mi]
            if ((d, m) in day_model_sessions) {
              if (detail != "") detail = detail ", "
              detail = detail day_model_sessions[d, m] " " m
            }
          }
          # Unknown models
          for (combo in day_model_sessions) {
            split(combo, cp, SUBSEP)
            if (cp[1] == d && cp[2] != "Opus" && cp[2] != "Sonnet" && cp[2] != "Haiku") {
              if (detail != "") detail = detail ", "
              detail = detail day_model_sessions[combo] " " cp[2]
            }
          }
          sess = day_sessions[d]
          s_suffix = (sess != 1) ? "s" : ""
          printf "    %-7s %s$%.2f%s  (%d session%s, %s)\n", \
            label, cyan, day_cost[d], reset, sess, s_suffix, detail
        }
      }

      printf "%s\n", sep
      printf "    %-7s %s$%.2f%s\n", "Total", cyan, tw_cost, reset

      # Last week
      printf "\n  %sLast week%s\n", pink, reset
      if (lw_sessions > 0) {
        s_suffix = (lw_sessions != 1) ? "s" : ""
        printf "    Total  %s$%.2f%s  (%d session%s)\n", cyan, lw_cost, reset, lw_sessions, s_suffix
      } else {
        printf "    %s(no data)%s\n", dim, reset
      }

      # Model split (30d)
      if (total_sessions_30d > 0) {
        printf "\n"
        split_str = ""
        # Fixed order
        for (mi = 1; mi <= 3; mi++) {
          m = models_order[mi]
          if (m in model_sessions_30d) {
            pct = int(model_sessions_30d[m] * 100 / total_sessions_30d + 0.5)
            if (split_str != "") split_str = split_str " \302\267 "
            split_str = split_str m " " pct "%"
          }
        }
        # Unknown models
        for (m in model_sessions_30d) {
          if (m != "Opus" && m != "Sonnet" && m != "Haiku") {
            pct = int(model_sessions_30d[m] * 100 / total_sessions_30d + 0.5)
            if (split_str != "") split_str = split_str " \302\267 "
            split_str = split_str m " " pct "%"
          }
        }
        printf "  Model split (30d): %s\n", split_str
      }

      # Costliest day
      if (max_day != "") {
        printf "  Costliest day: %s (%s$%.2f%s)\n", max_day, cyan, max_day_cost, reset
      }
      printf "\n"
    }'
    ;;

  continue)
    # Session Handoff — show context from last session, optionally launch new one
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"

    # ── Find the project hash for the current directory ──
    _cwd_hash=$(echo "$PWD" | sed 's|/|-|g; s|^-||')
    _project_dir="$HOME/.claude/projects/-${_cwd_hash}"
    if [[ ! -d "$_project_dir" ]]; then
      # Fallback: search all projects for the most recent transcript
      _project_dir=""
    fi

    # ── Find the latest JSONL transcript ──
    _find_latest_jsonl() {
      local search_dir="$1" latest="" latest_mt=0
      while IFS= read -r f; do
        [[ -f "$f" ]] || continue
        # Skip subagent transcripts — only main session files
        [[ "$f" == */subagents/* ]] && continue
        local mt
        if stat -f%m "$f" >/dev/null 2>&1; then
          mt=$(stat -f%m "$f")
        else
          mt=$(stat -c%Y "$f" 2>/dev/null || echo 0)
        fi
        if (( mt > latest_mt )); then
          latest_mt=$mt
          latest="$f"
        fi
      done < <(find "$search_dir" -maxdepth 2 -name "*.jsonl" -type f 2>/dev/null)
      echo "$latest"
    }

    if [[ -n "$_project_dir" ]]; then
      _transcript=$(_find_latest_jsonl "$_project_dir")
    fi
    if [[ -z "${_transcript:-}" ]]; then
      # Try all projects
      _transcript=$(_find_latest_jsonl "$HOME/.claude/projects")
    fi

    if [[ -z "${_transcript:-}" ]]; then
      echo "No transcript found."
      echo "  Start a Claude session first, then run: claudii continue"
      exit 1
    fi

    # ── Extract session ID from filename ──
    _basename=$(basename "$_transcript" .jsonl)
    _session_id="$_basename"

    # ── Get transcript mtime ──
    if stat -f%m "$_transcript" >/dev/null 2>&1; then
      _tx_mt=$(stat -f%m "$_transcript")
    else
      _tx_mt=$(stat -c%Y "$_transcript" 2>/dev/null || echo 0)
    fi
    _tx_date=$(date -r "$_tx_mt" "+%Y-%m-%d %H:%M" 2>/dev/null || date -d "@$_tx_mt" "+%Y-%m-%d %H:%M" 2>/dev/null || echo "unknown")

    # ── Read session cache for model/cost/context info ──
    _c_model="" _c_ctx="" _c_cost=""
    _cache_file="$cache_dir/session-${_session_id:0:8}"
    if [[ -f "$_cache_file" ]]; then
      _cc=$(cat "$_cache_file" 2>/dev/null) || true
      [[ $'\n'"$_cc" == *$'\n'model=* ]]   && _c_model="${_cc#*model=}"   && _c_model="${_c_model%%$'\n'*}"
      [[ $'\n'"$_cc" == *$'\n'ctx_pct=* ]] && _c_ctx="${_cc#*ctx_pct=}"   && _c_ctx="${_c_ctx%%$'\n'*}"
      [[ $'\n'"$_cc" == *$'\n'cost=* ]]    && _c_cost="${_cc#*cost=}"     && _c_cost="${_c_cost%%$'\n'*}"
    fi

    # ── Extract last N user messages (only actual typed messages, not tool results) ──
    _max_user=5
    _max_chars=500
    _user_msgs=()
    while IFS= read -r msg; do
      [[ -z "$msg" || "$msg" == "null" ]] && continue
      # Skip system-injected messages (XML tags from tool results, usage stats, etc.)
      [[ "$msg" == "<"* ]] && continue
      [[ "$msg" == *"</task-notification>"* ]] && continue
      # Truncate long messages
      if (( ${#msg} > _max_chars )); then
        msg="${msg:0:$_max_chars}..."
      fi
      _user_msgs+=("$msg")
    done < <(
      jq -r '
        select(.type == "user" and .userType == "external") |
        .message.content |
        if type == "string" then
          if length > 0 then . else empty end
        elif type == "array" then
          [.[] | select(.type == "text") | .text] | join("") |
          if length > 0 then . else empty end
        else empty end
      ' "$_transcript" 2>/dev/null | tail -"$_max_user"
    )

    # ── Extract last assistant text message (summary) ──
    _summary=""
    _summary=$(
      jq -r '
        select(.type == "assistant") |
        [.message.content[]? | select(.type == "text") | .text] | join("") |
        if length > 0 then . else empty end
      ' "$_transcript" 2>/dev/null | tail -1
    )
    # Truncate summary to 1000 chars
    if [[ -n "$_summary" ]] && (( ${#_summary} > 1000 )); then
      _summary="${_summary:0:1000}..."
    fi

    # ── Handle subcommands ──
    case "${2:-}" in
      --launch)
        # Launch a new forked session from the last one
        echo "Forking session ${_session_id:0:8}..."
        exec claude --continue --fork-session
        ;;
      --resume)
        # Resume the exact same session (no fork)
        echo "Resuming session ${_session_id:0:8}..."
        exec claude --resume "$_session_id"
        ;;
      "")
        # Default: print context summary
        printf '\n'
        printf '  \033[0;36mclaudii continue\033[0m\n'
        printf '\n'

        # Session info line
        _info="  Last session:"
        [[ -n "$_c_model" ]] && _info+=" \033[1m${_c_model}\033[0m,"
        [[ -n "$_c_ctx" ]]   && _info+=" ${_c_ctx}% context,"
        [[ -n "$_c_cost" && "$_c_cost" != "0" ]] && _info+=" \033[0;36m\$$(printf '%.2f' "$_c_cost")\033[0m,"
        # Remove trailing comma
        _info="${_info%,}"
        printf '%b\n' "$_info"

        printf '  Transcript: \033[38;5;240m%s\033[0m\n' "$_transcript"
        printf '  Updated:    \033[38;5;240m%s\033[0m\n' "$_tx_date"
        printf '\n'

        # User messages
        if [[ ${#_user_msgs[@]} -gt 0 ]]; then
          printf '  \033[38;5;213m── Last %d user message%s ──\033[0m\n' \
            "${#_user_msgs[@]}" "$( (( ${#_user_msgs[@]} != 1 )) && echo 's' || true)"
          _n=1
          for _msg in "${_user_msgs[@]}"; do
            # Replace newlines with spaces for display, trim
            _display=$(echo "$_msg" | tr '\n' ' ' | sed 's/  */ /g; s/^ //; s/ $//')
            printf '  %d. "%s"\n' "$_n" "$_display"
            (( _n++ ))
          done
          printf '\n'
        fi

        # Summary
        if [[ -n "$_summary" ]]; then
          printf '  \033[38;5;213m── Context summary ──\033[0m\n'
          # Print summary with word wrap at ~76 chars, indented
          echo "$_summary" | fold -s -w 72 | while IFS= read -r _line; do
            printf '  %s\n' "$_line"
          done
          printf '\n'
        fi

        # Action hints
        printf '  \033[38;5;240mTo continue:\033[0m\n'
        printf '    claudii continue --launch   fork into new session with context\n'
        printf '    claudii continue --resume   resume the exact same session\n'
        printf '    claude --continue            built-in continue (same session)\n'
        printf '\n'
        ;;
      *)
        echo "Usage: claudii continue [--launch|--resume]"; exit 1
        ;;
    esac
    ;;

  search)
    _cfg_init
    search_dir=$(_cfgget search.dir)
    search_dir="${search_dir/#\~/$HOME}"
    model=$(_cfgget aliases.clq.model)
    effort=$(_cfgget aliases.clq.effort)
    cd "$search_dir"
    exec claude --model "$model" --effort "$effort" "${@:2}"
    ;;

  "")
    # Smart default: show contextual info based on current state
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    now=$(date +%s)

    printf '\n'
    printf '  \033[0;36mclaudii\033[0m \033[38;5;213mv%s\033[0m\n' "$VERSION"
    printf '\n'

    # Collect session data
    shopt -s nullglob
    _sd_files=("$cache_dir"/session-*)
    shopt -u nullglob

    if [[ ${#_sd_files[@]} -eq 0 ]]; then
      # No cache at all
      printf '  No session data yet.\n'
      printf '  Run \033[0;36mclaudii doctor\033[0m to check your setup.\n'
      printf '\n'
      printf '  \033[38;5;240mclaudii help  for all commands\033[0m\n'
      printf '\n'
    else
      # Find most-recent session file and read it
      _sd_latest="" _sd_latest_mt=0
      for _sd_f in "${_sd_files[@]}"; do
        [[ -f "$_sd_f" ]] || continue
        if stat -f%m "$_sd_f" >/dev/null 2>&1; then
          _sd_mt=$(stat -f%m "$_sd_f")
        else
          _sd_mt=$(stat -c%Y "$_sd_f")
        fi
        if (( _sd_mt > _sd_latest_mt )); then
          _sd_latest_mt=$_sd_mt
          _sd_latest=$_sd_f
        fi
      done

      # Parse the latest session file
      _sd_content="" _sd_model="" _sd_ctx="" _sd_cost="" _sd_5h="" _sd_7d="" _sd_reset=""
      if [[ -n "$_sd_latest" ]]; then
        _sd_content=$(cat "$_sd_latest" 2>/dev/null) || true
        [[ $'\n'"$_sd_content" == *$'\n'model=* ]]    && _sd_model="${_sd_content#*model=}"    && _sd_model="${_sd_model%%$'\n'*}"
        [[ $'\n'"$_sd_content" == *$'\n'ctx_pct=* ]]  && _sd_ctx="${_sd_content#*ctx_pct=}"    && _sd_ctx="${_sd_ctx%%$'\n'*}"
        [[ $'\n'"$_sd_content" == *$'\n'cost=* ]]     && _sd_cost="${_sd_content#*cost=}"      && _sd_cost="${_sd_cost%%$'\n'*}"
        [[ $'\n'"$_sd_content" == *$'\n'rate_5h=* ]]  && _sd_5h="${_sd_content#*rate_5h=}"     && _sd_5h="${_sd_5h%%$'\n'*}"
        [[ $'\n'"$_sd_content" == *$'\n'rate_7d=* ]]  && _sd_7d="${_sd_content#*rate_7d=}"     && _sd_7d="${_sd_7d%%$'\n'*}"
        [[ $'\n'"$_sd_content" == *$'\n'reset_5h=* ]] && _sd_reset="${_sd_content#*reset_5h=}" && _sd_reset="${_sd_reset%%$'\n'*}"
      fi

      _sd_age=$(( now - _sd_latest_mt ))
      _sd_active=$(( _sd_age < 300 ))

      # Check rate limit
      _sd_5h_int="${_sd_5h%.*}"
      _sd_rate_warn=0
      [[ -n "$_sd_5h_int" ]] && (( _sd_5h_int >= 80 )) && _sd_rate_warn=1

      if (( _sd_rate_warn )); then
        # Rate-limited: show warning
        _sd_reset_str=""
        if [[ -n "$_sd_reset" && "$_sd_reset" != "0" ]]; then
          _sd_remaining=$(( _sd_reset - now ))
          (( _sd_remaining > 0 )) && _sd_reset_str=" — reset in $(( _sd_remaining / 60 ))min"
        fi
        printf '  \033[0;33m⚠\033[0m \033[1m%s\033[0m 5h:%s%%%s\n' \
          "${_sd_model:-?}" "${_sd_5h_int}" "$_sd_reset_str"
      else
        # Active or stale session — show session line
        if (( _sd_active )); then
          _sd_icon="\033[0;32m●\033[0m"
        else
          _sd_icon="\033[0;90m○\033[0m"
        fi

        # Build context bar (10 blocks)
        _sd_bar=""
        if [[ -n "$_sd_ctx" && "$_sd_ctx" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
          _sd_filled=$(( ${_sd_ctx%.*} / 10 ))
          (( _sd_filled > 10 )) && _sd_filled=10
          _sd_empty=$(( 10 - _sd_filled ))
          for (( _i=0; _i<_sd_filled; _i++ )); do _sd_bar+="\033[0;32m█\033[0m"; done
          for (( _i=0; _i<_sd_empty; _i++ ));  do _sd_bar+="\033[38;5;240m░\033[0m"; done
        fi

        # Build line
        _sd_line="  ${_sd_icon} \033[1m${_sd_model:-?}\033[0m"
        [[ -n "$_sd_bar" ]] && _sd_line+=" ${_sd_bar} ${_sd_ctx%.*}%"
        if [[ -n "$_sd_cost" && "$_sd_cost" != "0" ]]; then
          _sd_line+=" \033[38;5;240m│\033[0m \033[0;36m\$$(printf '%.2f' "$_sd_cost")\033[0m"
        fi
        if [[ -n "$_sd_5h_int" ]]; then
          _sd_reset_str=""
          if [[ -n "$_sd_reset" && "$_sd_reset" != "0" ]]; then
            _sd_remaining=$(( _sd_reset - now ))
            (( _sd_remaining > 0 )) && _sd_reset_str=" reset $(( _sd_remaining / 60 ))min"
          fi
          _sd_line+=" \033[38;5;240m│\033[0m 5h:${_sd_5h_int}%${_sd_reset_str}"
        fi
        printf '%b\n' "${_sd_line}"
      fi

      # Rate limits summary (always if available)
      if [[ -n "$_sd_5h" ]]; then
        printf '\n'
        _sd_rl_str="  Rate limits: 5h:${_sd_5h%.*}%"
        [[ -n "$_sd_7d" ]] && _sd_rl_str+="  7d:${_sd_7d%.*}%"
        printf '%s\n' "$_sd_rl_str"
      fi

      # Session count + total cost for today
      _sd_today_count=0 _sd_today_cost=0
      _sd_cutoff=$(( now - 86400 ))
      for _sd_f in "${_sd_files[@]}"; do
        [[ -f "$_sd_f" ]] || continue
        if stat -f%m "$_sd_f" >/dev/null 2>&1; then
          _sd_mt=$(stat -f%m "$_sd_f")
        else
          _sd_mt=$(stat -c%Y "$_sd_f")
        fi
        if (( _sd_mt >= _sd_cutoff )); then
          _sd_today_count=$(( _sd_today_count + 1 ))
          _sd_fc=$(cat "$_sd_f" 2>/dev/null) || true
          _sd_fc_cost=""
          [[ $'\n'"$_sd_fc" == *$'\n'cost=* ]] && _sd_fc_cost="${_sd_fc#*cost=}" && _sd_fc_cost="${_sd_fc_cost%%$'\n'*}"
          if [[ -n "$_sd_fc_cost" && "$_sd_fc_cost" != "0" ]]; then
            _sd_today_cost=$(echo "$_sd_today_cost + $_sd_fc_cost" | bc 2>/dev/null || echo "$_sd_today_cost")
          fi
        fi
      done
      if (( _sd_today_count > 0 )); then
        printf '  %d session%s today, \033[0;36m$%s\033[0m total\n' \
          "$_sd_today_count" "$( (( _sd_today_count != 1 )) && printf 's' || true)" \
          "$(printf '%.2f' "$_sd_today_cost")"
      fi

      printf '\n'
      printf '  \033[38;5;240mclaudii help  for all commands\033[0m\n'
      printf '\n'
    fi
    ;;

  version)
    if [[ "$_FORMAT" == "json" ]]; then
      jq -n --arg v "$VERSION" '{"version": $v}'
    elif _plain; then
      echo "$VERSION"
    else
      echo "claudii v$VERSION"
    fi
    ;;

  about)
    printf '\n'
    printf '  \033[0;36mclaudii\033[0m \033[38;5;213mv%s\033[0m\n' "$VERSION"
    printf '  \033[38;5;213m──────────────────────────────────────\033[0m\n'
    printf '  Claude Interaction Intelligence\n'
    printf '\n'
    printf '  zsh plugin + CLI for Claude Code power users.\n'
    printf '\n'
    printf '  \033[0;32m◆\033[0m  ClaudeStatus — model health in RPROMPT\n'
    printf '  \033[0;32m◆\033[0m  SessionBar — session data above prompt\n'
    printf '  \033[0;32m◆\033[0m  Sessionline — info-dense line inside Claude Code\n'
    printf '  \033[0;32m◆\033[0m  Auto-fallback · debug logging · zsh autocomplete\n'
    printf '\n'
    printf '  \033[38;5;240mclaudii components  — component overview\033[0m\n'
    printf '  \033[38;5;213mhttps://github.com/bmmmm/claudii\033[0m\n'
    printf '\n'
    ;;

  components)
    local_cache="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    _cfg_init

    printf '\n'
    printf '  \033[0;36mclaudii components\033[0m\n'
    printf '  \033[38;5;213m──────────────────────────────────────────────────────────\033[0m\n'
    printf '\n'

    # ClaudeStatus
    cs_enabled=$(_cfgget statusline.enabled)
    cs_models=$(_cfgget statusline.models)
    cs_ttl=$(_cfgget status.cache_ttl)
    cs_cache="$local_cache/status-models"
    if [[ "$cs_enabled" == "true" ]]; then
      cs_state="\033[0;32mon\033[0m"
    else
      cs_state="\033[0;33moff\033[0m"
    fi
    printf '  \033[1;36mClaudeStatus\033[0m                              Shell RPROMPT\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Model health indicators from status.claude.com\n'
    printf '  Example:  [Opus \033[0;32m✓\033[0m Sonnet \033[0;32m✓\033[0m Haiku \033[0;32m✓\033[0m] 13m\n'
    printf '\n'
    printf '  Status:   %b\n' "$cs_state"
    printf '  Models:   %s\n' "$cs_models"
    printf '  TTL:      %ss\n' "$cs_ttl"
    if [[ -f "$cs_cache" ]]; then
      printf '  Cache:    %s\n' "$cs_cache"
    else
      printf '  Cache:    \033[38;5;240m(not yet created)\033[0m\n'
    fi
    printf '  Commands: claudii on/off · status · show model\n'
    printf '\n'

    # SessionBar
    sb_count=0
    for _sf in "$local_cache"/session-*; do
      [[ -f "$_sf" ]] && sb_count=$((sb_count + 1))
    done 2>/dev/null
    printf '  \033[1;36mSessionBar\033[0m                                Shell, above prompt\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Session data from cache (model, context, cost, rate limits)\n'
    printf '  Example:  \033[1mOpus\033[0m \033[0;32m████████\033[0m\033[38;5;240m░░\033[0m 76%% \033[38;5;240m│\033[0m \033[0;36m$0.07\033[0m \033[38;5;240m│\033[0m 5h:17%% reset 43min\n'
    printf '\n'
    printf '  Source:   Sessionline writes cache, SessionBar reads it\n'
    printf '  Sessions: %d cache file(s)\n' "$sb_count"
    printf '  Dedup:    only prints when data changes\n'
    printf '\n'

    # Sessionline
    settings_file="$HOME/.claude/settings.json"
    if [[ -f "$settings_file" ]] && command -v jq >/dev/null 2>&1; then
      sl_cmd=$(jq -r '.statusLine // empty' "$settings_file" 2>/dev/null)
      if [[ -n "$sl_cmd" && "$sl_cmd" == *claudii* ]]; then
        sl_state="\033[0;32maktiv\033[0m"
      else
        sl_state="\033[38;5;240mnicht konfiguriert\033[0m"
      fi
    else
      sl_state="\033[38;5;240m~/.claude/settings.json nicht gefunden\033[0m"
    fi
    printf '  \033[1;36mSessionline\033[0m                               Inside Claude Code\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Info-dense status line rendered inside Claude Code CLI\n'
    printf '  Shows model, context bar, cost, tokens, rate limits, lines, duration\n'
    printf '\n'
    printf '  Status:   %b\n' "$sl_state"
    printf '  API:      Claude Code statusLine (stdin JSON)\n'
    printf '  Handler:  bin/claudii-sessionline (bash+jq)\n'
    printf '  Commands: claudii sessionline on/off\n'
    printf '\n'

    # Data flow
    printf '  \033[1;36mData Flow\033[0m\n'
    printf '  \033[38;5;240m%.56s\033[0m\n' "────────────────────────────────────────────────────────"
    printf '  Claude Code \033[38;5;240m─JSON→\033[0m \033[1mSessionline\033[0m \033[38;5;240m─cache→\033[0m \033[1mSessionBar\033[0m\n'
    printf '  status.claude.com \033[38;5;240m─bg→\033[0m \033[1mClaudeStatus\033[0m (RPROMPT)\n'
    printf '\n'
    ;;

  42)
    printf '\n'
    printf '  \033[0;36m✦  The answer is 42.\033[0m\n'
    printf '\n'
    printf '  It was also the number of times Opus was down\n'
    printf '  while this tool was being built.\n'
    printf '\n'
    printf '  \033[38;5;213m(We monitor all three now. You'\''re welcome.)\033[0m\n'
    printf '\n'
    ;;

  sessions)
    _cfg_init
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    now=$(date +%s)
    active=0 stale=0 total_cost=0
    latest_5h="" latest_7d="" latest_reset=""

    # Collect all session data into parallel arrays
    declare -a _sf_model _sf_ctx _sf_cost _sf_5h _sf_7d _sf_reset _sf_sid _sf_age _sf_active _sf_worktree _sf_agent
    _sf_count=0

    for sf in "$cache_dir"/session-*; do
      [[ -f "$sf" ]] || continue
      mt=$(stat -f%m "$sf" 2>/dev/null || stat -c%Y "$sf" 2>/dev/null || echo 0)
      age=$(( now - mt ))

      content=$(cat "$sf" 2>/dev/null) || continue
      s_model="" s_ctx="" s_cost="" s_5h="" s_7d="" s_reset="" s_sid="" s_worktree="" s_agent=""
      [[ $'\n'"$content" == *$'\n'model=* ]] && s_model="${content#*model=}" && s_model="${s_model%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'ctx_pct=* ]] && s_ctx="${content#*ctx_pct=}" && s_ctx="${s_ctx%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'cost=* ]] && s_cost="${content#*cost=}" && s_cost="${s_cost%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'rate_5h=* ]] && s_5h="${content#*rate_5h=}" && s_5h="${s_5h%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'rate_7d=* ]] && s_7d="${content#*rate_7d=}" && s_7d="${s_7d%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'reset_5h=* ]] && s_reset="${content#*reset_5h=}" && s_reset="${s_reset%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'session_id=* ]] && s_sid="${content#*session_id=}" && s_sid="${s_sid%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'worktree=* ]] && s_worktree="${content#*worktree=}" && s_worktree="${s_worktree%%$'\n'*}"
      [[ $'\n'"$content" == *$'\n'agent=* ]] && s_agent="${content#*agent=}" && s_agent="${s_agent%%$'\n'*}"

      # Accumulate cost
      if [[ -n "$s_cost" && "$s_cost" != "0" ]]; then
        total_cost=$(echo "$total_cost + $s_cost" | bc 2>/dev/null || echo "$total_cost")
      fi

      # Track freshest rate limits
      if [[ -n "$s_5h" ]] && (( age < 300 )); then
        latest_5h="$s_5h"; latest_7d="$s_7d"; latest_reset="$s_reset"
      fi

      _sf_model[$_sf_count]="$s_model"
      _sf_ctx[$_sf_count]="$s_ctx"
      _sf_cost[$_sf_count]="$s_cost"
      _sf_5h[$_sf_count]="$s_5h"
      _sf_7d[$_sf_count]="$s_7d"
      _sf_reset[$_sf_count]="$s_reset"
      _sf_sid[$_sf_count]="$s_sid"
      _sf_worktree[$_sf_count]="$s_worktree"
      _sf_agent[$_sf_count]="$s_agent"
      _sf_age[$_sf_count]="$age"
      if (( age < 300 )); then
        _sf_active[$_sf_count]="active"
        (( active++ ))
      else
        _sf_active[$_sf_count]="stale"
        (( stale++ ))
      fi
      (( _sf_count++ ))
    done

    if [[ "$_FORMAT" == "json" ]]; then
      # Build JSON array from collected data
      _json_arr="["
      _first=1
      for (( i=0; i<_sf_count; i++ )); do
        [[ "$_first" -eq 0 ]] && _json_arr+=","
        _json_arr+=$(jq -n \
          --arg model "${_sf_model[$i]}" \
          --arg ctx_pct "${_sf_ctx[$i]}" \
          --arg cost "${_sf_cost[$i]:-0}" \
          --arg rate_5h "${_sf_5h[$i]}" \
          --arg rate_7d "${_sf_7d[$i]}" \
          --arg reset_5h "${_sf_reset[$i]}" \
          --arg session_id "${_sf_sid[$i]}" \
          --arg worktree "${_sf_worktree[$i]}" \
          --arg agent "${_sf_agent[$i]}" \
          --arg age "${_sf_age[$i]}" \
          --arg status "${_sf_active[$i]}" \
          '{model:$model, ctx_pct:($ctx_pct|if .=="" then null else tonumber? end),
            cost:($cost|tonumber? // 0), rate_5h:($rate_5h|if .=="" then null else tonumber? end),
            rate_7d:($rate_7d|if .=="" then null else tonumber? end),
            reset_5h:($reset_5h|if .=="" then null else tonumber? end),
            session_id:$session_id, worktree:$worktree, agent:$agent,
            age_seconds:($age|tonumber), status:$status}')
        _first=0
      done
      _json_arr+="]"
      echo "$_json_arr" | jq .
      exit 0
    elif [[ "$_FORMAT" == "tsv" ]]; then
      printf "model\tctx_pct\tcost\trate_5h\trate_7d\treset_5h\tsession_id\tworktree\tagent\tage_seconds\tstatus\n"
      for (( i=0; i<_sf_count; i++ )); do
        printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
          "${_sf_model[$i]}" "${_sf_ctx[$i]}" "${_sf_cost[$i]:-0}" \
          "${_sf_5h[$i]}" "${_sf_7d[$i]}" "${_sf_reset[$i]}" \
          "${_sf_sid[$i]}" "${_sf_worktree[$i]}" "${_sf_agent[$i]}" \
          "${_sf_age[$i]}" "${_sf_active[$i]}"
      done
      exit 0
    fi

    # Pretty output
    printf '\n'
    for (( i=0; i<_sf_count; i++ )); do
      local status_icon age_str
      age="${_sf_age[$i]}"
      if [[ "${_sf_active[$i]}" == "active" ]]; then
        status_icon="\033[0;32m●\033[0m"
      else
        status_icon="\033[0;90m○\033[0m"
      fi
      if (( age < 60 )); then age_str="${age}s"
      elif (( age < 3600 )); then age_str="$(( age / 60 ))m"
      elif (( age < 86400 )); then age_str="$(( age / 3600 ))h"
      else age_str="$(( age / 86400 ))d"; fi

      line="  ${status_icon} \033[1m${_sf_model[$i]:-?}\033[0m"
      [[ -n "${_sf_worktree[$i]}" ]] && line+=" \033[2m[wt:${_sf_worktree[$i]}]\033[0m"
      [[ -n "${_sf_agent[$i]}" ]] && line+=" \033[2m[agent:${_sf_agent[$i]}]\033[0m"
      [[ -n "${_sf_ctx[$i]}" ]] && line+="  ${_sf_ctx[$i]}%"
      [[ -n "${_sf_cost[$i]}" && "${_sf_cost[$i]}" != "0" ]] && line+="  \033[36m\$$(printf '%.2f' "${_sf_cost[$i]}")\033[0m"
      [[ -n "${_sf_5h[$i]}" ]] && line+="  5h:${_sf_5h[$i]%.*}%"
      line+="  \033[2m${age_str} ago\033[0m"
      [[ -n "${_sf_sid[$i]}" ]] && line+="  \033[2m${_sf_sid[$i]:0:8}\033[0m"
      printf "${line}\n"
    done

    # Summary
    printf '\n'
    total_fmt=$(printf '$%.2f' "$total_cost")
    printf "  \033[38;5;213m%d aktiv, %d beendet, %s total\033[0m" "$active" "$stale" "$total_fmt"
    if [[ -n "$latest_5h" ]]; then
      reset_str=""
      if [[ -n "$latest_reset" && "$latest_reset" != "0" ]]; then
        remaining=$(( latest_reset - now ))
        (( remaining > 0 )) && reset_str=" (Reset in $(( remaining / 60 ))min)"
      fi
      printf "  \033[2m5h:%s%% 7d:%s%%%s\033[0m" "${latest_5h%.*}" "${latest_7d%.*}" "$reset_str"
    fi
    printf '\n\n'
    ;;

  update)
    if ! git -C "$CLAUDII_HOME" rev-parse --git-dir >/dev/null 2>&1; then
      printf 'claudii: not a git repo — install via:\n'
      printf '  git clone https://github.com/bmmmm/claudii\n'; exit 1
    fi
    git -C "$CLAUDII_HOME" pull --ff-only
    printf '\033[0;32m✓ Updated. Run: claudii restart\033[0m\n'
    ;;

  watch)
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    pid_file="$cache_dir/watch.pid"

    _watch_notify() {
      local title="claudii watch" msg="$1"
      if command -v terminal-notifier >/dev/null 2>&1; then
        terminal-notifier -title "$title" -message "$msg" >/dev/null 2>&1
      else
        osascript -e "display notification \"$msg\" with title \"$title\"" >/dev/null 2>&1
      fi
    }

    _watch_loop() {
      local cache_dir="$1" pid_file="$2"
      local last_notified=0

      while true; do
        sleep 60
        local now
        now=$(date +%s)

        for sf in "$cache_dir"/session-*; do
          [[ -f "$sf" ]] || continue
          local reset_ts=""
          while IFS='=' read -r key val; do
            [[ "$key" == "reset_5h" ]] && reset_ts="$val"
          done < "$sf"

          [[ -z "$reset_ts" || "$reset_ts" == "0" ]] && continue
          # Rate limit has reset and we haven't notified for this timestamp yet
          if (( now >= reset_ts && reset_ts != last_notified )); then
            _watch_notify "Rate limit reset — Claude is ready"
            last_notified="$reset_ts"
            break
          fi
        done
      done
    }

    case "${2:-start}" in
      start)
        [[ -d "$cache_dir" ]] || mkdir -p "$cache_dir"
        # Check if already running
        if [[ -f "$pid_file" ]]; then
          existing_pid=$(<"$pid_file")
          if kill -0 "$existing_pid" 2>/dev/null; then
            echo "claudii watch already running (PID $existing_pid)"
            exit 0
          fi
        fi
        # Export functions needed in subshell
        export -f _watch_notify _watch_loop 2>/dev/null || true
        ( _watch_loop "$cache_dir" "$pid_file" &>/dev/null & echo $! > "$pid_file" ) &>/dev/null
        disown %% 2>/dev/null || true
        sleep 0.2
        if [[ -f "$pid_file" ]]; then
          watcher_pid=$(<"$pid_file")
          echo "claudii watch started (PID $watcher_pid)"
        else
          echo "claudii watch started"
        fi
        ;;
      stop)
        if [[ -f "$pid_file" ]]; then
          watcher_pid=$(<"$pid_file")
          if kill -0 "$watcher_pid" 2>/dev/null; then
            kill "$watcher_pid" 2>/dev/null
            rm -f "$pid_file"
            echo "claudii watch stopped (PID $watcher_pid)"
          else
            rm -f "$pid_file"
            echo "claudii watch was not running (stale PID file removed)"
          fi
        else
          echo "claudii watch is not running"
        fi
        ;;
      status)
        if [[ -f "$pid_file" ]]; then
          watcher_pid=$(<"$pid_file")
          if kill -0 "$watcher_pid" 2>/dev/null; then
            echo -e "claudii watch: \033[0;32mrunning\033[0m (PID $watcher_pid)"
          else
            rm -f "$pid_file"
            echo "claudii watch: not running (stale PID file removed)"
          fi
        else
          echo "claudii watch: not running"
        fi
        ;;
      *)
        echo "Usage: claudii watch [start|stop|status]"; exit 1
        ;;
    esac
    ;;

  doctor)
    _cfg_init

    # Collect check results into parallel arrays: name, status (ok/warn/fail), detail
    declare -a _dc_name _dc_status _dc_detail
    _dc_count=0

    _dc_add() { _dc_name[$_dc_count]="$1"; _dc_status[$_dc_count]="$2"; _dc_detail[$_dc_count]="$3"; (( _dc_count++ )); }

    # 1. Claude Code
    if command -v claude >/dev/null 2>&1; then
      claude_ver=$(claude --version 2>/dev/null | head -1 || echo "unknown")
      _dc_add "claude_code" "ok" "Claude Code $claude_ver"
    else
      _dc_add "claude_code" "fail" "Claude Code not found — install from https://claude.ai/download"
    fi

    # 2. jq
    if command -v jq >/dev/null 2>&1; then
      jq_ver=$(jq --version 2>/dev/null || echo "unknown")
      _dc_add "jq" "ok" "jq $jq_ver"
    else
      _dc_add "jq" "fail" "jq not installed — brew install jq"
    fi

    # 3. Sessionline config
    settings="${HOME}/.claude/settings.json"
    if [[ ! -f "$settings" ]]; then
      _dc_add "sessionline" "warn" "Sessionline not configured — claudii sessionline on"
    elif jq -e '.statusLine.command == "claudii-sessionline"' "$settings" >/dev/null 2>&1; then
      _dc_add "sessionline" "ok" "Sessionline configured"
    elif jq -e '.statusLine' "$settings" >/dev/null 2>&1; then
      other=$(jq -r '.statusLine.command // "unknown"' "$settings")
      _dc_add "sessionline" "warn" "Sessionline: other command ($other) — claudii sessionline on"
    else
      _dc_add "sessionline" "warn" "Sessionline not configured — claudii sessionline on"
    fi

    # 4. Cache directory
    cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
    if [[ -d "$cache_dir" ]]; then
      cache_count=$(ls -1 "$cache_dir" 2>/dev/null | wc -l | tr -d ' ')
      _dc_add "cache" "ok" "Cache directory exists ($cache_count files)"
    else
      _dc_add "cache" "warn" "Cache directory missing — will be created on first status check"
    fi

    # 5. Completions
    comp_dir="$CLAUDII_HOME/completions"
    if [[ -f "$comp_dir/_claudii" ]]; then
      _dc_add "completions" "ok" "Completions file present ($comp_dir)"
    else
      _dc_add "completions" "fail" "Completions not found — add to .zshrc: fpath+=($comp_dir)"
    fi

    # 6. Plugin loaded
    if [[ -n "${CLAUDII_HOME:-}" ]]; then
      _dc_add "plugin" "ok" "Plugin loaded (CLAUDII_HOME=$CLAUDII_HOME)"
    else
      _dc_add "plugin" "warn" "CLAUDII_HOME not set — source claudii.plugin.zsh in .zshrc"
    fi

    # 7. Version
    _dc_add "version" "ok" "claudii v$VERSION"

    # 8. Updates (git only, non-fatal)
    if git -C "$CLAUDII_HOME" rev-parse --git-dir >/dev/null 2>&1; then
      git -C "$CLAUDII_HOME" fetch --quiet origin main 2>/dev/null || true
      local_ref=$(git -C "$CLAUDII_HOME" rev-parse HEAD 2>/dev/null)
      remote_ref=$(git -C "$CLAUDII_HOME" rev-parse origin/main 2>/dev/null || echo "")
      if [[ -z "$remote_ref" ]]; then
        _dc_add "updates" "warn" "Update check failed (no remote/network)"
      elif [[ "$local_ref" == "$remote_ref" ]]; then
        _dc_add "updates" "ok" "Up to date"
      else
        behind=$(git -C "$CLAUDII_HOME" rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
        _dc_add "updates" "warn" "$behind commit(s) behind origin/main — claudii update"
      fi
    else
      _dc_add "updates" "warn" "Not a git repo — skipping update check"
    fi

    if [[ "$_FORMAT" == "json" ]]; then
      _json_arr="["
      _first=1
      for (( i=0; i<_dc_count; i++ )); do
        [[ "$_first" -eq 0 ]] && _json_arr+=","
        _json_arr+=$(jq -n --arg name "${_dc_name[$i]}" --arg status "${_dc_status[$i]}" --arg detail "${_dc_detail[$i]}" \
          '{"check": $name, "status": $status, "detail": $detail}')
        _first=0
      done
      _json_arr+="]"
      echo "$_json_arr" | jq .
      exit 0
    fi

    local ok="\033[0;32m✓\033[0m"
    local warn="\033[0;33m⚠\033[0m"
    local fail="\033[0;31m✗\033[0m"
    printf '\n'
    printf '  \033[0;36mclaudii doctor\033[0m\n\n'
    for (( i=0; i<_dc_count; i++ )); do
      case "${_dc_status[$i]}" in
        ok)   icon="$ok"   ;;
        warn) icon="$warn" ;;
        *)    icon="$fail" ;;
      esac
      printf "  %b %s\n" "$icon" "${_dc_detail[$i]}"
    done
    printf '\n'
    ;;

  agents)
    agents_dir="${HOME}/.claude/agents"
    shopt -s nullglob
    agent_files=("$agents_dir"/*.md)
    shopt -u nullglob

    if [[ ${#agent_files[@]} -eq 0 ]]; then
      if [[ "$_FORMAT" == "json" ]]; then
        echo "[]"
      else
        echo "No agents found in $agents_dir"
        echo ""
        echo "Create agent files as ~/.claude/agents/<name>.md"
        echo "The first line of each file is used as the description."
        echo ""
        echo "Example:"
        echo "  ~/.claude/agents/orchestrator.md"
        echo "  ~/.claude/agents/explorer.md"
        echo ""
        echo "Then launch with: clorch  or  cle"
      fi
      exit 0
    fi

    if [[ "$_FORMAT" == "json" ]]; then
      first=1
      printf '['
      for f in "${agent_files[@]}"; do
        name=$(basename "$f" .md)
        desc=$(head -1 "$f" 2>/dev/null | sed 's/^#* *//')
        [[ "$first" -eq 0 ]] && printf ','
        printf '%s' "$(jq -n --arg name "$name" --arg path "$f" --arg desc "$desc" \
          '{"name":$name,"path":$path,"description":$desc}')"
        first=0
      done
      printf ']\n'
    else
      if _plain; then
        for f in "${agent_files[@]}"; do
          name=$(basename "$f" .md)
          desc=$(head -1 "$f" 2>/dev/null | sed 's/^#* *//')
          printf "%s\t%s\n" "$name" "$desc"
        done
      else
        printf '\n'
        printf '  \033[38;5;213mAgents\033[0m  (~/.claude/agents/)\n'
        for f in "${agent_files[@]}"; do
          name=$(basename "$f" .md)
          desc=$(head -1 "$f" 2>/dev/null | sed 's/^#* *//')
          printf "    %-20s  \033[38;5;240m%s\033[0m\n" "$name" "$desc"
        done
        printf '\n'
      fi
    fi
    ;;

  explore)
    # Internal dev tool — not shipped, not documented
    [[ -x "$CLAUDII_HOME/bin/claudii-explore" ]] || { echo "claudii-explore not found (internal tool)"; exit 1; }
    exec "$CLAUDII_HOME/bin/claudii-explore" "${@:2}"
    ;;

  metrics)
    echo "claudii metrics ist eine zsh-Shell-Funktion."
    echo "Führe sie direkt im Terminal aus (nicht als Subprozess)."
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    echo "Unknown command: $1"
    usage; exit 1
    ;;
esac
