#!/bin/bash
# claudii — Claude Interaction Intelligence CLI
# Usage: claudii <command> [args]
#
# Thin dispatcher — command logic lives in lib/cmd/*.sh

set -euo pipefail

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
source "$CLAUDII_HOME/lib/visual.sh"
source "$CLAUDII_HOME/lib/spinner.sh"
VERSION="0.15.0"

# TTY detection — 1 if stdout is a terminal, 0 if piped
_TTY=0
[ -t 1 ] && _TTY=1

# Explicit output format flag (--json / --tsv), parsed before alias expansion
_FORMAT=""
_args_filtered=()
for _arg in "$@"; do
  case "$_arg" in
    --json) _FORMAT="json" ;;
    --tsv)  _FORMAT="tsv"  ;;
    *)      _args_filtered+=("$_arg") ;;
  esac
done
set -- "${_args_filtered[@]+"${_args_filtered[@]}"}"
unset _args_filtered _arg

# Returns 0 (true) when output should be plain (no ANSI colors):
# either piped without an explicit format flag, or an explicit --json/--tsv flag is set.
_plain() { [[ "$_TTY" -eq 0 ]] || [[ -n "$_FORMAT" ]]; }

command -v jq >/dev/null 2>&1 || {
  echo "claudii: jq not found. Install: brew install jq" >&2; exit 1
}

# ── Shared helpers (used by lib/cmd/*.sh) ──────────────────────────────────

# Collect history TSV files from a cache directory into global array _HIST_FILES.
# Usage: _collect_history_files <dir>
# Populates _HIST_FILES with non-empty history.tsv and history-*.tsv files found.
_HIST_FILES=()
_collect_history_files() {
  local _dir="$1"
  _HIST_FILES=()
  [[ -f "$_dir/history.tsv" && -s "$_dir/history.tsv" ]] && _HIST_FILES+=("$_dir/history.tsv")
  local _f
  for _f in "$_dir"/history-*.tsv; do
    [[ -f "$_f" && -s "$_f" ]] && _HIST_FILES+=("$_f")
  done
  return 0
}

# Date/timezone initialization — sets shared variables used by cost and trends commands.
# Sets: _DATE_CMD ("macos" or "gnu"), _TZ_OFFSET (seconds), _WS_DOW (1=Mon..7=Sun)
_DATE_CMD="" _TZ_OFFSET="" _WS_DOW=""
_date_init() {
  # Detect macOS vs GNU date
  if date -j -f '%s' "$(date +%s)" '+%Y-%m-%d' >/dev/null 2>&1; then
    _DATE_CMD="macos"
  else
    _DATE_CMD="gnu"
  fi

  # Timezone offset in seconds (maps UTC epoch → local day in epoch_to_date)
  _TZ_OFFSET=$(date +%z | awk '{
    s = (substr($0,1,1) == "-") ? -1 : 1
    print s * (substr($0,2,2)*3600 + substr($0,4,2)*60)
  }')

  # Read configurable week_start (default: monday)
  local _ws_name
  _ws_name=$(_cfgget cost.week_start)
  _ws_name="${_ws_name:-monday}"
  case "$_ws_name" in
    monday)    _WS_DOW=1 ;;
    tuesday)   _WS_DOW=2 ;;
    wednesday) _WS_DOW=3 ;;
    thursday)  _WS_DOW=4 ;;
    friday)    _WS_DOW=5 ;;
    saturday)  _WS_DOW=6 ;;
    sunday)    _WS_DOW=7 ;;
    *)         _WS_DOW=1 ;;
  esac
}

# Spinner start/stop — wraps the _claudii_spinner background job with label file management.
# _spinner_start [label]  — starts spinner, writes optional initial label, sets _SPINNER_PID
# _spinner_stop           — kills spinner, clears line, removes label file
# Callers can update the displayed label at any time by writing to $CLAUDII_SPINNER_LABEL_FILE.
_SPINNER_PID=""
_spinner_start() {
  local _label="${1:-}"
  _SPINNER_PID=""
  _plain && return
  local _lf
  _lf=$(mktemp "${TMPDIR:-/tmp}/claudii-spinner.XXXXXX") || return
  chmod 0600 "$_lf"
  export CLAUDII_SPINNER_LABEL_FILE="$_lf"
  [[ -n "$_label" ]] && printf '%s' "$_label" > "$_lf"
  _claudii_spinner &
  _SPINNER_PID=$!
}

_spinner_stop() {
  if [[ -n "${_SPINNER_PID:-}" ]]; then
    kill "$_SPINNER_PID" 2>/dev/null
    wait "$_SPINNER_PID" 2>/dev/null || true
    printf '\r\033[K' >&2
    _SPINNER_PID=""
  fi
  if [[ -n "${CLAUDII_SPINNER_LABEL_FILE:-}" ]]; then
    rm -f "$CLAUDII_SPINNER_LABEL_FILE"
    unset CLAUDII_SPINNER_LABEL_FILE
  fi
}

# Session JSONL map — build once, O(1) lookup per session.
# Uses parallel arrays (bash 3.2 compatible — no declare -A).
_SID_MAP_KEYS=()
_SID_MAP_VALS=()
_session_build_map() {
  _SID_MAP_KEYS=()
  _SID_MAP_VALS=()
  local _jsonl _sid _i=0
  for _jsonl in "$HOME/.claude/projects"/*/*.jsonl; do
    [[ -f "$_jsonl" ]] || continue
    _sid="${_jsonl##*/}"
    _sid="${_sid%.jsonl}"
    _SID_MAP_KEYS[$_i]="$_sid"
    _SID_MAP_VALS[$_i]="$_jsonl"
    (( ++_i ))
  done
}

# Resolve JSONL path for a session_id (uses map if built, falls back to scan).
_session_jsonl() {
  local sid="$1" _j
  [[ -z "$sid" ]] && return
  # Map lookup
  for (( _j=0; _j<${#_SID_MAP_KEYS[@]}; _j++ )); do
    if [[ "${_SID_MAP_KEYS[$_j]}" == "$sid" ]]; then
      echo "${_SID_MAP_VALS[$_j]}"
      return
    fi
  done
  # Fallback: direct scan
  for _d in "$HOME/.claude/projects"/*/; do
    [[ -f "${_d}${sid}.jsonl" ]] && echo "${_d}${sid}.jsonl" && return
  done
}

# Resolve project path (cwd) for a given session_id from JSONL transcript.
_session_project_path() {
  local sid="$1" jsonl
  jsonl=$(_session_jsonl "$sid")
  [[ -z "$jsonl" ]] && return
  local cwd
  cwd=$(grep -m5 '"cwd"' "$jsonl" 2>/dev/null | head -1 | grep -o '"cwd":"[^"]*"' | sed 's/"cwd":"//; s/"$//' || true)
  [[ -z "$cwd" ]] && return
  local short="${cwd/#$HOME/\~}"
  if (( ${#short} > 40 )); then
    short="...${short: -37}"
  fi
  echo "$short"
}

# Single-pass JSONL resolver: extracts name, fingerprint, last_message in one awk.
# Output: 3 lines (name\nfingerprint\nlast_message), any may be empty.
_session_resolve() {
  local sid="$1" jsonl
  jsonl=$(_session_jsonl "$sid")
  [[ -z "$jsonl" ]] && { printf '\n\n\n'; return; }
  awk '
    # Session name: last "Session renamed to:" match
    match($0, /"Session renamed to: [^"\\]*"/) {
      name = substr($0, RSTART+21, RLENGTH-22)
      # Strip ANSI escapes
      gsub(/\033\[[0-9;]*m/, "", name)
      gsub(/\\033\[[0-9;]*m/, "", name)
      gsub(/\\e\[[0-9;]*m/, "", name)
    }
    # Fingerprint: collect file_path occurrences
    {
      pos = 0
      s = $0
      while (match(s, /"file_path":"[^"]*"/)) {
        fp = substr(s, RSTART+13, RLENGTH-14)
        # basename
        n = split(fp, parts, "/")
        bn = parts[n]
        files[bn]++
        s = substr(s, RSTART + RLENGTH)
      }
    }
    # Last user message
    /"role":"user"/ { last_user = $0 }
    END {
      # Name (max 60 chars)
      if (length(name) > 60) name = substr(name, 1, 60)
      print name

      # Fingerprint: top-5 by count
      n = 0
      for (f in files) { n++; fnames[n] = f; fcounts[n] = files[f] }
      # Simple selection sort (max 5 from n)
      fp_out = ""
      for (i = 1; i <= 5 && i <= n; i++) {
        max_idx = i
        for (j = i+1; j <= n; j++) {
          if (fcounts[j] > fcounts[max_idx]) max_idx = j
        }
        if (max_idx != i) {
          tmp = fnames[i]; fnames[i] = fnames[max_idx]; fnames[max_idx] = tmp
          tmp = fcounts[i]; fcounts[i] = fcounts[max_idx]; fcounts[max_idx] = tmp
        }
        fp_out = fp_out (fp_out == "" ? "" : " ") fnames[i] "(" fcounts[i] ")"
      }
      print fp_out

      # Last user message (max 80 chars)
      msg = ""
      if (last_user != "") {
        if (match(last_user, /"text":"[^"]*"/)) {
          msg = substr(last_user, RSTART+7, RLENGTH-8)
        }
        if (length(msg) > 80) msg = substr(msg, 1, 80)
      }
      print msg
    }
  ' "$jsonl" 2>/dev/null || printf '\n\n\n'
}

# Legacy wrappers (used individually in some code paths)
_session_name() {
  local sid="$1" result
  result=$(_session_resolve "$sid")
  echo "$result" | head -1
}

_session_fingerprint() {
  local sid="$1" result
  result=$(_session_resolve "$sid")
  echo "$result" | sed -n '2p'
}

# Atomic jq update — writes to tmp then renames (prevents partial reads on jq error).
# Usage: _jq_update <file> <jq-filter> [jq-args...]
# Example: _jq_update "$CONFIG" '.debug.level = "info"'
# Example: _jq_update "$CONFIG" --argjson v 900 '.status.cache_ttl = $v'
_jq_update() {
  local _file="$1"; shift
  local _tmp; _tmp=$(mktemp) || return 1
  if jq "$@" "$_file" > "$_tmp"; then
    mv -f "$_tmp" "$_file"
  else
    rm -f "$_tmp"
    return 1
  fi
}

# Config helper — sets CONFIG, CONFIG_DIR, DEFAULTS in calling scope
_cfg_init() {
  CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudii"
  CONFIG="$CONFIG_DIR/config.json"
  DEFAULTS="$CLAUDII_HOME/config/defaults.json"
  [[ -d "$CONFIG_DIR" ]] || mkdir -p "$CONFIG_DIR"
  [[ -f "$CONFIG" ]] || cp "$DEFAULTS" "$CONFIG"
  _claudii_theme_load
}

# Validate config key — alphanumeric, dots, hyphens, underscores only (prevents jq injection)
_validate_key() { [[ "$1" =~ ^[a-zA-Z0-9._-]+$ ]] || { echo "Invalid key: $1 (allowed: alphanumeric, dots, hyphens, underscores)" >&2; return 1; }; }

# Config value lookup — user config first, falls back to defaults.json
# Builds a properly quoted jq path so hyphenated keys (e.g. session-dashboard.enabled)
# are accessed as ."session-dashboard"."enabled" rather than the invalid .session-dashboard.enabled
_cfgget() {
  local key="$1" val _jp="" _seg
  _validate_key "$key" || return 1
  # Split on '.' and quote each segment: "a.b-c.d" → ."a"."b-c"."d"
  local _IFS_OLD="$IFS"
  IFS='.' read -ra _cfgget_segs <<< "$key"
  IFS="$_IFS_OLD"
  for _seg in "${_cfgget_segs[@]}"; do
    _jp+='."'"$_seg"'"'
  done
  val=$(jq -r "${_jp} // empty" "$CONFIG" 2>/dev/null)
  [[ -z "$val" ]] && val=$(jq -r "${_jp} // empty" "$DEFAULTS" 2>/dev/null)
  echo "$val"
}

usage() {
  local d="${CLAUDII_CLR_DIM}›${CLAUDII_CLR_RESET}"  # dim separator
  printf '\n'
  printf "  ${CLAUDII_CLR_CYAN}claudii${CLAUDII_CLR_RESET} ${CLAUDII_CLR_ACCENT}v%s${CLAUDII_CLR_RESET} — Claude Interaction Intelligence\n" "$VERSION"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}aliases${CLAUDII_CLR_RESET}\n"
  local _def="${CLAUDII_HOME}/config/defaults.json"
  while IFS=$'\t' read -r _a _m _e _desc; do
    [[ -z "$_a" ]] && continue
    printf "    %-5s  %-7s  %-6s  $d %s\n" "$_a" "$_m" "$_e" "$_desc"
  done < <(jq -r '.aliases // {} | to_entries[] | [.key, .value.model, .value.effort, .value.description] | @tsv' "$_def" 2>/dev/null)
  printf "    %-5s  %-21s  $d %s\n"      "clh" ""                 "alias table + model status"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}Display Layers${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "on | off"                        "enable/disable all layers"
  printf "    %-33s $d %s\n" "claudestatus [on|off]"           "ClaudeStatus RPROMPT toggle"
  printf "    %-33s $d %s\n" "session-dashboard [on|off]"      "Session Dashboard above-prompt toggle"
  printf "    %-33s $d %s\n" "cc-statusline [on|off]"          "CC-Statusline inside Claude toggle"
  printf "    %-33s $d %s\n" "explain"                         "components, symbols & data flow"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}Sessions & Cost${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "sessions (se)"                   "list all active sessions"
  printf "    %-33s $d %s\n" "sessions-inactive (si)"          "list all inactive sessions"
  printf "    %-33s $d %s\n" "pin / unpin <session-id>"        "protect session from GC"
  printf "    %-33s $d %s\n" "cost (c)"                        "aggregate session costs"
  printf "    %-33s $d %s\n" "trends (t)"                      "weekly/daily cost history"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}Config${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "config [get|set|reset|export|import]" "manage configuration"
  printf "    %-33s $d %s\n" "agents"                          "configured agents (alias→skill)"
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}System${CLAUDII_CLR_RESET}\n"
  printf "    %-33s $d %s\n" "status (s) [5m|15m|30m]"        "live model check · refresh interval"
  printf "    %-33s $d %s\n" "doctor (d)"                      "installation health check"
  printf "    %-33s $d %s\n" "update"                          "update to latest version"
  printf "    %-33s $d %s\n" "version"                         "show version number"
  printf "    %-33s $d %s\n" "changelog"                       "release notes for current version"
  printf "    %-33s $d %s\n" "restart"                         "reload plugin"
  printf "    %-33s $d %s\n" "search ['query']"                "launch Claude in search mode"
  printf '\n'
  printf '\n'
  printf "  ${CLAUDII_CLR_ACCENT}man claudii${CLAUDII_CLR_RESET}  full reference\n"
  printf '\n'
}

# ── Parse session cache file into _PSC_* variables ──────────────────────────
_parse_session_cache() {
  _PSC_model= _PSC_ctx_pct= _PSC_cost= _PSC_rate_5h= _PSC_rate_7d=
  _PSC_reset_5h= _PSC_reset_7d= _PSC_session_id= _PSC_ppid=
  _PSC_worktree= _PSC_agent= _PSC_cache_pct= _PSC_rate_7d_start=
  _PSC_rate_5h_start= _PSC_project_path=
  _PSC_pinned=
  while IFS='=' read -r _k _v; do
    case "$_k" in
      model)          _PSC_model="$_v" ;;
      ctx_pct)        _PSC_ctx_pct="$_v" ;;
      cost)           _PSC_cost="$_v" ;;
      rate_5h)        _PSC_rate_5h="$_v" ;;
      rate_7d)        _PSC_rate_7d="$_v" ;;
      reset_5h)       _PSC_reset_5h="$_v" ;;
      reset_7d)       _PSC_reset_7d="$_v" ;;
      session_id)     _PSC_session_id="$_v" ;;
      ppid)           _PSC_ppid="$_v" ;;
      worktree)       _PSC_worktree="$_v" ;;
      agent)          _PSC_agent="$_v" ;;
      cache_pct)      _PSC_cache_pct="$_v" ;;
      rate_7d_start)  _PSC_rate_7d_start="$_v" ;;
      rate_5h_start)  _PSC_rate_5h_start="$_v" ;;
      project_path)   _PSC_project_path="$_v" ;;
      pinned)         _PSC_pinned="$_v" ;;
    esac
  done < "$1"
  if stat -f %m "$1" >/dev/null 2>&1; then
    _PSC_mtime=$(stat -f %m "$1")
  else
    _PSC_mtime=$(stat -c %Y "$1")
  fi
  _PSC_age=$(( $(date +%s) - _PSC_mtime ))
  # Active = Claude Code process (ppid) is still running AND file is < 24h old.
  # The 24h cap guards against PID recycling (OS reuses PIDs of long-dead processes).
  _PSC_is_active=0
  if [[ "$_PSC_ppid" =~ ^[0-9]+$ ]] && [[ "$_PSC_ppid" != "0" ]] \
      && (( _PSC_age < 86400 )) && kill -0 "$_PSC_ppid" 2>/dev/null; then
    _PSC_is_active=1
  fi
}

# ── Render context bar (8 blocks) into _CTX_BAR ─────────────────────────────
_render_ctx_bar() {
  local _pct=${1:-0}
  local _filled=$(( _pct * 8 / 100 ))
  [[ $_filled -gt 8 ]] && _filled=8
  local _empty=$(( 8 - _filled ))
  local _clr
  if   [[ $_pct -ge 90 ]]; then _clr=$CLAUDII_CLR_RED
  elif [[ $_pct -ge 70 ]]; then _clr=$CLAUDII_CLR_YELLOW
  else                          _clr=$CLAUDII_CLR_GREEN
  fi
  local _bar="" i
  for ((i=0; i<_filled; i++)); do _bar+="$CLAUDII_SYM_BAR_FULL"; done
  for ((i=0; i<_empty;  i++)); do _bar+="$CLAUDII_SYM_BAR_EMPTY"; done
  _CTX_BAR="${_clr}${_bar}${CLAUDII_CLR_RESET}"
}

# ── Render age into _AGE_STR ─────────────────────────────────────────────────
_render_age() {
  local _s=${1:-0}
  (( _s < 0 )) && _s=0
  if   [[ $_s -lt 60    ]]; then _AGE_STR="${_s}s ago"
  elif [[ $_s -lt 3600  ]]; then _AGE_STR="$(( _s / 60 ))m ago"
  elif [[ $_s -lt 86400 ]]; then _AGE_STR="$(( _s / 3600 ))h ago"
  else                           _AGE_STR="$(( _s / 86400 ))d ago"
  fi
}

_cmd_resume() {
  local _id="${2:-}"
  if [[ -z "$_id" ]]; then
    echo "Usage: claudii resume <session-id>" >&2
    echo "  Use 'claudii se' to list sessions with their IDs" >&2
    exit 1
  fi
  exec claude --resume "$_id"
}

# ── Source command modules ──────────────────────────────────────────────────
source "$CLAUDII_HOME/lib/cmd/system.sh"
source "$CLAUDII_HOME/lib/cmd/sessions.sh"
source "$CLAUDII_HOME/lib/cmd/display.sh"
source "$CLAUDII_HOME/lib/cmd/config.sh"

# ── Shorthand aliases — expand before main case statement ───────────────────
case "${1:-}" in
  s)     set -- status             "${@:2}" ;;
  se)    set -- sessions           "${@:2}" ;;
  ss)    set -- sessions           "${@:2}" ;;
  si)    set -- sessions-inactive  "${@:2}" ;;
  about) set -- changelog          "${@:2}" ;;
  c)     set -- cost               "${@:2}" ;;
  t)     set -- trends             "${@:2}" ;;
  d)     set -- doctor             "${@:2}" ;;
  g)     set -- gc                 "${@:2}" ;;
esac

# ── Main dispatcher ─────────────────────────────────────────────────────────
case "${1:-}" in
  # System commands
  on)                  _cmd_on                ;;
  off)                 _cmd_off               ;;
  claudestatus)        _cmd_claudestatus "$@"        ;;
  session-dashboard)   _cmd_session_dashboard "$@"   ;;
  dashboard)           _cmd_session_dashboard "$@"   ;; # deprecated alias
  status)              _cmd_status "$@"       ;;
  cc-statusline)       _cmd_cc_statusline "$@" ;;
  sessionline)         exec "$0" cc-statusline "${@:2}" ;;
  install-sessionline) exec "$0" cc-statusline on ;;
  update)              _cmd_update            ;;
  doctor)              _cmd_doctor            ;;

  # Session commands
  cost)                _cmd_cost              ;;
  sessions)
    if [[ "${2:-}" == "--resume" && -n "${3:-}" ]]; then
      exec claude --resume "$3"
    fi
    _cmd_sessions "$@"
    ;;
  sessions-inactive)   _cmd_sessions_inactive ;;
  pin)                 _cmd_pin "$@"          ;;
  unpin)               _cmd_unpin "$@"        ;;
  gc)                  _cmd_gc "$@"           ;;
  resume)              _cmd_resume "$@"       ;;
  "")                  _cmd_default           ;;

  # Display commands
  trends)              _cmd_trends            ;;
  explain)             _cmd_explain           ;;
  layers|components)   exec "$0" explain "${@:2}" ;;
  version)             _cmd_version           ;;
  changelog)           _cmd_changelog         ;;
  42)                  _cmd_42                ;;

  # Config commands
  config)              _cmd_config "$@"       ;;
  agents)              _cmd_agents            ;;
  search)              _cmd_search "$@"       ;;

  # Help
  help|--help|-h)      usage                  ;;

  # Unknown
  *)
    echo "Unknown command: $1 — run 'claudii help' for available commands" >&2
    usage; exit 1
    ;;
esac
