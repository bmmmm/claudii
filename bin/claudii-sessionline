#!/bin/bash
# claudii-sessionline — Claude Code statusLine handler
# Reads JSON session metrics from stdin, outputs a single info-dense line.
# Configure in settings.json:
#   "statusLine": { "type": "command", "command": "claudii-sessionline" }

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
# shellcheck source=lib/log.sh
source "$CLAUDII_HOME/lib/log.sh"

read -r json

# Write session data to cache (key=value) — RPROMPT reads this without jq
_cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
[[ -d "$_cache_dir" ]] || mkdir -p "$_cache_dir"

# Parse all fields in one jq call — single process, max efficiency
# Delimiter: Unit Separator (0x1F) — non-whitespace, so read won't collapse empty fields
_D=$'\x1f'
IFS="$_D" read -r model ctx_pct cost input_tok output_tok rate_5h rate_7d \
  duration_ms lines_add lines_rm ctx_size session_id reset_5h reset_7d \
  cache_read cache_create worktree_name agent_name model_id <<< "$(
  echo "$json" | jq -r '[
    (.model.display_name // ""),
    (.context_window.used_percentage // "" | tostring),
    (.cost.total_cost_usd // "" | tostring),
    (.context_window.total_input_tokens // "" | tostring),
    (.context_window.total_output_tokens // "" | tostring),
    (.rate_limits.five_hour.used_percentage // "" | tostring),
    (.rate_limits.seven_day.used_percentage // "" | tostring),
    (.cost.total_duration_ms // "" | tostring),
    (.cost.total_lines_added // "" | tostring),
    (.cost.total_lines_removed // "" | tostring),
    (.context_window.context_window_size // "" | tostring),
    (.session_id // ""),
    (.rate_limits.five_hour.resets_at // "" | tostring),
    (.rate_limits.seven_day.resets_at // "" | tostring),
    (.context_window.current_usage.cache_read_input_tokens // "" | tostring),
    (.context_window.current_usage.cache_creation_input_tokens // "" | tostring),
    (.workspace.name // .worktree.name // .workspace.worktree_name // ""),
    (.agent.name // .agent_name // ""),
    (.model.id // "")
  ] | join("\u001f")' 2>/dev/null || printf "${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}"
)"

# Cache hit percentage — computed from cache_read vs input tokens
_cache_pct=""
if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
  _cr=${cache_read%.*}
  _ci=${input_tok%.*}
  if (( _ci + _cr > 0 )); then
    _cache_pct=$(( _cr * 100 / (_cr + _ci) ))
  fi
fi

# 7d-Delta: record rate_7d_start on FIRST update if not yet set
_sid="${session_id:+${session_id:0:8}}"
_session_file="$_cache_dir/session-${_sid:-unknown}"
_rate_7d_start=""
if [[ -n "$rate_7d" && "$rate_7d" != "null" && "$rate_7d" != "" ]]; then
  # Check if existing cache file has rate_7d_start already
  if [[ -f "$_session_file" ]]; then
    _existing_cache=""
    { _existing_cache=$(<"$_session_file"); } 2>/dev/null
    if [[ $'\n'"$_existing_cache" == *$'\n'rate_7d_start=* ]]; then
      _rate_7d_start="${_existing_cache#*rate_7d_start=}"
      _rate_7d_start="${_rate_7d_start%%$'\n'*}"
    fi
  fi
  # If still empty, this is the first update — record current 7d as start
  [[ -z "$_rate_7d_start" ]] && _rate_7d_start="$rate_7d"
fi

# Track 5h rate-limit start value for delta display — set once, never overwritten
_rate_5h_start=""
if [[ -n "$rate_5h" && "$rate_5h" != "null" && -f "$_session_file" ]]; then
  _rate_5h_start=$(grep '^rate_5h_start=' "$_session_file" 2>/dev/null | cut -d= -f2-)
fi
if [[ -z "$_rate_5h_start" && -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _rate_5h_start="$rate_5h"
fi

# Burn-rate ETA — computed for dashboard cache, not rendered in sessionline
_burn_eta=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" && "$duration_ms" != "0" ]]; then
  _session_min_f=$(awk "BEGIN { printf \"%.4f\", $duration_ms / 60000 }")
  _session_min_int=${_session_min_f%.*}
  _rate_5h_int=${rate_5h%.*}
  if [[ -n "$rate_5h" && "$rate_5h" != "null" && "$rate_5h" != "0" ]] && \
     (( _session_min_int >= 3 && _rate_5h_int > 0 )); then
    _burn_eta=$(awk "BEGIN { r=$rate_5h; m=$_session_min_f; printf \"%d\", int((100-r)/(r/m) + 0.5) }")
  fi
fi

# Write per-session cache (key=value) — RPROMPT + aliases read without jq
# Include ppid so dashboard can check if Claude process is still alive
_ppid="${PPID:-}"
{ printf '%s\n' \
  "model=$model" "ctx_pct=$ctx_pct" "cost=$cost" \
  "rate_5h=$rate_5h" "rate_7d=$rate_7d" \
  "reset_5h=$reset_5h" "reset_7d=$reset_7d" \
  "session_id=$session_id" \
  "worktree=$worktree_name" \
  "agent=$agent_name" \
  "model_id=$model_id" \
  "burn_eta=$_burn_eta" \
  "cache_pct=$_cache_pct" \
  "ppid=$_ppid" \
  "rate_7d_start=$_rate_7d_start" \
  "rate_5h_start=$_rate_5h_start" \
  > "$_session_file"; } 2>/dev/null || true

# Append to persistent history (Flight Recorder) — one TSV line per update
# Fields: timestamp, model, cost, ctx_pct, rate_5h, session_id
printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
  "$(date +%s)" "$model" "$cost" "$ctx_pct" "$rate_5h" "$session_id" \
  >> "$_cache_dir/history.tsv" 2>/dev/null || true

_claudii_log debug "input: $(echo "$json" | head -c 200)"
_claudii_log debug "parsed: model=${model} ctx=${ctx_pct} cost=${cost} in=${input_tok} out=${output_tok} 5h=${rate_5h} 7d=${rate_7d} dur=${duration_ms} +${lines_add} -${lines_rm} win=${ctx_size} sid=${session_id:0:8} r5h=${reset_5h} r7d=${reset_7d} cache_r=${cache_read} cache_c=${cache_create} wt=${worktree_name} agent=${agent_name} model_id=${model_id}"

# --- helpers ---

# Format token count: 1234->1.2K  1234567->1.2M
_tok() {
  local n=$1
  [[ -z "$n" || "$n" == "null" ]] && return
  if (( n >= 1000000 )); then
    printf "%.1fM" "$(echo "scale=1; $n/1000000" | bc)"
  elif (( n >= 1000 )); then
    printf "%.1fK" "$(echo "scale=1; $n/1000" | bc)"
  else
    echo "$n"
  fi
}

# Format duration: ms -> "<1m", "5m", "1h 23m"
_dur() {
  local ms=$1
  [[ -z "$ms" || "$ms" == "null" ]] && return
  local sec=$(( ${ms%.*} / 1000 ))
  if (( sec < 60 )); then printf "<1m"
  elif (( sec < 3600 )); then printf "%dm" $(( sec / 60 ))
  else printf "%dh %dm" $(( sec / 3600 )) $(( (sec % 3600) / 60 ))
  fi
}

# Threshold color: green < 70, yellow 70-89, red 90+
_thr() {
  local pct=${1%.*}
  [[ -z "$pct" ]] && pct=0
  if (( pct >= 90 )); then printf "\033[31m"
  elif (( pct >= 70 )); then printf "\033[33m"
  else printf "\033[32m"
  fi
}

# Rate limit color: cyan < 50, yellow 50-79, red 80+
_rlc() {
  local pct=${1%.*}
  [[ -z "$pct" ]] && pct=0
  if (( pct >= 80 )); then printf "\033[31m"
  elif (( pct >= 50 )); then printf "\033[33m"
  else printf "\033[36m"
  fi
}

RST="\033[0m"
DIM="\033[2m"
SEP="${DIM} │${RST} "

# --- build output ---
out=""

# Terminal width for adaptive truncation
# Default to 120 (full output) when COLUMNS is not set — the sessionline
# runs inside Claude Code which controls its own rendering width.
_cols="${COLUMNS:-120}"

# Model (bold) + effort mode (dim, from env — workaround until API exposes it)
if [[ -n "$model" ]]; then
  out+="\033[1m${model}${RST}"
  _effort="${CLAUDII_EFFORT:-}"
  if [[ -n "$_effort" && "$_effort" != "high" ]]; then
    out+=" ${DIM}${_effort}${RST}"
  fi
fi

# Context bar (10 chars) + percentage — always shown (>= any width)
if [[ -n "$ctx_pct" && "$ctx_pct" != "null" ]]; then
  local_pct=${ctx_pct%.*}
  (( local_pct < 0 )) && local_pct=0
  (( local_pct > 100 )) && local_pct=100
  filled=$(( local_pct / 10 ))
  empty=$(( 10 - filled ))
  bar=""
  (( filled > 0 )) && printf -v f "%${filled}s" "" && bar="${f// /█}"
  (( empty > 0 )) && printf -v e "%${empty}s" "" && bar="${bar}${e// /░}"
  # Context window size indicator (1M = extended)
  win=""
  if [[ -n "$ctx_size" && "$ctx_size" != "null" && "$ctx_size" -ge 1000000 ]] 2>/dev/null; then
    win=" ${DIM}1M${RST}"
  fi
  out+=" $(_thr "$local_pct")${bar}${RST} ${DIM}${local_pct}%${RST}${win}"
fi

# Truncation logic: segments shown based on COLUMNS
# < 60: only model + context bar (already added)
# 60-80: + cost
# 80-100: + rate limits
# > 100: everything (tokens, lines, duration)

# Cost — shown when cols >= 60
if (( _cols >= 60 )); then
  if [[ -n "$cost" && "$cost" != "null" && "$cost" != "0" ]]; then
    out+="${SEP}\033[36m\$$(printf '%.2f' "$cost")${RST}"
  fi
fi

# Rate limits — shown when cols >= 80
if (( _cols >= 80 )); then
  if [[ -n "$rate_5h" && "$rate_5h" != "null" ]]; then
    _rate_5h_pct=${rate_5h%.*}

    # 5h delta vs session start
    _delta_str=""
    if [[ -n "$_rate_5h_start" && "$_rate_5h_start" != "null" ]]; then
      _start_pct=${_rate_5h_start%.*}
      _delta=$(( _rate_5h_pct - _start_pct ))
      if (( _delta > 0 )); then
        _delta_str=" ${DIM}(+${_delta}%)${RST}"
      elif (( _delta < 0 )); then
        _delta_str=" ${DIM}(${_delta}%)${RST}"
      fi
    fi

    out+="${SEP}$(_rlc "$rate_5h")5h:${_rate_5h_pct}%${RST}"

    # Reset countdown ↺Xm — color depends on rate level and time remaining
    if [[ -n "$reset_5h" && "$reset_5h" != "null" && "$reset_5h" != "" ]]; then
      _now=$(date +%s)
      _reset_min=$(awk "BEGIN { d=$reset_5h - $_now; printf \"%d\", (d > 0 ? int(d/60 + 0.5) : 0) }")
      if (( _reset_min > 0 )); then
        if (( _rate_5h_pct < 50 )); then
          _reset_color="${DIM}"         # dim — not relevant
        elif (( _reset_min < 5 )); then
          _reset_color="\033[0;32m"    # green — refresh imminent!
        elif (( _reset_min < 60 )); then
          _reset_color="\033[0;97m"    # bright white — getting close
        elif (( _reset_min < 120 )); then
          _reset_color=""              # default — light at end of tunnel
        else
          _reset_color="${DIM}"        # dim — plenty of time
        fi
        out+=" ${_reset_color}↺${_reset_min}m${RST}"
      fi
    fi
  fi

  if [[ -n "$rate_7d" && "$rate_7d" != "null" ]]; then
    [[ -z "$rate_5h" || "$rate_5h" == "null" ]] && out+="${SEP}"
    _rate_7d_pct=${rate_7d%.*}

    # 7d delta vs session start
    _delta_7d_str=""
    if [[ -n "$_rate_7d_start" && "$_rate_7d_start" != "null" ]]; then
      _start_7d_pct=${_rate_7d_start%.*}
      _delta_7d=$(( _rate_7d_pct - _start_7d_pct ))
      if (( _delta_7d > 0 )); then
        _delta_7d_str=" ${DIM}(+${_delta_7d}%)${RST}"
      elif (( _delta_7d < 0 )); then
        _delta_7d_str=" ${DIM}(${_delta_7d}%)${RST}"
      fi
    fi

    out+=" $(_rlc "$rate_7d")7d:${_rate_7d_pct}%${RST}"

    # 7d reset countdown — format depends on remaining time
    if [[ -n "$reset_7d" && "$reset_7d" != "null" && "$reset_7d" != "" ]]; then
      _now=$(date +%s)
      _reset_7d_sec=$(awk "BEGIN { d=$reset_7d - $_now; printf \"%d\", (d > 0 ? int(d + 0.5) : 0) }")
      if (( _reset_7d_sec > 0 )); then
        _reset_7d_min=$(( _reset_7d_sec / 60 ))
        _reset_7d_hr=$(( _reset_7d_sec / 3600 ))
        if (( _reset_7d_sec < 3600 )); then
          _reset_7d_fmt="${_reset_7d_min}m"
        elif (( _reset_7d_sec < 86400 )); then
          _reset_7d_fmt="${_reset_7d_hr}h"
        else
          _r7d_days=$(( _reset_7d_sec / 86400 ))
          _r7d_hours=$(( (_reset_7d_sec % 86400) / 3600 ))
          if (( _r7d_hours > 0 )); then
            _reset_7d_fmt="${_r7d_days}d${_r7d_hours}h"
          else
            _reset_7d_fmt="${_r7d_days}d"
          fi
        fi
        if (( _rate_7d_pct < 50 )); then
          _reset_7d_color="${DIM}"         # dim — not relevant
        elif (( _reset_7d_min < 5 )); then
          _reset_7d_color="\033[0;32m"    # green — refresh imminent!
        elif (( _reset_7d_min < 60 )); then
          _reset_7d_color="\033[0;97m"    # bright white — getting close
        elif (( _reset_7d_min < 120 )); then
          _reset_7d_color=""              # default — light at end of tunnel
        else
          _reset_7d_color="${DIM}"        # dim — plenty of time
        fi
        out+=" ${_reset_7d_color}↺${_reset_7d_fmt}${RST}"
      fi
    fi
  fi
fi

# Full details — shown when cols > 100
if (( _cols > 100 )); then
  # Tokens (compact: 15K↑ 4K↓ ⚡73%)
  if [[ -n "$input_tok" && "$input_tok" != "null" ]]; then
    in_fmt=$(_tok "$input_tok")
    out_fmt=$(_tok "$output_tok")
    out+="${SEP}${DIM}${in_fmt}↑${RST}"
    [[ -n "$out_fmt" ]] && out+=" ${DIM}${out_fmt}↓${RST}"
    # Cache hit ratio — only show when cache_read > 0
    if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
      if [[ -n "$_cache_pct" && "$_cache_pct" != "0" ]]; then
        if (( _cache_pct >= 60 )); then _cc="\033[32m"
        elif (( _cache_pct < 30 )); then _cc="\033[33m"
        else _cc="${DIM}"; fi
        out+=" ${_cc}⚡${_cache_pct}%${RST}"
      fi
    fi
  fi

  # Lines changed (only when > 0)
  if [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] || \
     [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]]; then
    lns=""
    [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] && lns+="\033[32m+${lines_add}${RST}"
    [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]] && lns+=" \033[31m-${lines_rm}${RST}"
    out+="${SEP}${lns}"
  fi

  # Duration
  if [[ -n "$duration_ms" && "$duration_ms" != "null" ]]; then
    dur=$(_dur "$duration_ms")
    [[ -n "$dur" ]] && out+="${SEP}${DIM}${dur}${RST}"
  fi
fi

echo -e "$out"
