#!/bin/bash
# claudii-sessionline â€” Claude Code statusLine handler
# Reads JSON session metrics from stdin, outputs a configurable multi-line status.
# Configure in settings.json:
#   "statusLine": { "type": "command", "command": "claudii-sessionline" }

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
# shellcheck source=lib/log.sh
source "$CLAUDII_HOME/lib/log.sh"

read -r json

# Write session data to cache (key=value) â€” RPROMPT reads this without jq
_cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
[[ -d "$_cache_dir" ]] || mkdir -p "$_cache_dir"

# Parse all fields in one jq call â€” single process, max efficiency
# Delimiter: Unit Separator (0x1F) â€” non-whitespace, so read won't collapse empty fields
_D=$'\x1f'
IFS="$_D" read -r model ctx_pct cost input_tok output_tok rate_5h rate_7d \
  duration_ms lines_add lines_rm ctx_size session_id reset_5h reset_7d \
  cache_read cache_create worktree_name agent_name model_id cwd \
  session_name worktree_branch api_duration_ms exceeds_200k <<< "$(
  echo "$json" | jq -r '[
    (.model.display_name // ""),
    (.context_window.used_percentage // "" | tostring),
    (.cost.total_cost_usd // "" | tostring),
    (.context_window.total_input_tokens // "" | tostring),
    (.context_window.total_output_tokens // "" | tostring),
    (.rate_limits.five_hour.used_percentage // "" | tostring),
    (.rate_limits.seven_day.used_percentage // "" | tostring),
    (.cost.total_duration_ms // "" | tostring),
    (.cost.total_lines_added // "" | tostring),
    (.cost.total_lines_removed // "" | tostring),
    (.context_window.context_window_size // "" | tostring),
    (.session_id // ""),
    (.rate_limits.five_hour.resets_at // "" | tostring),
    (.rate_limits.seven_day.resets_at // "" | tostring),
    (.context_window.current_usage.cache_read_input_tokens // "" | tostring),
    (.context_window.current_usage.cache_creation_input_tokens // "" | tostring),
    (.worktree.name // ""),
    (.agent.name // ""),
    (.model.id // ""),
    (.workspace.current_dir // .cwd // ""),
    (.session_name // ""),
    (.worktree.branch // ""),
    (.cost.total_api_duration_ms // "" | tostring),
    (.exceeds_200k_tokens // false | tostring)
  ] | join("\u001f")' 2>/dev/null || printf "${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}"
)"

# Cache hit percentage â€” computed from cache_read vs input tokens
_cache_pct=""
if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
  _cr=${cache_read%.*}
  _ci=${input_tok%.*}
  if (( _ci + _cr > 0 )); then
    _cache_pct=$(( _cr * 100 / (_cr + _ci) ))
  fi
fi

# 7d-Delta: record rate_7d_start on FIRST update if not yet set
_sid="${session_id:+${session_id:0:8}}"
_session_file="$_cache_dir/session-${_sid:-unknown}"
_rate_7d_start=""
if [[ -n "$rate_7d" && "$rate_7d" != "null" && "$rate_7d" != "" ]]; then
  # Check if existing cache file has rate_7d_start already
  if [[ -f "$_session_file" ]]; then
    _existing_cache=""
    { _existing_cache=$(<"$_session_file"); } 2>/dev/null
    if [[ $'\n'"$_existing_cache" == *$'\n'rate_7d_start=* ]]; then
      _rate_7d_start="${_existing_cache#*rate_7d_start=}"
      _rate_7d_start="${_rate_7d_start%%$'\n'*}"
    fi
  fi
  # If still empty, this is the first update â€” record current 7d as start
  [[ -z "$_rate_7d_start" ]] && _rate_7d_start="$rate_7d"
fi

# Track 5h rate-limit start value for delta display â€” set once, never overwritten
_rate_5h_start=""
if [[ -n "$rate_5h" && "$rate_5h" != "null" && -f "$_session_file" ]]; then
  _rate_5h_start=$(grep '^rate_5h_start=' "$_session_file" 2>/dev/null | cut -d= -f2-)
fi
if [[ -z "$_rate_5h_start" && -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _rate_5h_start="$rate_5h"
fi

# Burn-rate ETA â€” computed for dashboard cache, not rendered in sessionline
_burn_eta=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" && "$duration_ms" != "0" ]]; then
  _session_min_f=$(awk "BEGIN { printf \"%.4f\", $duration_ms / 60000 }")
  _session_min_int=${_session_min_f%.*}
  _rate_5h_int=${rate_5h%.*}
  if [[ -n "$rate_5h" && "$rate_5h" != "null" && "$rate_5h" != "0" ]] && \
     (( _session_min_int >= 3 && _rate_5h_int > 0 )); then
    _burn_eta=$(awk "BEGIN { r=$rate_5h; m=$_session_min_f; printf \"%d\", int((100-r)/(r/m) + 0.5) }")
  fi
fi

# Write per-session cache (key=value) â€” RPROMPT + aliases read without jq
# Include ppid so dashboard can check if Claude process is still alive
# Atomic write: write to tmp then rename â€” prevents RPROMPT from reading partial data
_ppid="${PPID:-}"
_tmp_session="${_session_file}.tmp.$$"
{ printf '%s\n' \
  "model=$model" "ctx_pct=$ctx_pct" "cost=$cost" \
  "rate_5h=$rate_5h" "rate_7d=$rate_7d" \
  "reset_5h=$reset_5h" "reset_7d=$reset_7d" \
  "session_id=$session_id" \
  "worktree=$worktree_name" \
  "agent=$agent_name" \
  "model_id=$model_id" \
  "burn_eta=$_burn_eta" \
  "cache_pct=$_cache_pct" \
  "ppid=$_ppid" \
  "rate_7d_start=$_rate_7d_start" \
  "rate_5h_start=$_rate_5h_start" \
  "project_path=$cwd" \
  > "$_tmp_session" && mv -f "$_tmp_session" "$_session_file"; } 2>/dev/null || true

# Append to persistent history (Flight Recorder) â€” one TSV line per update
# Fields: timestamp, model, cost, ctx_pct, rate_5h, session_id, input_tok, output_tok, api_duration_ms
_now=$(date +%s)
printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
  "$_now" "$model" "$cost" "$ctx_pct" "$rate_5h" "$session_id" \
  "${input_tok:-0}" "${output_tok:-0}" "${api_duration_ms:-0}" \
  >> "$_cache_dir/history.tsv" 2>/dev/null || true

_claudii_log debug "input: $(echo "$json" | head -c 200)"
_claudii_log debug "parsed: model=${model} ctx=${ctx_pct} cost=${cost} in=${input_tok} out=${output_tok} 5h=${rate_5h} 7d=${rate_7d} dur=${duration_ms} +${lines_add} -${lines_rm} win=${ctx_size} sid=${session_id:0:8} r5h=${reset_5h} r7d=${reset_7d} cache_r=${cache_read} cache_c=${cache_create} wt=${worktree_name} agent=${agent_name} model_id=${model_id}"

# --- helpers ---

# Format token count: 999->999  1000->1.0K  1500->1.5K  1000000->1.0M
_tok() {
  local n=$1
  [[ -z "$n" || "$n" == "null" ]] && return
  if   (( n >= 1000000 )); then awk "BEGIN{printf \"%.1fM\",$n/1000000}"
  elif (( n >= 1000    )); then awk "BEGIN{printf \"%.1fK\",$n/1000}"
  else printf "%d" "$n"
  fi
}

# Format duration: ms -> "<1m", "5m", "1h 23m"
_dur() {
  local ms=$1
  [[ -z "$ms" || "$ms" == "null" ]] && return
  local sec=$(( ${ms%.*} / 1000 ))
  if (( sec < 60 )); then printf "<1m"
  elif (( sec < 3600 )); then printf "%dm" $(( sec / 60 ))
  else printf "%dh %dm" $(( sec / 3600 )) $(( (sec % 3600) / 60 ))
  fi
}

# Threshold color: green < 70, yellow 70-89, red 90+
_thr() {
  local pct=${1%.*}
  [[ -z "$pct" ]] && pct=0
  if (( pct >= 90 )); then printf "\033[31m"
  elif (( pct >= 70 )); then printf "\033[33m"
  else printf "\033[32m"
  fi
}

# Rate limit color: cyan < 50, yellow 50-79, red 80+
_rlc() {
  local pct=${1%.*}
  [[ -z "$pct" ]] && pct=0
  if (( pct >= 80 )); then printf "\033[31m"
  elif (( pct >= 50 )); then printf "\033[33m"
  else printf "\033[36m"
  fi
}

RST="\033[0m"
DIM="\033[2m"
SEP="${DIM}  â”‚  ${RST}"

# --- segment pre-computation ---

# Model (bold) + effort mode (dim, from env â€” workaround until API exposes it)
_seg_model=""
if [[ -n "$model" ]]; then
  _seg_model="\033[1m${model}${RST}"
  _effort="${CLAUDII_EFFORT:-}"
  if [[ -n "$_effort" && "$_effort" != "high" ]]; then
    _seg_model+=" ${DIM}${_effort}${RST}"
  fi
fi

# Context bar (10 chars) + usable percentage + âš¡cache%
_seg_context=""
if [[ -n "$ctx_pct" && "$ctx_pct" != "null" ]]; then
  local_pct=${ctx_pct%.*}
  (( local_pct < 0 )) && local_pct=0
  (( local_pct > 100 )) && local_pct=100
  # Usable context %: raw_pct / 0.8 â€” scales to the 80% practical usable window
  # Example: 76% raw â†’ 76/0.8 = 95% usable. Bar and number both reflect usable %.
  _usable_pct=$(awk "BEGIN { v = int($local_pct / 0.8); if (v > 100) v = 100; printf \"%d\", v }")
  filled=$(( _usable_pct / 10 ))
  empty=$(( 10 - filled ))
  bar=""
  (( filled > 0 )) && printf -v f "%${filled}s" "" && bar="${f// /â–ˆ}"
  (( empty > 0 )) && printf -v e "%${empty}s" "" && bar="${bar}${e// /â–‘}"
  # Context size indicator: >200k flag (current API call exceeded 200k tokens)
  # or 1M label when extended context window active
  win=""
  if [[ "$exceeds_200k" == "true" ]]; then
    win=" \033[31m>200k${RST}"
  elif [[ -n "$ctx_size" && "$ctx_size" != "null" && "$ctx_size" -ge 1000000 ]] 2>/dev/null; then
    win=" ${DIM}1M${RST}"
  fi
  _seg_context="$(_thr "$_usable_pct")${bar}${RST} ${DIM}${_usable_pct}%${RST}${win}"
  # Cache hit ratio â€” suffix to context segment
  if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
    if [[ -n "$_cache_pct" && "$_cache_pct" != "0" ]]; then
      if (( _cache_pct >= 60 )); then _cc="\033[32m"
      elif (( _cache_pct < 30 )); then _cc="\033[33m"
      else _cc="${DIM}"; fi
      _seg_context+=" ${_cc}âš¡${_cache_pct}%${RST}"
    fi
  fi
fi

# Cost â€” cyan $X.XX
_seg_cost=""
if [[ -n "$cost" && "$cost" != "null" && "$cost" != "0" ]]; then
  _seg_cost="\033[36m\$$(printf '%.2f' "$cost")${RST}"
fi

# Rate limits â€” 5h and 7d
_seg_rate5h=""
if [[ -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _rate_5h_pct=${rate_5h%.*}
  _seg_rate5h="$(_rlc "$rate_5h")5h:${_rate_5h_pct}%${RST}"
  # Reset countdown â†ºXm â€” color depends on rate level and time remaining
  if [[ -n "$reset_5h" && "$reset_5h" != "null" && "$reset_5h" != "" ]]; then
    _reset_min=$(awk "BEGIN { d=$reset_5h - $_now; printf \"%d\", (d > 0 ? int(d/60 + 0.5) : 0) }")
    if (( _reset_min > 0 )); then
      if (( _rate_5h_pct < 50 )); then
        _reset_color="${DIM}"         # dim â€” not relevant
      elif (( _reset_min < 5 )); then
        _reset_color="\033[0;32m"    # green â€” refresh imminent!
      elif (( _reset_min < 60 )); then
        _reset_color="\033[0;97m"    # bright white â€” getting close
      elif (( _reset_min < 120 )); then
        _reset_color=""              # default â€” light at end of tunnel
      else
        _reset_color="${DIM}"        # dim â€” plenty of time
      fi
      _seg_rate5h+=" ${_reset_color}â†º${_reset_min}m${RST}"
    fi
  fi
fi

_seg_rate7d=""
if [[ -n "$rate_7d" && "$rate_7d" != "null" ]]; then
  _rate_7d_pct=${rate_7d%.*}
  _seg_rate7d="$(_rlc "$rate_7d")7d:${_rate_7d_pct}%${RST}"
  # 7d reset countdown â€” format depends on remaining time
  if [[ -n "$reset_7d" && "$reset_7d" != "null" && "$reset_7d" != "" ]]; then
    _reset_7d_sec=$(awk "BEGIN { d=$reset_7d - $_now; printf \"%d\", (d > 0 ? int(d + 0.5) : 0) }")
    if (( _reset_7d_sec > 0 )); then
      _reset_7d_min=$(( _reset_7d_sec / 60 ))
      _reset_7d_hr=$(( _reset_7d_sec / 3600 ))
      if (( _reset_7d_sec < 3600 )); then
        _reset_7d_fmt="${_reset_7d_min}m"
      elif (( _reset_7d_sec < 86400 )); then
        _reset_7d_fmt="${_reset_7d_hr}h"
      else
        _r7d_days=$(( _reset_7d_sec / 86400 ))
        _r7d_hours=$(( (_reset_7d_sec % 86400) / 3600 ))
        if (( _r7d_hours > 0 )); then
          _reset_7d_fmt="${_r7d_days}d${_r7d_hours}h"
        else
          _reset_7d_fmt="${_r7d_days}d"
        fi
      fi
      if (( _rate_7d_pct < 50 )); then
        _reset_7d_color="${DIM}"         # dim â€” not relevant
      elif (( _reset_7d_min < 5 )); then
        _reset_7d_color="\033[0;32m"    # green â€” refresh imminent!
      elif (( _reset_7d_min < 60 )); then
        _reset_7d_color="\033[0;97m"    # bright white â€” getting close
      elif (( _reset_7d_min < 120 )); then
        _reset_7d_color=""              # default â€” light at end of tunnel
      else
        _reset_7d_color="${DIM}"        # dim â€” plenty of time
      fi
      _seg_rate7d+=" ${_reset_7d_color}â†º${_reset_7d_fmt}${RST}"
    fi
  fi
fi

# Tokens: DIM Xkâ†‘ Xkâ†“
_seg_tokens=""
if [[ -n "$input_tok" && "$input_tok" != "null" ]]; then
  in_fmt=$(_tok "$input_tok")
  out_fmt=$(_tok "$output_tok")
  _seg_tokens="${DIM}${in_fmt}â†‘${RST}"
  [[ -n "$out_fmt" ]] && _seg_tokens+=" ${DIM}${out_fmt}â†“${RST}"
fi

# Lines changed: green +X red -X (only when > 0)
_seg_lines=""
if [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] || \
   [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]]; then
  [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] && _seg_lines+="\033[32m+${lines_add}${RST}"
  [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]] && _seg_lines+=" \033[31m-${lines_rm}${RST}"
fi

# Duration: DIM Xm / Xh Xm
_seg_dur=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" ]]; then
  _dur_fmt=$(_dur "$duration_ms")
  [[ -n "$_dur_fmt" ]] && _seg_dur="${DIM}${_dur_fmt}${RST}"
fi

# Burn-ETA: DIM ETA:Xm (only when _burn_eta set and > 0)
_seg_eta=""
if [[ -n "$_burn_eta" && "$_burn_eta" != "0" ]] 2>/dev/null; then
  _seg_eta="${DIM}ETA:${_burn_eta}m${RST}"
fi

# Worktree: name + branch if available (only when in a worktree session)
_seg_worktree=""
if [[ -n "$worktree_name" ]]; then
  _seg_worktree="${DIM}${worktree_name}${RST}"
  [[ -n "$worktree_branch" ]] && _seg_worktree+=" ${DIM}âŽ‡ ${worktree_branch}${RST}"
fi

# Agent: DIM @agent_name (only when set)
_seg_agent=""
if [[ -n "$agent_name" ]]; then
  _seg_agent="${DIM}@${agent_name}${RST}"
fi

# Session name: custom name set via /rename or --name (only when set)
_seg_session_name=""
if [[ -n "$session_name" ]]; then
  _seg_session_name="${DIM}${session_name}${RST}"
fi

# API duration: time actually spent waiting for Claude (vs. total wall-clock)
_seg_api_dur=""
if [[ -n "$api_duration_ms" && "$api_duration_ms" != "null" ]]; then
  _api_fmt=$(_dur "$api_duration_ms")
  if [[ -n "$_api_fmt" ]]; then
    _seg_api_dur="${DIM}api:${_api_fmt}${RST}"
    # Add ratio if total duration available and > 0
    if [[ -n "$duration_ms" && "$duration_ms" != "null" ]]; then
      _dur_int=${duration_ms%.*}
      _api_int=${api_duration_ms%.*}
      if (( _dur_int > 0 && _api_int > 0 && _api_int <= _dur_int )); then
        _api_pct=$(awk "BEGIN { printf \"%d\", int($_api_int / $_dur_int * 100) }")
        _seg_api_dur+=" ${DIM}(${_api_pct}%)${RST}"
      fi
    fi
  fi
fi

# Session deltas: only the change since session start (current rate is already on line 1)
_seg_delta5h=""
if [[ -n "$_rate_5h_start" && "$_rate_5h_start" != "null" && -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _d5=$(( ${rate_5h%.*} - ${_rate_5h_start%.*} ))
  if (( _d5 > 0 )); then
    _seg_delta5h="${DIM}Î”5h:${RST}$(_rlc "$rate_5h")+${_d5}%${RST}"
  elif (( _d5 < 0 )); then
    _seg_delta5h="${DIM}Î”5h:${RST}\033[32m${_d5}%${RST}"
  fi
fi

_seg_delta7d=""
if [[ -n "$_rate_7d_start" && "$_rate_7d_start" != "null" && -n "$rate_7d" && "$rate_7d" != "null" ]]; then
  _d7=$(( ${rate_7d%.*} - ${_rate_7d_start%.*} ))
  if (( _d7 > 0 )); then
    _seg_delta7d="${DIM}Î”7d:${RST}$(_rlc "$rate_7d")+${_d7}%${RST}"
  elif (( _d7 < 0 )); then
    _seg_delta7d="${DIM}Î”7d:${RST}\033[32m${_d7}%${RST}"
  fi
fi

# Cache writes: tokens written INTO cache this session (costs extra vs cache reads)
# Distinct from âš¡cache-pct (hit ratio) â€” this shows write volume
_seg_cache_create=""
if [[ -n "$cache_create" && "$cache_create" != "null" && "$cache_create" != "0" ]]; then
  _cc_fmt=$(_tok "$cache_create")
  [[ -n "$_cc_fmt" ]] && _seg_cache_create="${DIM}âœŽ${_cc_fmt}${RST}"
fi

# Terminal width â€” used by ruler segment to fill remaining space
# COLUMNS (exported by parent shell) is more reliable than tput cols in piped context
_term_cols=""
[[ -n "$COLUMNS" ]] && (( COLUMNS > 20 )) && _term_cols="$COLUMNS"
[[ -z "$_term_cols" ]] && _term_cols=$(tput cols 2>/dev/null)
# If width unknown or implausible: set to 0 â€” ruler will silently skip
(( _term_cols > 20 )) || _term_cols=0

# --- layout config ---

_DEFAULT_LINES="model,context-bar,cache-create
rate-5h,rate-7d,burn-eta,lines-changed
api-duration,tokens,worktree"

_lines_raw="$_DEFAULT_LINES"
_config_file="${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json"
if [[ -f "$_config_file" ]]; then
  _from_cfg=$(jq -r 'if .statusline.lines then (.statusline.lines | .[] | join(",")) else empty end' \
    "$_config_file" 2>/dev/null)
  [[ -n "$_from_cfg" ]] && _lines_raw="$_from_cfg"
fi

# --- layout loop ---

while IFS= read -r _line_segs; do
  [[ -z "$_line_segs" ]] && continue
  _line_out=""; _first=1
  IFS=',' read -ra _segs <<< "$_line_segs"
  for _seg in "${_segs[@]}"; do
    case "$_seg" in
      model)         _val="$_seg_model"    ;;
      context-bar)   _val="$_seg_context"  ;;
      cost)          _val="$_seg_cost"     ;;
      rate-5h)       _val="$_seg_rate5h"   ;;
      rate-7d)       _val="$_seg_rate7d"   ;;
      tokens)        _val="$_seg_tokens"   ;;
      lines-changed) _val="$_seg_lines"    ;;
      duration)      _val="$_seg_dur"      ;;
      burn-eta)      _val="$_seg_eta"      ;;
      worktree)      _val="$_seg_worktree"       ;;
      agent)         _val="$_seg_agent"         ;;
      session-name)  _val="$_seg_session_name"  ;;
      api-duration)  _val="$_seg_api_dur"       ;;
      delta-5h)      _val="$_seg_delta5h"       ;;
      delta-7d)      _val="$_seg_delta7d"       ;;
      cache-create)  _val="$_seg_cache_create"  ;;
      ruler)
        # Fill remaining terminal width with â”€
        # Skip entirely if width unknown â€” prevents overflow and wrapping in narrow terminals
        _val=""
        if (( _term_cols > 0 )); then
          if (( _first )); then
            _used=0
          else
            _vis=$(echo -e "$_line_out" | sed 's/\x1b\[[0-9;]*m//g')
            _used=$(( ${#_vis} + 5 ))  # +5 for the "  â”‚  " separator to be prepended
          fi
          _fill=$(( _term_cols - _used ))
          if (( _fill > 1 )); then
            printf -v _v "%${_fill}s" ""
            _val="${DIM}${_v// /â”€}${RST}"
          fi
        fi
        ;;
      *)             _val=""               ;;
    esac
    if [[ -n "$_val" ]]; then
      if (( _first )); then _line_out="$_val"; _first=0
      else _line_out+="${SEP}${_val}"; fi
    fi
  done
  [[ -n "$_line_out" ]] && echo -e "\033[0m${_line_out}" || true
done <<< "$_lines_raw"
true
