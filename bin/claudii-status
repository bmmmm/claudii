#!/bin/bash
# claudii-status — checks model health
#
# Strategy:
#   1. unresolved.json → active incidents (authoritative, structured, no HTML parsing)
#      Empty incidents[] = all OK. Non-empty = parse name + impact for affected models.
#   2. RSS fallback → only when unresolved.json is unreachable
#      Parses HTML-encoded <strong> status tags to skip resolved items.
#
# Cache format: model=ok|degraded|down  (+ optional _api=unreachable marker)
# Exit codes:   0=all ok, 1=some degraded or down
#
# Env overrides: CLAUDII_UNRESOLVED_URL, CLAUDII_RSS_URL, CLAUDII_CACHE_TTL

set -uo pipefail

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
command -v jq >/dev/null 2>&1 || { printf 'claudii-status: jq not found — install jq\n' >&2; exit 1; }
CACHE_DIR="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
mkdir -p "$CACHE_DIR" && chmod 0700 "$CACHE_DIR"
CACHE_STATUS="$CACHE_DIR/status-models"
CACHE_INCIDENTS="$CACHE_DIR/status-unresolved.json"
CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json"
DEFAULTS="${CLAUDII_HOME}/config/defaults.json"
_cfg() { jq -r "if (.$1 | type) != \"null\" then (.$1 | tostring) else empty end" "$CONFIG" 2>/dev/null; }
_def() { jq -r "if (.$1 | type) != \"null\" then (.$1 | tostring) else empty end" "$DEFAULTS" 2>/dev/null; }

CACHE_TTL="${CLAUDII_CACHE_TTL:-$(_cfg status.cache_ttl)}"
CACHE_TTL="${CACHE_TTL:-$(_def status.cache_ttl)}"
CACHE_TTL="${CACHE_TTL:-300}"

RSS_URL="${CLAUDII_RSS_URL:-$(_cfg status.rss_url)}"
RSS_URL="${RSS_URL:-https://status.claude.com/history.rss}"

_base_url="${RSS_URL%/history.rss}"; _base_url="${_base_url%/}"
UNRESOLVED_URL="${CLAUDII_UNRESOLVED_URL:-$(_cfg status.unresolved_url)}"
UNRESOLVED_URL="${UNRESOLVED_URL:-$(_def status.unresolved_url)}"
UNRESOLVED_URL="${UNRESOLVED_URL:-${_base_url}/api/v2/incidents/unresolved.json}"

case "${RSS_URL}" in
  https://*) ;;
  *) printf "error: RSS_URL must use https:// (got: %s)\n" "$RSS_URL" >&2; exit 1 ;;
esac
case "${UNRESOLVED_URL}" in
  https://*) ;;
  *) printf "error: UNRESOLVED_URL must use https:// (got: %s)\n" "$UNRESOLVED_URL" >&2; exit 1 ;;
esac

_mtime() { stat -f%m "$1" 2>/dev/null || stat -c%Y "$1" 2>/dev/null || echo 0; }
_tmp_status="${CACHE_STATUS}.tmp.$$"
_tmp_incidents="${CACHE_INCIDENTS}.tmp.$$"
trap 'rm -f "$_tmp_status" "$_tmp_incidents"' EXIT

source "${CLAUDII_HOME}/lib/log.sh"

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

quiet=false
_pid_file=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet) quiet=true ;;
    --pid-file) shift; _pid_file="${1:-}" ;;
    --pid-file=*) _pid_file="${1#--pid-file=}" ;;
  esac
  shift
done

[[ -n "$_pid_file" ]] && printf '%s\n' "$$" > "$_pid_file"

models_raw="${CLAUDII_MODELS:-$(_cfg statusline.models)}"
models_raw="${models_raw:-$(_def statusline.models)}"
models_raw="${models_raw:-opus,sonnet,haiku}"
IFS=',' read -ra MODELS <<< "$models_raw"
for i in "${!MODELS[@]}"; do MODELS[$i]="${MODELS[$i]// /}"; done

_claudii_log debug "Unresolved: $UNRESOLVED_URL | RSS: $RSS_URL | TTL: ${CACHE_TTL}s | Models: ${MODELS[*]}"

# ── Cache check ───────────────────────────────────────────────────────────────

if [[ -f "$CACHE_STATUS" ]]; then
  cache_age=$(( $(date +%s) - $(_mtime "$CACHE_STATUS") ))
  if (( cache_age < CACHE_TTL )); then
    _claudii_log debug "Cache hit (${cache_age}s < TTL ${CACHE_TTL}s)"
    if ! $quiet; then
      while IFS='=' read -r model state; do
        case "$state" in
          down)     echo -e "${RED}✗ ${model} down${NC}" >&2 ;;
          degraded) echo -e "${YELLOW}~ ${model} degraded${NC}" >&2 ;;
        esac
      done < "$CACHE_STATUS"
    fi
    grep -q "=down\|=degraded" "$CACHE_STATUS" 2>/dev/null && exit 1
    exit 0
  fi
  _claudii_log debug "Cache stale (${cache_age}s > TTL ${CACHE_TTL}s)"
fi

# ── Helper: write cache + output + exit ──────────────────────────────────────

_write_all_ok() {
  printf '%s=ok\n' "${MODELS[@]}" > "$_tmp_status" && mv -f "$_tmp_status" "$CACHE_STATUS"
  printf '{"incidents":[]}\n' > "$_tmp_incidents" && mv -f "$_tmp_incidents" "$CACHE_INCIDENTS"
  _claudii_log info "Status: all ok"
  exit 0
}

_write_incidents() {
  local service_level="$1" down_models="$2" incident_detail="$3"

  # If no specific model named in incident → all models affected
  local no_model_named=true
  for m in "${MODELS[@]}"; do
    echo "$down_models" | grep -q " $m " && no_model_named=false && break
  done

  {
    for model in "${MODELS[@]}"; do
      if $no_model_named || echo "$down_models" | grep -q " $model "; then
        printf '%s=%s\n' "$model" "$service_level"
      else
        printf '%s=ok\n' "$model"
      fi
    done
  } > "$_tmp_status" && mv -f "$_tmp_status" "$CACHE_STATUS"

  local summary="" any_issue=false
  for m in "${MODELS[@]}"; do
    ms=$(grep "^${m}=" "$CACHE_STATUS" | cut -d= -f2 || true)
    summary+=" ${m}=${ms}"
    local label; label="$(echo "${m:0:1}" | tr '[:lower:]' '[:upper:]')${m:1}"
    case "$ms" in
      down)     $quiet || echo -e "${RED}✗ ${label} down${NC}" >&2;     any_issue=true ;;
      degraded) $quiet || echo -e "${YELLOW}~ ${label} degraded${NC}" >&2; any_issue=true ;;
    esac
  done
  _claudii_log info "Status:${summary}"

  if $any_issue && [[ -n "$incident_detail" ]]; then
    $quiet || echo -e "${YELLOW}  ↳ ${incident_detail}${NC}" >&2
  fi

  $any_issue && exit 1 || exit 0
}

# ── Step 1: unresolved.json → active incidents ────────────────────────────────

_claudii_log info "Fetching $UNRESOLVED_URL"
unresolved=$(curl -sf --max-time 5 --connect-timeout 3 "$UNRESOLVED_URL" 2>/dev/null) || true

if [[ -n "$unresolved" ]]; then
  printf '%s\n' "$unresolved" > "$_tmp_incidents" && mv -f "$_tmp_incidents" "$CACHE_INCIDENTS"
  incident_count=$(echo "$unresolved" | jq -r '.incidents | length' 2>/dev/null || echo "")
  [[ "$incident_count" =~ ^[0-9]+$ ]] || incident_count=""

  if [[ "$incident_count" == "0" ]]; then
    _claudii_log info "No active incidents"
    _write_all_ok
  fi

  if [[ -n "$incident_count" ]]; then
    _claudii_log info "$incident_count active incident(s)"

    # Impact → service level (most severe wins)
    service_level=$(echo "$unresolved" | jq -r '
      .incidents | map(.impact) |
      if any(. == "critical" or . == "major") then "down"
      else "degraded"
      end
    ' 2>/dev/null || echo "degraded")

    # Collect all incident names for model matching
    incident_names=$(echo "$unresolved" | jq -r '.incidents[].name' 2>/dev/null || echo "")
    incident_detail=$(echo "$unresolved" | jq -r '.incidents[0].name' 2>/dev/null || echo "")

    down_models=" "
    for m in "${MODELS[@]}"; do
      echo "$incident_names" | grep -qiE "(^|[^a-zA-Z])${m}([^a-zA-Z]|$)" && down_models="$down_models$m "
    done

    _claudii_log debug "Incidents: $incident_names → service=$service_level down=[${down_models}]"
    _write_incidents "$service_level" "$down_models" "$incident_detail"
  fi

  # jq parse failed — fall through to RSS
  _claudii_log warn "unresolved.json parse failed — falling back to RSS"
fi

# ── Step 2: RSS fallback (unresolved.json unreachable or unparseable) ─────────

_claudii_log warn "unresolved.json unavailable — trying RSS fallback"
$quiet || echo -e "${YELLOW}claudii: Primary status API unreachable, trying RSS${NC}" >&2

rss=$(curl -sf --max-time 5 --connect-timeout 3 "$RSS_URL" 2>/dev/null) || true

if [[ -z "$rss" ]]; then
  $quiet || echo -e "${YELLOW}claudii: Status API unreachable${NC}" >&2
  _claudii_log warn "All status sources unreachable — writing all-ok fallback"
  { printf '%s=ok\n' "${MODELS[@]}"; echo "_api=unreachable"; } > "$_tmp_status" && mv -f "$_tmp_status" "$CACHE_STATUS"
  exit 0
fi

incident_detail=""
down_models=" "
rss_has_incident=false

while IFS= read -r item; do
  echo "$item" | grep -qo '&lt;strong&gt;Resolved&lt;/strong&gt;' && continue
  echo "$item" | grep -qi '<title>[^<]*Resolved[^<]*</title>' && continue
  title=$(echo "$item" | sed -n 's/.*<title>\(.*\)<\/title>.*/\1/p')
  [[ -z "$title" ]] && continue
  rss_has_incident=true
  [[ -z "$incident_detail" ]] && incident_detail="$title"
  for m in "${MODELS[@]}"; do
    echo "$title" | grep -qiE "(^|[^a-zA-Z])${m}([^a-zA-Z]|$)" && down_models="$down_models$m "
  done
  _claudii_log debug "RSS item: '$title' → down: [${down_models}]"
done < <(
  echo "$rss" | sed -n '/<item>/,/<\/item>/p' | \
    awk '/<item>/{buf=""} {buf=buf $0 " "} /<\/item>/{print buf}'
)

if ! $rss_has_incident; then
  _claudii_log info "RSS: no unresolved incidents"
  _write_all_ok
fi

_write_incidents "degraded" "$down_models" "$incident_detail"
