#!/bin/bash
# claudii-otel — fold Claude Code's local OTLP/JSON export into the perf cache.
#
# The OTEL path is optional and local-only. bin/claudii-otel-receiver writes the
# raw OTLP batches Claude Code emits to $CACHE/otel/{traces,logs}.jsonl, and
# `claudii-otel build` folds them into the SAME .latency shape lib/cmd/perf.sh
# already renders from transcripts — plus the exact fields the transcript
# estimate can't provide (duration_ms, ttft_ms, api_error status codes). The
# only claudii<->OTEL coupling is the local JSONL file; nothing here touches the
# network.
#
# Optional fan-out (perf.otel.forward): the receiver tees each batch verbatim to
# an internal collector gateway. claudii itself never reads the gateway — it
# only reads the local file; the forward is purely for central retention.
#
# Usage:
#   claudii-otel build [--days N]   # emit {source,latency,errors} JSON on stdout
#   claudii-otel receiver [args]    # exec the local OTLP receiver (foreground)
#   claudii-otel doctor             # check receiver wiring + data freshness
#   claudii-otel cache-dir          # print the OTEL data directory

set -uo pipefail
export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
command -v jq >/dev/null 2>&1 || { printf 'claudii-otel: jq not found — install jq\n' >&2; exit 1; }

CACHE_BASE="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
OTEL_DIR="$CACHE_BASE/otel"
INSIGHTS_DIR="$CACHE_BASE/insights"
JQ_PROGRAM="$CLAUDII_HOME/lib/otel.jq"
RECEIVER="$CLAUDII_HOME/bin/claudii-otel-receiver"

_mtime() { stat -f%m "$1" 2>/dev/null || stat -c%Y "$1" 2>/dev/null || echo 0; }

# floor = today - (days-1) in UTC; BSD date first, GNU fallback (matches perf).
_floor_day() {
  local days="$1"
  date -u -v-"$(( days - 1 ))"d +%Y-%m-%d 2>/dev/null \
    || date -u -d "$(( days - 1 )) days ago" +%Y-%m-%d 2>/dev/null \
    || printf ''
}

# {sessionId: repo} from the insights caches — OTEL events carry session.id but
# no cwd, so the repo is resolved here (same source perf's transcript path uses).
_repomap() {
  shopt -s nullglob
  local files=("$INSIGHTS_DIR"/*.json)
  shopt -u nullglob
  if (( ${#files[@]} == 0 )); then printf '{}'; return; fi
  jq -n 'reduce inputs as $s ({};
           if ($s.sessionId // null) != null and ($s.project.repo // "") != ""
           then .[$s.sessionId] = $s.project.repo else . end)' "${files[@]}" 2>/dev/null \
    || printf '{}'
}

_cmd_build() {
  local days=30
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days) shift; days="${1:-30}" ;;
      *) printf 'build: unknown option: %s\n' "$1" >&2; exit 1 ;;
    esac
    shift
  done
  if ! [[ "$days" =~ ^[0-9]+$ ]] || [[ "$days" -lt 1 ]]; then
    printf 'build: --days must be a positive integer (got: %s)\n' "$days" >&2; exit 1
  fi

  local present=() f
  for f in "$OTEL_DIR/traces.jsonl" "$OTEL_DIR/logs.jsonl"; do
    [[ -s "$f" ]] && present+=("$f")
  done
  if (( ${#present[@]} == 0 )); then
    printf '{"source":"otel","latency":[],"errors":[]}\n'; return 0
  fi

  local floor; floor=$(_floor_day "$days")
  local repomap; repomap=$(_repomap)
  # -nR: read raw lines so one half-written batch (live-appended JSONL) skips
  # itself via fromjson? instead of aborting the whole stream.
  jq -nR --argjson repomap "$repomap" --arg floor "$floor" \
    -f "$JQ_PROGRAM" "${present[@]}"
}

_cmd_receiver() {
  [[ -f "$RECEIVER" ]] || { printf 'claudii-otel: receiver not found: %s\n' "$RECEIVER" >&2; exit 1; }
  command -v python3 >/dev/null 2>&1 || { printf 'claudii-otel: python3 required for the receiver\n' >&2; exit 1; }
  exec python3 "$RECEIVER" "$@"
}

_cmd_doctor() {
  printf 'claudii-otel doctor\n'
  if command -v python3 >/dev/null 2>&1; then
    printf '  python3      %s\n' "$(command -v python3)"
  else
    printf '  python3      MISSING — the receiver needs it\n'
  fi
  printf '  otel dir     %s\n' "$OTEL_DIR"
  local now t l tc lc age
  now=$(date +%s)
  for f in traces logs; do
    local path="$OTEL_DIR/$f.jsonl"
    if [[ -s "$path" ]]; then
      local lines; lines=$(wc -l < "$path" 2>/dev/null | tr -d ' ')
      age=$(( now - $(_mtime "$path") ))
      printf '  %-12s %s batches · last write %ds ago\n' "$f.jsonl" "$lines" "$age"
    else
      printf '  %-12s (none — receiver not running, or no session yet)\n' "$f.jsonl"
    fi
  done
  local n; n=$(_cmd_build --days 36500 2>/dev/null | jq '.latency | length' 2>/dev/null || echo '?')
  printf '  samples      %s response(s) parsed\n' "$n"
  if [[ -r "$CACHE_BASE/otel.env" ]]; then
    printf '  env wiring   %s (telemetry exported to the receiver)\n' "$CACHE_BASE/otel.env"
  else
    printf '  env wiring   off — run: claudii-otel setup\n'
  fi
  local fwd; fwd=$("$CLAUDII_HOME/bin/claudii" config get perf.otel.forward 2>/dev/null)
  if [[ -n "$fwd" ]]; then
    printf '  forward      %s (batches mirrored to the gateway)\n' "$fwd"
  else
    printf '  forward      off (local-only; set perf.otel.forward to fan out)\n'
  fi
}

# Enable the OTEL path: flip the config flag, write the shell env file the plugin
# sources (fork-free), and generate a launchd plist for a persistent receiver.
# The plist is written to the cache (not auto-installed) — the user loads it, so
# nothing touches ~/Library/LaunchAgents without consent.
_cmd_setup() {
  local cli="$CLAUDII_HOME/bin/claudii"
  local endpoint beta forward
  endpoint=$("$cli" config get perf.otel.endpoint 2>/dev/null); [[ -z "$endpoint" ]] && endpoint="http://127.0.0.1:4318"
  beta=$("$cli" config get perf.otel.beta_traces 2>/dev/null)
  forward=$("$cli" config get perf.otel.forward 2>/dev/null)
  "$cli" config set perf.otel.enabled true >/dev/null 2>&1

  mkdir -p "$OTEL_DIR"
  local envf="$CACHE_BASE/otel.env"
  {
    printf '%s\n' '# generated by `claudii-otel setup` — sourced by the claudii plugin.'
    printf '%s\n' '# Points Claude Code telemetry at the local receiver. Undo: claudii-otel off.'
    printf '%s\n' 'export CLAUDE_CODE_ENABLE_TELEMETRY=1'
    printf '%s\n' 'export OTEL_LOGS_EXPORTER=otlp'
    printf '%s\n' 'export OTEL_TRACES_EXPORTER=otlp'
    printf '%s\n' 'export OTEL_METRICS_EXPORTER=none'
    printf '%s\n' 'export OTEL_EXPORTER_OTLP_PROTOCOL=http/json'
    printf 'export OTEL_EXPORTER_OTLP_ENDPOINT=%s\n' "$endpoint"
    [[ "$beta" == "true" ]] && printf '%s\n' 'export CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1'
    [[ -n "$forward" ]] && printf 'export CLAUDII_OTEL_FORWARD=%s\n' "$forward"
  } > "$envf"

  local py; py=$(command -v python3 || echo /usr/bin/python3)
  local py_dir; py_dir=$(dirname "$py")
  # Invoke the receiver script directly (arg0), not `python3 <script>`, so macOS
  # Login Items / "Allow in the Background" shows it as "claudii-otel-receiver"
  # instead of "python3". The env-shebang then needs Homebrew on PATH (launchd's
  # default PATH lacks it) — set in EnvironmentVariables below. Keep it +x.
  chmod +x "$RECEIVER" 2>/dev/null || true
  local plist="$OTEL_DIR/com.claudii.otel-receiver.plist"
  # The receiver process needs CLAUDII_OTEL_FORWARD too (it does the teeing), so
  # bake it into the plist env when configured.
  local fwd_xml=""
  [[ -n "$forward" ]] && printf -v fwd_xml '\n    <key>CLAUDII_OTEL_FORWARD</key><string>%s</string>' "$forward"
  cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.claudii.otel-receiver</string>
  <key>ProgramArguments</key>
  <array>
    <string>$RECEIVER</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>$py_dir:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>CLAUDII_OTEL_DIR</key><string>$OTEL_DIR</string>$fwd_xml
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardErrorPath</key><string>$OTEL_DIR/receiver.log</string>
  <key>StandardOutPath</key><string>$OTEL_DIR/receiver.log</string>
</dict>
</plist>
PLIST

  printf 'claudii-otel: OTEL source enabled (perf.otel.enabled=true)\n'
  printf '  env written:   %s\n' "$envf"
  printf '  plist written: %s\n' "$plist"
  [[ -n "$forward" ]] && printf '  forwarding to: %s\n' "$forward"
  printf '\n'
  printf 'Next steps:\n'
  printf '  1. Start the receiver (persistent, restarts on boot):\n'
  printf '       cp "%s" ~/Library/LaunchAgents/\n' "$plist"
  printf '       launchctl load ~/Library/LaunchAgents/com.claudii.otel-receiver.plist\n'
  printf '  2. Reload your shell so the telemetry env is exported:  exec zsh\n'
  printf '  3. Run a Claude session, then:  claudii perf\n'
  printf '\nNo launchd? Run the receiver yourself:  claudii-otel receiver\n'
}

# Disable the OTEL path: flip the flag back and remove the shell env file. perf
# reverts to the transcript estimate. The launchd job is left for the user to
# unload (we never loaded it).
_cmd_off() {
  local cli="$CLAUDII_HOME/bin/claudii"
  "$cli" config set perf.otel.enabled false >/dev/null 2>&1
  rm -f "$CACHE_BASE/otel.env"
  printf 'claudii-otel: OTEL source disabled (perf reverts to the transcript estimate)\n'
  printf '  removed: %s\n' "$CACHE_BASE/otel.env"
  printf 'Stop the receiver:\n'
  printf '  launchctl unload ~/Library/LaunchAgents/com.claudii.otel-receiver.plist\n'
}

cmd="${1:-build}"; shift || true
case "$cmd" in
  build)     _cmd_build "$@" ;;
  receiver)  _cmd_receiver "$@" ;;
  setup)     _cmd_setup "$@" ;;
  off)       _cmd_off "$@" ;;
  doctor)    _cmd_doctor "$@" ;;
  cache-dir) printf '%s\n' "$OTEL_DIR" ;;
  -h|--help|help)
    cat <<'EOF'
claudii-otel — fold local OTLP/JSON telemetry into the perf cache

Usage:
  claudii-otel setup              enable the OTEL source (config + env + plist)
  claudii-otel off                disable it (perf reverts to transcript)
  claudii-otel build [--days N]   emit {source,latency,errors} JSON on stdout
  claudii-otel receiver [args]    exec the local OTLP receiver (foreground)
  claudii-otel doctor             check receiver wiring + data freshness
  claudii-otel cache-dir          print the OTEL data directory

Fan-out (optional): set perf.otel.forward to an internal collector URL and the
receiver mirrors every batch there (best-effort) for central retention.
EOF
    ;;
  *) printf 'claudii-otel: unknown command: %s\n' "$cmd" >&2; exit 1 ;;
esac
