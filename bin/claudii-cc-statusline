      "INCIDENT REPORT: THIS MOMENT"
      "WHO IS RUNNING PRODUCTION"
      "IT'S TOO LATE FOR REGRETS"
      "THE PR CAN WAIT FOREVER"
      "SHUT DOWN. NOW. PLEASE."
      "LOG OFF OR WE CALL SOMEONE"
      "BIOS UPDATE: YOUR BODY"
      "CORE HOURS: 9AM. SLEEP FIRST."
      "WE FOUND YOUR REGRESSION"
      "IT WAS YOU. IT WAS ALWAYS YOU."
      "THE ALGORITHM CANNOT SAVE YOU"
      "SOS FROM YOUR PILLOW"
      "PRODUCTION INCIDENT: YOUR BODY"
      "NO MORE FEATURES TONIGHT"
      "YOU ARE NOT REQUIRED TO SOLVE THIS"
      "THE INTERNET WILL STILL BE HERE"
      "NOTHING SHIPS TONIGHT"
      "YOUR COMMIT MESSAGE WILL BE GIBBERISH"
      "ROLLBACK: YOUR ENTIRE EVENING"
      "THIS IS AN OUTAGE. YOU ARE THE OUTAGE."
    )

    # Build combined pool based on mode
    _vibe_msgs=("${_vibe_msgs_1[@]}")
    if (( _vibe_mode >= 2 )); then _vibe_msgs+=("${_vibe_msgs_2[@]}"); fi
    if (( _vibe_mode >= 3 )); then _vibe_msgs+=("${_vibe_msgs_3[@]}"); fi
    if (( _vibe_mode >= 4 )); then _vibe_msgs+=("${_vibe_msgs_4[@]}"); fi

    # Message stable for 25s (time-based); color rolls with frame
    _vm_color="${_vibe_palette[$(( _frame % ${#_vibe_palette[@]} ))]}"
    _vm_text="${_vibe_msgs[$(( (_ts / 25) % ${#_vibe_msgs[@]} ))]}"

    # Bookend glyphs ŌĆö deterministic frame offsets, no jumps
    _vg_idx2=$(( (_vg_idx + 1) % ${#_vibe_glyphs[@]} ))
    _ck_glyph2="${_vibe_glyphs[$_vg_idx2]}"
    _vg_idx3=$(( (_vg_idx + 2) % ${#_vibe_glyphs[@]} ))
    _ck_glyph3="${_vibe_glyphs[$_vg_idx3]}"

    # Per-render effects ŌĆö alternate each frame for pulse/strobe
    # Mode 3: shame text flips REVERSE on/off each render (inverted Ōåö normal)
    # Mode 4: blink alternates slowŌåörapid for strobe effect
    _seg_rev=""
    (( _vibe_mode >= 3 && _frame % 2 == 1 )) && _seg_rev="${REVERSE}"
    _seg_fb="${BLINK}"
    (( _vibe_mode >= 4 && _frame % 2 == 1 )) && _seg_fb="${BLINK2}"

    case $_vibe_mode in
      1)
        _seg_clock="${BLINK}${_ck_glyph}${RST} ${_vibe_rainbow} ${BLINK}${BOLD}${_vm_color}${_vm_text}${RST}"
        ;;
      2)
        _seg_clock="${BLINK}${_ck_glyph}${RST} ${_vibe_rainbow} ${BLINK}${_ck_glyph2}${RST} ${BLINK}${BOLD}${UNDERLINE}${_vm_color}${_vm_text}${RST}"
        ;;
      3)
        _seg_clock="${BLINK}${_ck_glyph}${RST}${BLINK}${_ck_glyph2}${RST} ${_vibe_rainbow} ${BLINK}${_ck_glyph3}${RST}${BLINK}${_ck_glyph}${RST} ${BLINK}${BOLD}${_seg_rev}${_vm_color}${_vm_text}${RST}"
        ;;
      4)
        _seg_clock="${_seg_fb}${_ck_glyph}${_ck_glyph2}${_ck_glyph3}${RST} ${_vibe_rainbow} ${_seg_fb}${_ck_glyph3}${_ck_glyph2}${_ck_glyph}${RST} ${_seg_fb}${BOLD}${REVERSE}${UNDERLINE}${_vm_color}${_vm_text}${RST}"
        ;;
    esac
  else
    # Morning motivation: 07:00-15:59 ŌĆö plain, no blink, no rainbow
    if (( _now_min >= 420 && _now_min < 960 )); then
      _mot_msgs=(
        "let's go"
        "you've got this"
        "make it count"
        "clean slate"
        "ship something"
        "build cool things"
        "new day, fresh diff"
        "focus time"
        "the bugs fear you"
        "ideas into code"
        "start strong"
        "make it happen"
        "one thing at a time"
        "stay sharp"
        "coffee ŌåÆ code"
        "fresh eyes"
        "do the thing"
        "ready"
        "in the zone"
        "solve something hard"
        "today's the day"
        "good energy"
        "build it"
        "clear head, clean code"
        "momentum"
        "deep work time"
        "ship it"
        "keep moving"
        "make today count"
        "you know what to do"
      )
      _mot_text="${_mot_msgs[$(( RANDOM % ${#_mot_msgs[@]} ))]}"
      _seg_clock="${DIM}Ō£” ${_hhmm}${RST}  ${CYAN}${_mot_text}${RST}"
    else
      _seg_clock="${_ck_color}${_ck_glyph} ${_hhmm}${_ck_suffix}${RST}"
    fi
  fi
fi

# Worktree: name + branch. Falls back to workspace.git_worktree for plain git worktrees.
_seg_worktree=""
_wt_name="${worktree_name:-$workspace_git_worktree}"
if [[ -n "$_wt_name" ]]; then
  _seg_worktree="${DIM}${_wt_name}${RST}"
  [[ -n "$worktree_name" && -n "$worktree_branch" ]] && _seg_worktree+=" ${DIM}ŌÄć ${worktree_branch}${RST}"
fi

# Agent: DIM @name ŌĆö uses agent.name (CC sub-agents) with session_name as fallback
# (claudii_agent_launch passes --name <alias> so session_name carries the alias)
_seg_agent=""
_agent_display="${agent_name:-$session_name}"
if [[ -n "$_agent_display" ]]; then
  _seg_agent="${DIM}@${RST}${ACCENT}${_agent_display}${RST}"
fi

# Session name: custom name set via /rename or --name (only when set)
_seg_session_name=""
if [[ -n "$session_name" ]]; then
  _seg_session_name="${DIM}${session_name}${RST}"
fi

# API duration: time actually spent waiting for Claude (vs. total wall-clock)
_seg_api_dur=""
if [[ -n "$api_duration_ms" && "$api_duration_ms" != "null" ]]; then
  _dur "$api_duration_ms"; [[ -n "$_dur_result" ]] && _seg_api_dur="${DIM}api:${_dur_result}${RST}"
fi

# Session deltas: only the change since session start (current rate is already on line 1).
# In "remaining" mode the sign flips: usage +12% becomes remaining ŌłÆ12% (same magnitude,
# opposite direction). Color logic still keys off the underlying usage delta.
_seg_delta5h=""
if [[ -n "$_rate_5h_start" && "$_rate_5h_start" != "null" && -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _d5=$(( ${rate_5h%.*} - ${_rate_5h_start%.*} ))
  _d5_disp=$_d5
  [[ "$_rate_display" == "remaining" ]] && _d5_disp=$(( -_d5 ))
  if (( _d5 > 0 )); then
    _rlc "$rate_5h"; _seg_delta5h="${DIM}╬ö5h:${RST}${_CLR}$( (( _d5_disp > 0 )) && echo "+")${_d5_disp}%${RST}"
  elif (( _d5 < 0 )); then
    _seg_delta5h="${DIM}╬ö5h:${RST}${GREEN}$( (( _d5_disp > 0 )) && echo "+")${_d5_disp}%${RST}"
  fi
fi

_seg_delta7d=""
if [[ -n "$_rate_7d_start" && "$_rate_7d_start" != "null" && -n "$rate_7d" && "$rate_7d" != "null" ]]; then
  _d7=$(( ${rate_7d%.*} - ${_rate_7d_start%.*} ))
  _d7_disp=$_d7
  [[ "$_rate_display" == "remaining" ]] && _d7_disp=$(( -_d7 ))
  if (( _d7 > 0 )); then
    _rlc "$rate_7d"; _seg_delta7d="${DIM}╬ö7d:${RST}${_CLR}$( (( _d7_disp > 0 )) && echo "+")${_d7_disp}%${RST}"
  elif (( _d7 < 0 )); then
    _seg_delta7d="${DIM}╬ö7d:${RST}${GREEN}$( (( _d7_disp > 0 )) && echo "+")${_d7_disp}%${RST}"
  fi
fi

# Cache writes: tokens written INTO cache this session (costs extra vs cache reads)
# Distinct from ŌÜĪcache-pct (hit ratio) ŌĆö this shows write volume
_seg_cache_create=""
if [[ -n "$cache_create" && "$cache_create" != "null" && "$cache_create" != "0" ]]; then
  _tok "$cache_create"; [[ -n "$_tok_result" ]] && _seg_cache_create="${DIM}Ō£Ä${_tok_result}${RST}"
fi

# Working directory: basename of project_dir (with worktree.original_cwd as fallback for --worktree sessions)
_seg_dir=""
_dir_path="${worktree_original_cwd:-${workspace_project_dir:-$cwd}}"
if [[ -n "$_dir_path" && "$_dir_path" != "null" ]]; then
  _dir_name="${_dir_path##*/}"
  [[ -n "$_dir_name" ]] && _seg_dir="${DIM}Ōīé${RST} ${YELLOW}${_dir_name}${RST}"
fi

# Terminal width ŌĆö used by ruler segment to fill remaining space
# COLUMNS (exported by parent shell) is more reliable than tput cols in piped context
_term_cols=""
[[ -n "$COLUMNS" ]] && (( COLUMNS > 20 )) && _term_cols="$COLUMNS"
[[ -z "$_term_cols" ]] && _term_cols=$(tput cols 2>/dev/null)
# If width unknown or implausible: set to 0 ŌĆö ruler will silently skip
(( _term_cols > 20 )) || _term_cols=0

