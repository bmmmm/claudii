    )
    _vibe_msgs_4=(
      "ARE YOU OK???"
      "I AM CALLING YOUR MOM"
      "THIS IS NOT A TEST"
      "REALITY HAS LEFT THE CHAT"
      "YOU ARE THE BUG"
      "THE LIGHT IS FAKE"
      "WHAT IS A COMPUTER"
      "SEND HELP. ALSO SLEEP."
