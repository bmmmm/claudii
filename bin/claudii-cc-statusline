#!/bin/bash
# claudii-sessionline — Claude Code statusLine handler.
# Reads session JSON from stdin, prints a configurable multi-line status.

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
# shellcheck source=lib/log.sh
source "$CLAUDII_HOME/lib/log.sh"
# shellcheck source=lib/vibemap.sh
source "$CLAUDII_HOME/lib/vibemap.sh"
# shellcheck source=lib/timefmt.sh
source "$CLAUDII_HOME/lib/timefmt.sh"
# shellcheck source=lib/helpers.sh
source "$CLAUDII_HOME/lib/helpers.sh"

command -v jq >/dev/null 2>&1 || { printf 'claudii-sessionline: jq not found — install jq\n' >&2; exit 1; }

read -r json

_cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
[[ -d "$_cache_dir" ]] || { mkdir -p "$_cache_dir"; chmod 0700 "$_cache_dir"; }
# Default-deny: every file this script creates (session-*, history-*, *.tmp.$$)
# inherits 0600 instead of 0644 from umask 022. Cache dir is already 0700, so
# this is defense-in-depth for the CLAUDII_CACHE_DIR override case.
umask 077

# Config (statusline.* + vibemap.*) — single jq call.
# Separators: US (0x1F) between fields, RS (0x1E) between layout lines.
_config_file="${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json"
_from_cfg=""; _sc_models_cfg=""; _cfg_omlx=""; _rate_display=""; _cfg_bedtime=""
_cfg_vibemap_enabled=""; _cfg_vibemap_path=""
_cfg_shame="true"; _cfg_motivation="true"; _cfg_rainbow="true"; _cfg_insomnii="auto"
_cfg_status_ttl=""
if [[ -f "$_config_file" ]]; then
  IFS=$'\x1f' read -r _from_cfg _sc_models_cfg _cfg_omlx _rate_display _cfg_bedtime \
    _cfg_vibemap_enabled _cfg_vibemap_path _cfg_shame _cfg_motivation _cfg_rainbow _cfg_insomnii \
    _cfg_status_ttl < <(
    jq -r '[
      (if .statusline.lines then (.statusline.lines | map(join(",")) | join("\u001e")) else "" end),
      (.statusline.models // ""),
      (.statusline.omlx_active_path // ""),
      (.statusline.rate_display // ""),
      (.statusline.bedtime // ""),
      (.vibemap.enabled // false | tostring),
      (.vibemap.path // ""),
      (if .statusline.shame == false then "false" else "true" end),
      (if .statusline.motivation == false then "false" else "true" end),
      (if .statusline.rainbow == false then "false" else "true" end),
      (.statusline.insomnii // "auto"),
      (.status.cache_ttl // "" | tostring)
    ] | join("\u001f")' "$_config_file" 2>/dev/null
  )
  _from_cfg="${_from_cfg//$'\x1e'/$'\n'}"
fi
[[ "$_rate_display" != "remaining" ]] && _rate_display="used"
_rate_mark=""; [[ "$_rate_display" == "remaining" ]] && _rate_mark="↓"
[[ "$_cfg_insomnii" != "off" && "$_cfg_insomnii" != "on" ]] && _cfg_insomnii="auto"
# Re-apply opt-out defaults AFTER the read: a failing jq (corrupt config.json)
# leaves read with no input, which blanks every listed var — including the
# pre-seeded "true" defaults. Only an explicit "false" opts out.
[[ "$_cfg_shame"      != "false" ]] && _cfg_shame="true"
[[ "$_cfg_motivation" != "false" ]] && _cfg_motivation="true"
[[ "$_cfg_rainbow"    != "false" ]] && _cfg_rainbow="true"

# Clock segment delegation
_use_insomnii=0
[[ "$_cfg_insomnii" != "off" ]] && command -v cc-insomnii >/dev/null 2>&1 && _use_insomnii=1

# Skip clock when wrapped by cc-insomnii (it already rendered its line).
# The ps fork runs only when delegation is possible at all (_use_insomnii) —
# the flag's sole consumer is the clock segment, which is gated on it too.
_wrapped_by_insomnii=0
if (( _use_insomnii )); then
  _parent_cmd=$(ps -o comm= -p "${PPID:-0}" 2>/dev/null | tr -d ' ')
  [[ "$_parent_cmd" == *cc-insomnii* ]] && _wrapped_by_insomnii=1
fi

# Session JSON → variables. One jq call, US (0x1F) delimited.
_D=$'\x1f'
IFS="$_D" read -r model ctx_pct cost input_tok output_tok rate_5h rate_7d \
  duration_ms lines_add lines_rm ctx_size session_id reset_5h reset_7d \
  cache_read cache_create worktree_name agent_name model_id cwd \
  session_name worktree_branch api_duration_ms exceeds_200k \
  effort_level thinking_enabled workspace_git_worktree \
  workspace_project_dir worktree_original_cwd \
  repo_host repo_owner repo_name repo_pr <<< "$(
  jq -r '[
    (.model.display_name // ""),
    (.context_window.used_percentage // "" | tostring),
    (.cost.total_cost_usd // "" | tostring),
    (.context_window.total_input_tokens // "" | tostring),
    (.context_window.total_output_tokens // "" | tostring),
    (.rate_limits.five_hour.used_percentage // "" | tostring),
    (.rate_limits.seven_day.used_percentage // "" | tostring),
    (.cost.total_duration_ms // "" | tostring),
    (.cost.total_lines_added // "" | tostring),
    (.cost.total_lines_removed // "" | tostring),
    (.context_window.context_window_size // "" | tostring),
    (.session_id // ""),
    (.rate_limits.five_hour.resets_at // "" | tostring),
    (.rate_limits.seven_day.resets_at // "" | tostring),
    (.context_window.current_usage.cache_read_input_tokens // "" | tostring),
    (.context_window.current_usage.cache_creation_input_tokens // "" | tostring),
    (.worktree.name // ""),
    (.agent.name // ""),
    (.model.id // ""),
    (.workspace.current_dir // .cwd // ""),
    (.session_name // ""),
    (.worktree.branch // ""),
    (.cost.total_api_duration_ms // "" | tostring),
    (.exceeds_200k_tokens // false | tostring),
    (.effort.level // ""),
    (.thinking.enabled // false | tostring),
    (.workspace.git_worktree // ""),
    (.workspace.project_dir // ""),
    (.worktree.original_cwd // ""),
    (.workspace.repo.host // ""),
    (.workspace.repo.owner // ""),
    (.workspace.repo.name // ""),
    (.workspace.repo.pr_number // "" | tostring)
  ] | join("\u001f")' <<< "$json" 2>/dev/null || printf "${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}"
)"

# Helper: non-empty, non-"null", non-"0".
_isset() { [[ -n "$1" && "$1" != "null" && "$1" != "0" ]]; }

_cache_pct=""
if _isset "$cache_read"; then
  _cr=${cache_read%.*}
  _ci=${input_tok%.*}
  if (( _ci + _cr > 0 )); then _cache_pct=$(( _cr * 100 / (_cr + _ci) )); fi
fi

# Session-cumulative in+out tokens — persisted so the token-first dashboard and
# `claudii se` (which read this cache, not the live JSON) can show throughput.
_tok_total=0
[[ "${input_tok%.*}"  =~ ^[0-9]+$ ]] && _tok_total=$(( _tok_total + ${input_tok%.*} ))
[[ "${output_tok%.*}" =~ ^[0-9]+$ ]] && _tok_total=$(( _tok_total + ${output_tok%.*} ))

# Existing per-session cache → 7d/5h baselines + previous duration.
_sid="${session_id:+${session_id:0:8}}"
_session_file="$_cache_dir/session-${_sid:-unknown}"
_existing_cache=""
[[ -f "$_session_file" ]] && { _existing_cache=$(<"$_session_file"); } 2>/dev/null
_ec_nl=$'\n'"$_existing_cache"

# Read cached value or fall back to live current. Writes to _CG (no subshell —
# the call sites used to wrap this in $(...), one fork() each on every render).
_cache_get() {
  local key=$1 fallback=$2 v
  if [[ "$_ec_nl" == *$'\n'"$key"=* ]]; then
    v="${_existing_cache#*$key=}"
    v="${v%%$'\n'*}"
    [[ -n "$v" ]] && { _CG="$v"; return; }
  fi
  _CG="$fallback"
}
_rate_7d_start=""; [[ -n "$rate_7d" && "$rate_7d" != "null" ]] && { _cache_get rate_7d_start "$rate_7d"; _rate_7d_start="$_CG"; }
_rate_5h_start=""; [[ -n "$rate_5h" && "$rate_5h" != "null" ]] && { _cache_get rate_5h_start "$rate_5h"; _rate_5h_start="$_CG"; }
_cache_get last_duration_ms ""; _last_duration_ms="$_CG"

# Compaction counter — no compaction signal exists in the statusline JSON, so
# detect the footprint: context usage collapsing between renders of the SAME
# session (>= 30-point drop from >= 50%). Survives in the cache as compactions=.
_cache_get compactions "0"; _compactions="$_CG"
[[ "$_compactions" =~ ^[0-9]+$ ]] || _compactions=0
_cache_get last_ctx_pct ""; _last_ctx_pct="$_CG"
if [[ "$ctx_pct" != "null" && -n "$ctx_pct" && "$_last_ctx_pct" =~ ^[0-9]+$ ]]; then
  _ctx_now=${ctx_pct%.*}
  if [[ "$_ctx_now" =~ ^[0-9]+$ ]] && (( _last_ctx_pct >= 50 && _last_ctx_pct - _ctx_now >= 30 )); then
    (( ++_compactions ))
  fi
fi
_last_ctx_store=""
[[ -n "$ctx_pct" && "$ctx_pct" != "null" ]] && _last_ctx_store=${ctx_pct%.*}

# Burn-rate ETA + pace tri-state (cached for dashboard, not rendered here).
# Both derive from the same dur/rate inputs, so one awk emits both (US-joined)
# instead of two forks. US is passed as a var — \u escapes are not portable in
# BSD awk's printf (macOS CI), so build the byte in bash and hand it over.
_burn_eta=""
_pace_state=""
if _isset "$duration_ms"; then
  _rate_5h_int=${rate_5h%.*}
  _session_min_int=$(( ${duration_ms%.*} / 60000 ))
  if _isset "$rate_5h" && (( _session_min_int >= 3 && _rate_5h_int > 0 )); then
    # Pace: actual rate_5h vs linear burn (session_min / 300 * 100, hits 100% at
    # the 5h mark); ±15% tolerance band → ahead / on_pace / behind.
    _bp=$(LC_ALL=C awk -v dur="$duration_ms" -v rat="$rate_5h" -v us=$'\x1f' 'BEGIN {
      m = dur / 60000; r = rat + 0
      eta = (r > 0) ? int((100 - r) / (r / m) + 0.5) : 0
      linear = m / 300 * 100
      pace = ""
      if (linear > 0) {
        if      (r < linear * 0.85) pace = "ahead"
        else if (r > linear * 1.15) pace = "behind"
        else                        pace = "on_pace"
      }
      printf "%d%s%s", eta, us, pace
    }')
    _burn_eta="${_bp%%$'\x1f'*}"
    _pace_state="${_bp#*$'\x1f'}"
  fi
fi

# Per-session cache (atomic write). Preserves pinned= flag and Stop-hook keys
# (next_cron_at=, bg_tasks=) set by claudii-stop-hook so a statusLine update
# does not erase them. Keys are read from the existing cache via _cache_get
# and included in the new file write.
# FIXME(race): read-modify-write here races claudii-stop-hook's write of the
# same session-<sid> file. Both are atomic per-file (mktemp→mv) so no
# corruption, but if the Stop hook writes fresh next_cron_at/bg_tasks between
# our _cache_get (L208-210) and the mv below, this write clobbers them with the
# stale values we read (lost update). Rare (needs a Stop hook mid-render); a
# clean fix needs a lock or merge-on-write — deferred, not worth it yet.
# Stable ppid resolution. $PPID is the immediate parent of THIS render — Claude
# Code re-execs a fresh wrapper per statusLine invocation, so it is already
# dead within seconds of being recorded (confirmed: 42834 then 16372 minutes
# apart, both dead on check) and useless as a liveness signal for
# _parse_session_cache's kill-0 fallback (_PSC_is_active — read by claudii
# se/si/gc/dashboard). Fix: walk the process tree from $PPID up to the actual
# `claude` binary ancestor (same technique as ~/ops/scripts/claude-sessions'
# self_claude_pid()) — that PID persists for the session's whole lifetime.
# Cost is only paid on first resolution per session: the previous render's
# ppid is reused via _cache_get + kill -0 as long as it's still alive, so a
# living session forks `ps` here at most once (right after the walk finds it),
# not on every render. Re-resolves automatically if the cached ancestor ever
# dies for real (Claude Code restart, session recycle).
_cache_get ppid ""; _prev_ppid="$_CG"
if [[ "$_prev_ppid" =~ ^[0-9]+$ ]] && kill -0 "$_prev_ppid" 2>/dev/null; then
  _ppid="$_prev_ppid"
else
  _ppid=""
  _anc_p="${PPID:-}"
  _anc_n=0
  while [[ "$_anc_p" =~ ^[0-9]+$ ]] && (( _anc_p > 1 )) && (( _anc_n < 10 )); do
    _anc_comm=$(ps -o comm= -p "$_anc_p" 2>/dev/null)
    _anc_comm="${_anc_comm##*/}"
    if [[ "$_anc_comm" == "claude" ]]; then
      _ppid="$_anc_p"
      break
    fi
    _anc_p=$(ps -o ppid= -p "$_anc_p" 2>/dev/null | tr -d ' ')
    (( ++_anc_n ))
  done
  # No `claude` ancestor found (standalone/manual invocation, renamed binary,
  # walk exhausted) — fall back to the raw PPID rather than storing empty.
  [[ -z "$_ppid" ]] && _ppid="${PPID:-}"
fi
_cache_get pinned "";       _cached_pinned="$_CG"
_cache_get next_cron_at ""; _cached_next_cron_at="$_CG"
_cache_get bg_tasks "";     _cached_bg_tasks="$_CG"
_tmp_session="${_session_file}.tmp.$$"
{ printf '%s\n' \
  "model=$model" "ctx_pct=$ctx_pct" "cost=$cost" \
  "rate_5h=$rate_5h" "rate_7d=$rate_7d" \
  "reset_5h=$reset_5h" "reset_7d=$reset_7d" \
  "session_id=$session_id" \
  "worktree=$worktree_name" \
  "agent=$agent_name" \
  "model_id=$model_id" \
  "burn_eta=$_burn_eta" \
  "pace=$_pace_state" \
  "cache_pct=$_cache_pct" \
  "tok=$_tok_total" \
  "ppid=$_ppid" \
  "rate_7d_start=$_rate_7d_start" \
  "rate_5h_start=$_rate_5h_start" \
  "last_duration_ms=$duration_ms" \
  "last_ctx_pct=$_last_ctx_store" \
  "compactions=$_compactions" \
  "project_path=$cwd"
  [[ -n "$_cached_pinned" ]]        && printf 'pinned=%s\n'        "$_cached_pinned"
  [[ -n "$_cached_next_cron_at" ]]  && printf 'next_cron_at=%s\n'  "$_cached_next_cron_at"
  [[ -n "$_cached_bg_tasks" ]]      && printf 'bg_tasks=%s\n'      "$_cached_bg_tasks"
  true
  } > "$_tmp_session" 2>/dev/null && mv -f "$_tmp_session" "$_session_file" 2>/dev/null || true

# Flight Recorder — append one TSV row, monthly rotation.
read -r _now _date_ym <<< "$(date '+%s %Y-%m')"
_history_file="$_cache_dir/history-${_date_ym}.tsv"
[[ -f "$_history_file" ]] || { touch "$_history_file"; chmod 0600 "$_history_file"; }
printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
  "$_now" "$model" "$cost" "$ctx_pct" "$rate_5h" "$session_id" \
  "${input_tok:-0}" "${output_tok:-0}" "${api_duration_ms:-0}" \
  >> "$_history_file" 2>/dev/null || true

_claudii_log debug "input: ${json:0:200}"
_claudii_log debug "parsed: model=${model} ctx=${ctx_pct} cost=${cost} in=${input_tok} out=${output_tok} 5h=${rate_5h} 7d=${rate_7d} dur=${duration_ms} +${lines_add} -${lines_rm} win=${ctx_size} sid=${session_id:0:8} r5h=${reset_5h} r7d=${reset_7d} cache_r=${cache_read} cache_c=${cache_create} wt=${worktree_name} agent=${agent_name} model_id=${model_id}"

# Formatters — write to _tok_result / _dur_result (no subshell).
_tok_result=""
_tok() {
  local n=${1%.*}
  [[ -z "$n" || "$n" == "null" ]] && _tok_result="" && return
  (( n == 0 )) && _tok_result="" && return
  local _m _d
  if (( n >= 1000000 )); then
    _m=$(( n / 1000000 )); _d=$(( (n % 1000000 + 50000) / 100000 ))
    (( _d == 10 )) && { (( ++_m )); _d=0; }
    printf -v _tok_result '%d.%dM' "$_m" "$_d"
  elif (( n >= 1000 )); then
    _m=$(( n / 1000 )); _d=$(( (n % 1000 + 50) / 100 ))
    (( _d == 10 )) && { (( ++_m )); _d=0; }
    printf -v _tok_result '%d.%dK' "$_m" "$_d"
  else
    _tok_result="$n"
  fi
}

_dur_result=""
_dur() {
  local ms=$1
  [[ -z "$ms" || "$ms" == "null" ]] && _dur_result="" && return
  local sec=$(( ${ms%.*} / 1000 ))
  if   (( sec < 60 ));   then _dur_result="<1m"
  elif (( sec < 3600 )); then printf -v _dur_result '%dm' $(( sec / 60 ))
  else                        printf -v _dur_result '%dh%dm' $(( sec / 3600 )) $(( (sec % 3600) / 60 ))
  fi
}

# Context threshold color: green <70, yellow 70-89, red 90+.
_CLR=""
_thr() {
  local pct=${1%.*}; [[ -z "$pct" ]] && pct=0
  if   (( pct >= 90 )); then _CLR=$'\033[31m'
  elif (( pct >= 70 )); then _CLR=$'\033[33m'
  else                       _CLR=$'\033[32m'; fi
}
# Rate-limit color, keyed on *used* %: green <50, yellow 50-79, red 80+.
_rlc() {
  local pct=${1%.*}; [[ -z "$pct" ]] && pct=0
  if   (( pct >= 80 )); then _CLR=$'\033[31m'
  elif (( pct >= 50 )); then _CLR=$'\033[33m'
  else                       _CLR=$'\033[32m'; fi
}

RST=$'\033[0m'
DIM=$'\033[2m'
BOLD=$'\033[1m'
CYAN=$'\033[0;36m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
RED=$'\033[0;31m'
WHITE=$'\033[0;97m'
ACCENT=$'\033[38;5;213m'
SEP="${DIM}  │  ${RST}"

# Model + effort + thinking indicator.
_seg_model=""
if [[ -n "$model" ]]; then
  _seg_model="${BOLD}${model}${RST}"
  if [[ -n "$effort_level" && "$effort_level" != "null" ]]; then
    # ultracode = Claude Code's xhigh + standing workflow consent (menu mode,
    # not an API effort level). Highlight the high-end modes; dim the rest.
    case "$effort_level" in
      ultracode|max|xhigh) _eff_clr="$ACCENT" ;;
      high)                _eff_clr="$YELLOW" ;;
      *)                   _eff_clr="$DIM"    ;;
    esac
    _seg_model+=" ${_eff_clr}${effort_level}${RST}"
  fi
  [[ "$thinking_enabled" == "true" ]] && _seg_model+=" ${ACCENT}▲${RST}"
fi

# Flat-1M-billing check: true for model families with a native 1M window and
# no >200k long-context premium — opus (all versions), fable/mythos (all
# versions — same pricing/window per Anthropic's docs), and sonnet-5+ (unlike
# sonnet-4.6 and earlier, where 1M is a paid [1m] opt-in with its own long-
# context pricing tier). Matches model id or display name; add new flat-
# billing families/versions here (see "When a new Claude model ships" in
# CLAUDE.md — same most-specific-first discipline as _insights_model_label()).
_flat_1m_model() {
  case "$1" in
    *[Oo]pus*|*[Ff]able*|*[Mm]ythos*|*[Ss]onnet-5*|*[Ss]onnet\ 5*) return 0 ;;
    *) return 1 ;;
  esac
}

# Context bar: usable % = raw scaled to the model's practical (pre-compact) window.
# >200k flag, 1M label, cache hit %. used_percentage is pre-calculated against the
# FULL context_window_size, but the useful window ends at the compact point, not
# 100% — the scale compensates so the bar fills (and _thr turns yellow/red) as that
# point nears. The default scale is *model-aware*, mirroring the FLOOR rule in
# ~/.claude/hooks/reflect-nudge.sh: compact point = min(window * 80%, FLOOR), with
# FLOOR = the full window on flat-1M-billing models (_flat_1m_model — the 80%
# practical-window rule wins) and 195k on every other model (a habit ceiling — so
# a 1M sonnet-4.6[1m] window fills near 195k, not 800k, instead of reading "20%"
# while you're already past the compact point). Expressed as a % of the window.
# 80% here is claudii's auto-compact assumption, deliberately distinct from the
# nudge's 78% *manual*-compact point; on the common windows (flat-1M models,
# any 200k model) it resolves to 80 either way, so the only behaviour change is
# the large-window legacy-sonnet case. Window source: context_window_size, else
# inferred from the model id (flat-1M models → 1M, else 200k).
# CLAUDE_CODE_AUTO_COMPACT_WINDOW (inherited from Claude Code) overrides the
# default: a value > 1 is a token count (fraction = value / window size), a
# value in (0,1] is the fraction itself; clamped to [50,100]%, garbage → the
# default.
_ac_win="${ctx_size%.*}"
_ac_mid="${model_id:-$model}"
if [[ ! "$_ac_win" =~ ^[0-9]+$ ]] || (( _ac_win < 1 )); then
  if _flat_1m_model "$_ac_mid"; then _ac_win=1000000; else _ac_win=200000; fi
fi
if _flat_1m_model "$_ac_mid"; then _ac_floor=$_ac_win; else _ac_floor=195000; fi
_ac_thr=$(( _ac_win * 80 / 100 ))
(( _ac_floor < _ac_thr )) && _ac_thr=$_ac_floor
_ac_dflt=$(( _ac_thr * 100 / _ac_win ))
(( _ac_dflt < 10 )) && _ac_dflt=10     # sanity floor — below this the bar is useless
(( _ac_dflt > 100 )) && _ac_dflt=100
_ac_scale_pct=$_ac_dflt
_ac_env="${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-}"
if [[ "$_ac_env" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
  _ac_scale_pct=$(LC_ALL=C awk -v v="$_ac_env" -v w="${ctx_size:-0}" -v d="$_ac_dflt" 'BEGIN {
    f = d / 100
    if (v > 1)      { if (w + 0 >= 1) f = v / w }
    else if (v > 0) { f = v }
    if (f < 0.5) f = 0.5
    if (f > 1.0) f = 1.0
    printf "%d", f * 100 + 0.5
  }')
  [[ "$_ac_scale_pct" =~ ^[0-9]+$ ]] || _ac_scale_pct=$_ac_dflt
fi
_seg_context=""
if [[ -n "$ctx_pct" && "$ctx_pct" != "null" ]]; then
  local_pct=${ctx_pct%.*}
  (( local_pct < 0 )) && local_pct=0
  (( local_pct > 100 )) && local_pct=100
  (( _usable_pct = local_pct * 100 / _ac_scale_pct ))
  (( _usable_pct > 100 )) && _usable_pct=100
  filled=$(( _usable_pct / 10 ))
  empty=$(( 10 - filled ))
  bar=""
  (( filled > 0 )) && printf -v f "%${filled}s" "" && bar="${f// /█}"
  (( empty > 0 )) && printf -v e "%${empty}s" "" && bar="${bar}${e// /░}"
  # Window / pricing marker — model-aware (_flat_1m_model). Opus/Fable-Mythos/
  # Sonnet-5+ bill a flat rate across their entire 1M window (no >200k long-
  # context premium; Opus's real capacity edge is the ~780k compact point, not
  # 200k), so Claude Code's exceeds_200k_tokens flag is a non-event there: show
  # the dim 1M window label and NEVER a >200k warning. For a legacy-sonnet
  # model (4.6 and earlier) crossing 200k still means something — on a native
  # 1M window (sonnet[1m], a paid opt-in) it is the long-context pricing tier
  # → informational yellow; on a 200k-class window it is a genuine overflow of
  # the standard window → red. (Was unconditionally red, a false alarm on
  # Opus/1M.)
  win=""
  _win_1m=0
  [[ -n "$ctx_size" && "$ctx_size" != "null" && "$ctx_size" -ge 1000000 ]] 2>/dev/null && _win_1m=1
  if _flat_1m_model "${model_id:-$model}"; then
    (( _win_1m )) && win=" ${DIM}1M${RST}"
  else
    if [[ "$exceeds_200k" == "true" ]]; then
      if (( _win_1m )); then win=" ${YELLOW}>200k${RST}"
      else                   win=" ${RED}>200k${RST}"; fi
    elif (( _win_1m )); then
      win=" ${DIM}1M${RST}"
    fi
  fi
  _thr "$_usable_pct"; _seg_context="${_CLR}${bar}${RST} ${DIM}${_usable_pct}%${RST}${win}"
  if _isset "$cache_read" && _isset "$_cache_pct"; then
    if   (( _cache_pct >= 60 )); then _cc="${GREEN}"
    elif (( _cache_pct < 30 )); then _cc="${YELLOW}"
    else                              _cc="${DIM}"
    fi
    _seg_context+=" ${_cc}⚡${_cache_pct}%${RST}"
  fi
fi

_seg_cost=""
if _isset "$cost"; then
  # Cost demoted to a dim segment — token throughput is the primary signal now
  # (full $ detail lives in `claudii cost`).
  # env LC_ALL=C printf (external): a bare "LC_ALL=C printf" is inert on macOS
  # /bin/bash 3.2 — the prefix does not re-setlocale the printf BUILTIN, so a
  # comma locale still prints "$0,55" + an "invalid number" warning to stderr.
  _seg_cost="${DIM}\$$(env LC_ALL=C printf '%.2f' "$cost")${RST}"
fi

# Reset countdown formatter — sets _reset_fmt + _reset_color.
# < 60m → Xm, < 24h → XhYm (Yh suppressed if 0), ≥ 24h → XdYh (Yh suppressed if 0).
_fmt_reset() {
  local _secs="$1" _pct="$2" _m _h _d _rh
  _reset_fmt=""; _reset_color=""
  (( _secs <= 0 )) && return
  # _m feeds the color ladder below and must be set on EVERY branch — the
  # >=24h branch used to leave it unassigned, so `(( _m < 5 ))` saw 0 and
  # painted multi-day resets green instead of dim. The <60m branch overwrites
  # it with the rounded display value.
  _m=$(( _secs / 60 ))
  if (( _secs < 3600 )); then
    _m=$(( (_secs + 30) / 60 ))
    (( _m <= 0 )) && return
    _reset_fmt="${_m}m"
  elif (( _secs < 86400 )); then
    _m=$(( _secs / 60 ))
    _h=$(( _secs / 3600 ))
    _rh=$(( (_secs % 3600) / 60 ))
    if (( _rh > 0 )); then _reset_fmt="${_h}h${_rh}m"
    else _reset_fmt="${_h}h"; fi
  else
    _d=$(( _secs / 86400 ))
    _h=$(( (_secs % 86400) / 3600 ))
    if (( _h > 0 )); then _reset_fmt="${_d}d${_h}h"
    else _reset_fmt="${_d}d"; fi
  fi
  if   (( _pct < 50 ));  then _reset_color="${DIM}"
  elif (( _m < 5 ));     then _reset_color="${GREEN}"
  elif (( _m < 60 ));    then _reset_color="${WHITE}"
  elif (( _m < 120 ));   then _reset_color=""
  else                        _reset_color="${DIM}"
  fi
}

# Rate segment builder. Args: label, rate, reset_at → writes to _seg_result.
# Coloring keyed on used %; in remaining mode the displayed number flips.
# Result-global (no subshell) — call sites used to wrap this in $(...), one
# fork() each on every render (same reason as _cache_get/_tok/_dur above).
_mk_rate_seg() {
  _seg_result=""
  local label=$1 rate=$2 reset_at=$3
  [[ -z "$rate" || "$rate" == "null" ]] && return
  local pct=${rate%.*}
  local disp=$pct out
  [[ "$_rate_display" == "remaining" ]] && disp=$(( 100 - pct ))
  _rlc "$rate"; out="${_CLR}${label}${_rate_mark}:${disp}%${RST}"
  if [[ -n "$reset_at" && "$reset_at" != "null" ]]; then
    # resets_at is an epoch int in real CC payloads; guard the arithmetic so a
    # non-numeric value (format drift / ISO) drops ↺ instead of leaking a
    # "value too great for base" error to stderr (no set -e here, but noisy).
    reset_at="${reset_at%.*}"
    if [[ "$reset_at" =~ ^[0-9]+$ ]]; then
      _fmt_reset $(( reset_at - _now )) "$pct"
      [[ -n "$_reset_fmt" ]] && out+=" ${_reset_color}↺${_reset_fmt}${RST}"
    fi
  fi
  _seg_result="$out"
}
_mk_rate_seg 5h "$rate_5h" "$reset_5h"; _seg_rate5h=$_seg_result
_mk_rate_seg 7d "$rate_7d" "$reset_7d"; _seg_rate7d=$_seg_result

_seg_tokens=""
if [[ -n "$input_tok" && "$input_tok" != "null" ]]; then
  # Tokens are the primary metric — rendered in the value colour (cyan), not dim.
  _tok "$input_tok";  [[ -n "$_tok_result" ]] && _seg_tokens="${CYAN}${_tok_result}↑${RST}"
  _tok "$output_tok"; [[ -n "$_tok_result" ]] && _seg_tokens+="${_seg_tokens:+ }${CYAN}${_tok_result}↓${RST}"
fi

_seg_lines=""
if _isset "$lines_add" || _isset "$lines_rm"; then
  _isset "$lines_add" && _seg_lines+="${GREEN}+${lines_add}${RST}"
  _isset "$lines_rm"  && _seg_lines+="${_seg_lines:+ }${RED}-${lines_rm}${RST}"
fi

_seg_dur=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" ]]; then
  _dur "$duration_ms"; [[ -n "$_dur_result" ]] && _seg_dur="${DIM}⏱ ${_dur_result}${RST}"
fi

_seg_eta=""
_isset "$_burn_eta" 2>/dev/null && _seg_eta="${DIM}ETA:${_burn_eta}m${RST}"

_seg_pace=""
case "${_pace_state:-}" in
  ahead)   _seg_pace="${GREEN}↑${RST}" ;;
  on_pace) _seg_pace="${DIM}=${RST}"   ;;
  behind)  _seg_pace="${YELLOW}↓${RST}" ;;
esac

# Compactions segment — renders ♻N once the session survived a compaction.
# Pairs with burn-ETA ("how many compactions did this session survive?").
# Opt-in (not in default layout).
_seg_compactions=""
if [[ "$_compactions" =~ ^[0-9]+$ ]] && (( _compactions >= 1 )); then
  _seg_compactions="${DIM}♻${_compactions}${RST}"
fi

# Bg-tasks segment — reads bg_tasks from per-session cache (written by claudii-stop-hook).
# Renders ⚙ Nbg when bg_tasks >= 1; empty otherwise. Opt-in (not in default layout).
# _cached_bg_tasks was already read above for the cache-write preserve step.
_seg_bg=""
if [[ "$_cached_bg_tasks" =~ ^[0-9]+$ && "$_cached_bg_tasks" -ge 1 ]]; then
  _seg_bg="${DIM}⚙ ${_cached_bg_tasks}bg${RST}"
fi

# Cron segment — reads next_cron_at from per-session cache (written by claudii-stop-hook).
# Renders ⏰ <relative> when the epoch is in the future; omitted when absent or past.
# _cached_next_cron_at was already read above for the cache-write preserve step.
_seg_cron=""
if [[ "$_cached_next_cron_at" =~ ^[0-9]+$ && "$_cached_next_cron_at" != "0" ]]; then
  _fmt_rel $(( _cached_next_cron_at - _now ))
  [[ -n "$_REL_FMT" ]] && _seg_cron="${DIM}⏰ ${_REL_FMT}${RST}"
fi

# Clock — delegated to cc-insomnii(1) when present and not double-wrapped.
_seg_clock=""
if (( _use_insomnii && ! _wrapped_by_insomnii )); then
  _seg_clock=$(
    CC_INSOMNII_BEDTIME="${_cfg_bedtime:-23:00}" \
    CC_INSOMNII_SHAME="$_cfg_shame" \
    CC_INSOMNII_MOTIVATION="$_cfg_motivation" \
    CC_INSOMNII_RAINBOW="$_cfg_rainbow" \
    cc-insomnii <<< "$json" 2>/dev/null
  )
fi

_seg_worktree=""
_wt_name="${worktree_name:-$workspace_git_worktree}"
if [[ -n "$_wt_name" ]]; then
  _seg_worktree="${DIM}${_wt_name}${RST}"
  [[ -n "$worktree_name" && -n "$worktree_branch" ]] && _seg_worktree+=" ${DIM}⎇ ${worktree_branch}${RST}"
fi

_seg_agent=""
_agent_display="${agent_name:-$session_name}"
[[ -n "$_agent_display" ]] && _seg_agent="${DIM}@${RST}${ACCENT}${_agent_display}${RST}"

_seg_session_name=""
[[ -n "$session_name" ]] && _seg_session_name="${DIM}${session_name}${RST}"

_seg_api_dur=""
if [[ -n "$api_duration_ms" && "$api_duration_ms" != "null" ]]; then
  _dur "$api_duration_ms"; [[ -n "$_dur_result" ]] && _seg_api_dur="${DIM}api:${_dur_result}${RST}"
fi

# Delta segment builder. Args: label, current_rate, start_rate → writes _seg_result.
# Sign flips in remaining mode (magnitude unchanged). Color keyed on usage delta.
# Result-global (no subshell) — see _mk_rate_seg.
_mk_delta_seg() {
  _seg_result=""
  local label=$1 cur=$2 start=$3
  [[ -z "$start" || "$start" == "null" || -z "$cur" || "$cur" == "null" ]] && return
  local d disp sign clr
  d=$(( ${cur%.*} - ${start%.*} ))
  disp=$d
  [[ "$_rate_display" == "remaining" ]] && disp=$(( -d ))
  if (( d > 0 )); then
    _rlc "$cur"; clr=$_CLR
  elif (( d < 0 )); then
    clr=$GREEN
  else
    return
  fi
  sign=""; (( disp > 0 )) && sign="+"
  _seg_result="${DIM}Δ${label}:${RST}${clr}${sign}${disp}%${RST}"
}
_mk_delta_seg 5h "$rate_5h" "$_rate_5h_start"; _seg_delta5h=$_seg_result
_mk_delta_seg 7d "$rate_7d" "$_rate_7d_start"; _seg_delta7d=$_seg_result

# Cache writes — distinct from ⚡ hit ratio.
_seg_cache_create=""
if _isset "$cache_create"; then
  _tok "$cache_create"; [[ -n "$_tok_result" ]] && _seg_cache_create="${DIM}✎${_tok_result}${RST}"
fi

_seg_dir=""
_dir_path="${worktree_original_cwd:-${workspace_project_dir:-$cwd}}"
if [[ -n "$_dir_path" && "$_dir_path" != "null" ]]; then
  _dir_name="${_dir_path##*/}"
  [[ -n "$_dir_name" ]] && _seg_dir="${DIM}⌂${RST} ${YELLOW}${_dir_name}${RST}"
fi

# GitHub / repo segment (workspace.repo.*, Claude Code 2.1.145+).
# Renders <owner>/<name> + #<pr_number> when an open PR is detected on the
# current branch. Skipped when repo info absent (non-git project, no remote).
_seg_github=""
if [[ -n "$repo_owner" && -n "$repo_name" ]]; then
  _seg_github="${DIM}◆ ${repo_owner}/${repo_name}${RST}"
  _isset "$repo_pr" && _seg_github+=" ${YELLOW}#${repo_pr}${RST}"
fi

_DEFAULT_LINES="model,tokens,cache-create
rate-5h,rate-7d,burn-eta,lines-changed
api-duration,duration,worktree,dir,remotes,git-sync
omlx,proxy,cost,context-bar
claude-status,vpn"

_lines_raw="$_DEFAULT_LINES"
[[ -n "$_from_cfg" ]] && _lines_raw="$_from_cfg"

# Terminal width for the ruler segment — computed only when ruler is in the
# layout (off by default), else the `tput cols` fork ran on every render for a
# value nothing reads. Gated like the remotes/git-sync segments below.
_term_cols=0
if [[ "$_lines_raw" == *ruler* ]]; then
  _term_cols=""
  [[ -n "$COLUMNS" ]] && (( COLUMNS > 20 )) && _term_cols="$COLUMNS"
  [[ -z "$_term_cols" ]] && _term_cols=$(tput cols 2>/dev/null)
  (( _term_cols > 20 )) || _term_cols=0
fi

# Repo-remotes segment — where this working copy is published. Classifies the
# cwd's git remotes by host: a github.com URL → GitHub (gh); any other remote
# host → self-hosted forge (fj). Both present → fj·gh (source-of-truth first,
# mirror second). No remote → local; a non-git directory omits the segment.
# Gated on the segment being in the active layout so the one git fork only
# happens when the segment is actually shown.
_seg_remotes=""
if [[ "$_lines_raw" == *remotes* ]]; then
  _rr_dir="${cwd:-$workspace_project_dir}"
  if [[ -n "$_rr_dir" && "$_rr_dir" != "null" ]] && command -v git >/dev/null 2>&1; then
    _rr_out=$(git -C "$_rr_dir" remote -v 2>/dev/null); _rr_rc=$?
    if (( _rr_rc == 0 )); then
      _rr_gh=0; _rr_fj=0
      while IFS= read -r _rl; do
        [[ -z "$_rl" ]] && continue
        if   [[ "$_rl" == *github.com* ]];         then _rr_gh=1
        elif [[ "$_rl" == *://* || "$_rl" == *@* ]]; then _rr_fj=1
        fi
      done <<< "$_rr_out"
      if (( _rr_fj || _rr_gh )); then
        (( _rr_fj )) && _seg_remotes="${CYAN}fj${RST}"
        (( _rr_gh )) && _seg_remotes+="${_seg_remotes:+${DIM}·${RST}}${WHITE}gh${RST}"
        _seg_remotes="${DIM}⇡${RST}${_seg_remotes}"
      else
        _seg_remotes="${DIM}local${RST}"
      fi
    fi
  fi
fi

# Repo sync-state segment — the working copy's git status as a compact traffic
# light: ●N uncommitted (commit pending, yellow), ↑N ahead of upstream (push
# pending, yellow), ↓N behind upstream (pull pending, red — you're missing
# commits, the highest merge-conflict risk). Clean and in sync → a green ✓.
# One `git status --porcelain=v2 --branch` fork yields both the dirty count and
# the ahead/behind counts. Gated on the segment being in the active layout so
# the working-tree scan (the most expensive segment fork) is skipped by any
# custom layout that drops git-sync — it ships in the default layout, but the
# gate keeps the fork off when the segment isn't actually rendered.
# No upstream / detached HEAD → no branch.ab line → only the dirty state shows.
# Outside a git repo (rc != 0) → empty.
# Matched as *git-sync* (not *git*) so it never false-fires on the github segment.
_seg_git_sync=""
if [[ "$_lines_raw" == *git-sync* ]]; then
  _gs_dir="${cwd:-$workspace_project_dir}"
  if [[ -n "$_gs_dir" && "$_gs_dir" != "null" ]] && command -v git >/dev/null 2>&1; then
    _gs_out=$(git -C "$_gs_dir" status --porcelain=v2 --branch 2>/dev/null); _gs_rc=$?
    if (( _gs_rc == 0 )); then
      _gs_ahead=0; _gs_behind=0; _gs_dirty=0
      while IFS= read -r _gl; do
        case "$_gl" in
          '# branch.ab '*)
            _gs_ab="${_gl#\# branch.ab }"        # "+A -B"
            _gs_a="${_gs_ab%% *}"; _gs_b="${_gs_ab##* }"
            _gs_a="${_gs_a#+}"; _gs_b="${_gs_b#-}"
            [[ "$_gs_a" =~ ^[0-9]+$ ]] && _gs_ahead=$_gs_a
            [[ "$_gs_b" =~ ^[0-9]+$ ]] && _gs_behind=$_gs_b
            ;;
          '#'*|'') : ;;                          # other header / blank line
          *) (( ++_gs_dirty )) ;;                # 1/2/u/? line = one changed path
        esac
      done <<< "$_gs_out"
      (( _gs_dirty  > 0 )) && _seg_git_sync="${YELLOW}●${_gs_dirty}${RST}"
      (( _gs_ahead  > 0 )) && _seg_git_sync+="${_seg_git_sync:+ }${YELLOW}↑${_gs_ahead}${RST}"
      (( _gs_behind > 0 )) && _seg_git_sync+="${_seg_git_sync:+ }${RED}↓${_gs_behind}${RST}"
      [[ -z "$_seg_git_sync" ]] && _seg_git_sync="${GREEN}✓${RST}"
    fi
  fi
fi

# Other-sessions segment — surfaces OTHER live Claude Code sessions working in
# this same project_path, so a long session doesn't silently drift out of sync
# with a parallel one (the failure mode that motivated this: git state moved
# under a session that had no idea another one was pushing to the same repo).
# Reuses the per-render session cache (lib/helpers.sh: _session_files /
# _parse_session_cache — the same file-based store `claudii se`/`si` read,
# written by THIS script further up) instead of polling processes: no new
# writer, just a read of state that already exists. _PSC_is_active is now
# trustworthy (the ppid resolved above is the stable `claude` ancestor, not
# the per-render wrapper it used to be) — no mtime-freshness workaround
# needed. Gated like remotes/git-sync — the file scan only runs when the
# segment is actually in the layout.
_seg_sessions=""
if [[ "$_lines_raw" == *sessions* ]]; then
  _sess_dir="${cwd:-$workspace_project_dir}"
  if [[ -n "$_sess_dir" && "$_sess_dir" != "null" ]]; then
    _NOW="$_now"
    _session_files "$_cache_dir"
    _sess_other=0
    for _sf in "${_SESSION_FILES[@]}"; do
      [[ "$_sf" == "$_session_file" ]] && continue   # skip this render's own row
      _parse_session_cache "$_sf"
      [[ "$_PSC_project_path" == "$_sess_dir" ]] || continue
      (( _PSC_is_active )) || continue
      (( ++_sess_other ))
    done
    (( _sess_other > 0 )) && _seg_sessions="${YELLOW}⚠${_sess_other}${RST}"
  fi
fi

# ClaudeStatus — read status-models cache, render [Model glyph ...] + age + incident.
_seg_claude_status=""
_status_cache="${_cache_dir}/status-models"
_sc_mtime=""   # set once below (render block); reused by the self-refresh TTL check
if [[ -f "$_status_cache" ]]; then
  _sc=""
  { _sc=$(<"$_status_cache"); } 2>/dev/null
  if [[ -n "$_sc" ]]; then
    _sc_models=("opus" "sonnet" "haiku" "fable")
    [[ -n "$_sc_models_cfg" ]] && IFS=',' read -ra _sc_models <<< "$_sc_models_cfg"
    # Collapsed health: when every model is healthy the row is a single
    # "claude ✓" — an unlisted model is assumed working. Only down/degraded
    # models get named (Fable included, once its API presence surfaces); a
    # uniform all-down / all-degraded row collapses to one "claude" glyph.
    # No declare -A: bash 3.2 (macOS /bin/bash) maps every key to arr[0] and
    # last-write-wins, so a per-model map would render the same label thrice.
    # Kept in sync with lib/statusline.zsh (RPROMPT) and lib/cmd/overview.sh.
    _sc_total=0; _sc_ok=0; _sc_down=0; _sc_degr=0; _sc_problems=""
    for _scm in "${_sc_models[@]}"; do
      _scm="${_scm// /}"
      [[ -z "$_scm" ]] && continue
      (( ++_sc_total ))
      case "$_scm" in
        opus)   _scm_lbl="Opus"   ;;
        sonnet) _scm_lbl="Sonnet" ;;
        haiku)  _scm_lbl="Haiku"  ;;
        fable)  _scm_lbl="Fable"  ;;
        *)      _scm_lbl="$_scm"  ;;
      esac
      if [[ $'\n'"$_sc" == *$'\n'"${_scm}=down"* ]]; then
        (( ++_sc_down )); _sc_worst="down"
        _sc_problems+="${_sc_problems:+ }${DIM}${_scm_lbl}${RST} ${RED}↓${RST}"
      elif [[ $'\n'"$_sc" == *$'\n'"${_scm}=degraded"* ]]; then
        (( ++_sc_degr )); [[ "${_sc_worst:-}" != "down" ]] && _sc_worst="degraded"
        _sc_problems+="${_sc_problems:+ }${DIM}${_scm_lbl}${RST} ${YELLOW}~${RST}"
      else
        (( ++_sc_ok ))
      fi
    done
    if (( _sc_total > 0 )); then
      if   (( _sc_ok   == _sc_total )); then _seg_claude_status="${DIM}claude${RST} ${GREEN}✓${RST}"
      elif (( _sc_down == _sc_total )); then _seg_claude_status="${DIM}claude${RST} ${RED}↓${RST}"
      elif (( _sc_degr == _sc_total )); then _seg_claude_status="${DIM}claude${RST} ${YELLOW}~${RST}"
      else                                   _seg_claude_status="$_sc_problems"
      fi
      _seg_claude_status="${DIM}[${RST}${_seg_claude_status}${DIM}]${RST}"
    fi

    _sc_mtime=$(stat -f%m "$_status_cache" 2>/dev/null || stat -c%Y "$_status_cache" 2>/dev/null || echo 0)
    if [[ "$_sc_mtime" =~ ^[0-9]+$ ]] && (( _sc_mtime > 0 )); then
      _fmt_brief $(( _now - _sc_mtime ))
      _seg_claude_status+=" ${DIM}${_BRIEF_FMT}${RST}"
    fi

    # Incident indicator. When a status incident exists but NONE of the tracked
    # models are actually affected (e.g. a feature-access note naming only
    # Mythos/Fable), show a neutral note glyph instead of the stage-colored
    # alarm — your models are fine, this is informational. When a tracked model
    # IS affected, the stage color (‼/⚐/◎) reflects the incident stage; absent
    # an incident marker, a bare model outage falls back to ⚠.
    # Kept in sync with lib/statusline.zsh (RPROMPT) and lib/cmd/overview.sh.
    _sc_incident=""
    if   [[ $'\n'"$_sc" == *$'\n'"_incident=investigating"* ]]; then _sc_incident="investigating"
    elif [[ $'\n'"$_sc" == *$'\n'"_incident=identified"* ]];    then _sc_incident="identified"
    elif [[ $'\n'"$_sc" == *$'\n'"_incident=monitoring"* ]];    then _sc_incident="monitoring"
    fi
    if   [[ -n "$_sc_incident" && -z "${_sc_worst:-}" ]];  then _seg_claude_status+=" ${DIM}ⓘ${RST}"
    elif [[ "$_sc_incident" == "investigating" ]];        then _seg_claude_status+=" ${RED}‼${RST}"
    elif [[ "$_sc_incident" == "identified" ]];           then _seg_claude_status+=" ${YELLOW}⚐${RST}"
    elif [[ "$_sc_incident" == "monitoring" ]];           then _seg_claude_status+=" ${CYAN}◎${RST}"
    elif [[ "${_sc_worst:-}" == "down" ]];                then _seg_claude_status+=" ${RED}⚠${RST}"
    elif [[ "${_sc_worst:-}" == "degraded" ]];            then _seg_claude_status+=" ${YELLOW}⚠${RST}"
    fi
  fi
fi

# ClaudeStatus self-refresh — the zsh precmd is the primary cache refresher,
# but inside a long Claude Code session no zsh prompt may ever fire, so the
# segment age would grow unbounded (this script only reads the cache).
# Spawn claudii-status in the background when the cache is older than the
# configured TTL (or missing). claudii-status re-checks the TTL itself and
# exits fast on a fresh cache; the PID-file liveness check prevents stacking
# fetches across rapid renders and parallel sessions. Skipped entirely when
# the layout doesn't render the claude-status segment.
if [[ "$_lines_raw" == *claude-status* ]]; then
  _sc_ttl="$_cfg_status_ttl"
  [[ "$_sc_ttl" =~ ^[0-9]+$ ]] || _sc_ttl=300
  # Reuse the mtime already stat'd for the age display; only fork stat when the
  # render block above did not run (cache absent / empty → _sc_mtime still "").
  [[ "$_sc_mtime" =~ ^[0-9]+$ ]] || _sc_mtime=$(stat -f%m "$_status_cache" 2>/dev/null || stat -c%Y "$_status_cache" 2>/dev/null || echo 0)
  _sc_age=$(( _now - _sc_mtime ))
  if (( _sc_age > _sc_ttl )); then
    _spid_file="$_cache_dir/status.pid"
    _spid=""
    [[ -f "$_spid_file" ]] && { _spid=$(<"$_spid_file"); } 2>/dev/null
    _sp_fresh=0
    if [[ "$_spid" =~ ^[0-9]+$ ]] && kill -0 "$_spid" 2>/dev/null; then
      # PID alive — trust it only while the PID file is recent (< 30s), same
      # recycling guard as the zsh spawner.
      _sp_mt=$(stat -f%m "$_spid_file" 2>/dev/null || stat -c%Y "$_spid_file" 2>/dev/null || echo 0)
      (( _now - _sp_mt < 30 )) && _sp_fresh=1
    fi
    (( _sp_fresh )) || ( "$CLAUDII_HOME/bin/claudii-status" --quiet --pid-file "$_spid_file" >/dev/null 2>&1 & )
  fi
fi

# omlx local-agent indicator — gateii's active.json, 300s stale-guard.
_seg_omlx=""
_omlx_active_path="${CLAUDII_OMLX_ACTIVE:-${_cfg_omlx:-$HOME/offline_coding/gateii/data/agents/active.json}}"
if [[ -f "$_omlx_active_path" ]]; then
  IFS=$'\x1f' read -r _omlx_started _omlx_task _omlx_model_short <<< "$(
    jq -r '[
      (.started_epoch // 0 | tostring),
      (.task // "?"),
      (.model // "?" | gsub("-MLX-4bit$";"") | gsub("-A3B-4bit$";"-A3B") | gsub("-a4b-it-4bit$";"") | gsub("-it-4bit$";""))
    ] | join("\u001f")' "$_omlx_active_path" 2>/dev/null
  )"
  if [[ -n "$_omlx_started" && "$_omlx_started" != "0" ]]; then
    _omlx_age=$(( _now - _omlx_started ))
    if (( _omlx_age >= 0 && _omlx_age < 300 )); then
      _seg_omlx="${ACCENT}⚡${RST} ${BOLD}${_omlx_task}${RST} ${DIM}${_omlx_model_short} ${_omlx_age}s${RST}"
    fi
  fi
fi

# VPN — WireGuard (state file) + Tailscale (CGNAT 100.64.0.0/10).
_seg_vpn=""
_vpn_state="${_cache_dir}/vpnii"
if [[ -f "$_vpn_state" ]]; then
  _vpn_tunnel=$(<"$_vpn_state")
  [[ -n "$_vpn_tunnel" ]] && _seg_vpn="${GREEN}⬡${RST} ${DIM}${_vpn_tunnel}${RST}"
fi
# Tailscale — the ifconfig probe is a fork + grep on every render, so cache the
# up/down result ~30s (shared with the zsh RPROMPT segment in lib/vpnii.zsh:
# $_cache_dir/vpnii-ts, "<epoch> <0|1>", 1 = up). Garbage/torn reads fall through
# to a re-probe via the numeric guard.
_ts_cache="${_cache_dir}/vpnii-ts"
_ts_up=1; _ts_have=0
if [[ -r "$_ts_cache" ]]; then
  _ts_line=""; { _ts_line=$(<"$_ts_cache"); } 2>/dev/null
  _ts_ep="${_ts_line%% *}"; _ts_val="${_ts_line##* }"
  if [[ "$_ts_ep" =~ ^[0-9]+$ ]] && (( _now - _ts_ep < 30 )); then
    [[ "$_ts_val" == "1" ]] && _ts_up=0
    _ts_have=1
  fi
fi
if (( ! _ts_have )); then
  _ts_up=1
  ifconfig 2>/dev/null | grep -qE 'inet 100\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\.' && _ts_up=0
  printf '%s %s\n' "$_now" "$(( _ts_up == 0 ? 1 : 0 ))" > "$_ts_cache" 2>/dev/null || true
fi
if (( _ts_up == 0 )); then
  [[ -n "$_seg_vpn" ]] && _seg_vpn+="  "
  _seg_vpn+="${GREEN}⬢${RST} ${DIM}ts${RST}"
fi

# Proxy — non-empty only when ANTHROPIC_BASE_URL is set in .claude/settings.local.json.
_seg_proxy=""
for _p in \
  "${workspace_project_dir:+${workspace_project_dir}/.claude/settings.local.json}" \
  "${cwd:+${cwd}/.claude/settings.local.json}" \
  ".claude/settings.local.json"; do
  [[ -n "$_p" && -f "$_p" ]] && { _proxy_settings=$_p; break; }
done
if [[ -n "${_proxy_settings:-}" && -f "$_proxy_settings" ]]; then
  _proxy_url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$_proxy_settings" 2>/dev/null)
  if [[ -n "$_proxy_url" ]]; then
    if [[ "$_proxy_url" == "http://localhost:8888" ]]; then
      _proxy_label="gateii"
    else
      _proxy_label="${_proxy_url#http://}"; _proxy_label="${_proxy_label#https://}"; _proxy_label="${_proxy_label%%/*}"
    fi
    _seg_proxy="${CYAN}⇄${RST} ${YELLOW}${_proxy_label}${RST}"
  else
    _seg_proxy="${DIM}→ api${RST}"
  fi
fi

while IFS= read -r _line_segs; do
  [[ -z "$_line_segs" ]] && continue
  _line_out=""; _first=1
  IFS=',' read -ra _segs <<< "$_line_segs"
  for _seg in "${_segs[@]}"; do
    case "$_seg" in
      model)         _val="$_seg_model"    ;;
      context-bar)   _val="$_seg_context"  ;;
      cost)          _val="$_seg_cost"     ;;
      rate-5h)       _val="$_seg_rate5h"   ;;
      rate-7d)       _val="$_seg_rate7d"   ;;
      tokens)        _val="$_seg_tokens"   ;;
      lines-changed) _val="$_seg_lines"    ;;
      duration)      _val="$_seg_dur"      ;;
      burn-eta)      _val="$_seg_eta"      ;;
      pace)          _val="$_seg_pace"     ;;
      cron)          _val="$_seg_cron"     ;;
      bg-tasks)      _val="$_seg_bg"       ;;
      compactions)   _val="$_seg_compactions" ;;
      worktree)      _val="$_seg_worktree" ;;
      agent)         _val="$_seg_agent"    ;;
      session-name)  _val="$_seg_session_name" ;;
      api-duration)  _val="$_seg_api_dur"  ;;
      delta-5h)      _val="$_seg_delta5h"  ;;
      delta-7d)      _val="$_seg_delta7d"  ;;
      cache-create)  _val="$_seg_cache_create" ;;
      dir)           _val="$_seg_dir"      ;;
      github)        _val="$_seg_github"   ;;
      remotes)       _val="$_seg_remotes"  ;;
      git-sync)      _val="$_seg_git_sync" ;;
      sessions)      _val="$_seg_sessions" ;;
      claude-status) _val="$_seg_claude_status" ;;
      vpn)           _val="$_seg_vpn"      ;;
      omlx)          _val="$_seg_omlx"     ;;
      proxy)         _val="$_seg_proxy"    ;;
      clock)         _val="$_seg_clock"    ;;
      ruler)
        # Fill remaining terminal width with ─. Falls back to 60 cols.
        _val=""
        _ruler_cols=$(( _term_cols > 0 ? _term_cols : 60 ))
        if (( _first )); then
          _used=0
        else
          _vis=$(printf '%s' "$_line_out" | sed $'s/\033\\[[0-9;]*m//g')
          _used=$(( ${#_vis} + 5 ))
        fi
        _fill=$(( _ruler_cols - _used ))
        if (( _fill > 1 )); then
          printf -v _v "%${_fill}s" ""
          _val="${DIM}${_v// /─}${RST}"
        fi
        ;;
      *)             _val=""               ;;
    esac
    if [[ -n "$_val" ]]; then
      if (( _first )); then _line_out="$_val"; _first=0
      else _line_out+="${SEP}${_val}"; fi
    fi
  done
  [[ -n "$_line_out" ]] && printf '%s\n' "${RST}${_line_out}" || true
done <<< "$_lines_raw"

# Vibemap append — opt-in, fire-and-forget, errors silent.
if [[ "$_cfg_vibemap_enabled" == "true" ]]; then
  _vm_delta=0
  if [[ "$_last_duration_ms" =~ ^[0-9]+$ && "$duration_ms" =~ ^[0-9]+$ ]]; then
    _vm_delta=$(( duration_ms - _last_duration_ms ))
    (( _vm_delta < 0 )) && _vm_delta=0
  fi
  _vm_path=$(_vibemap_resolve_path "$_cfg_vibemap_path")
  _vibemap_append "$_vm_path" "$model" "$session_id" "$_vm_delta" 2>/dev/null || true
fi

true
