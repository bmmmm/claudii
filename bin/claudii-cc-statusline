#!/bin/bash
# claudii-sessionline ŌĆö Claude Code statusLine handler
# Reads JSON session metrics from stdin, outputs a configurable multi-line status.
# Configure in settings.json:
#   "statusLine": { "type": "command", "command": "claudii-sessionline" }

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
# shellcheck source=lib/log.sh
source "$CLAUDII_HOME/lib/log.sh"
# shellcheck source=lib/vibemap.sh
source "$CLAUDII_HOME/lib/vibemap.sh"

command -v jq >/dev/null 2>&1 || { printf 'claudii-sessionline: jq not found ŌĆö install jq\n' >&2; exit 1; }

read -r json

# Write session data to cache (key=value) ŌĆö RPROMPT reads this without jq
_cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
[[ -d "$_cache_dir" ]] || { mkdir -p "$_cache_dir"; chmod 0700 "$_cache_dir"; }

# ŌöĆŌöĆ User config (statusline.* keys) ŌĆö single jq call, available everywhere ŌöĆŌöĆ
# Field separator: US (0x1F). Inside .statusline.lines: RS (0x1E), restored to
# \n after split. Reading early so _rate_display (used by rate segments) is set.
_config_file="${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json"
_from_cfg=""
_sc_models_cfg=""
_cfg_omlx=""
_rate_display=""
_cfg_bedtime=""
_cfg_vibemap_enabled=""
_cfg_vibemap_path=""
if [[ -f "$_config_file" ]]; then
  IFS=$'\x1f' read -r _from_cfg _sc_models_cfg _cfg_omlx _rate_display _cfg_bedtime _cfg_vibemap_enabled _cfg_vibemap_path < <(
    jq -r '[
      (if .statusline.lines then (.statusline.lines | map(join(",")) | join("")) else "" end),
      (.statusline.models // ""),
      (.statusline.omlx_active_path // ""),
      (.statusline.rate_display // ""),
      (.statusline.bedtime // ""),
      (.vibemap.enabled // false | tostring),
      (.vibemap.path // "")
    ] | join("")' "$_config_file" 2>/dev/null
  )
  _from_cfg="${_from_cfg//$'\x1e'/$'\n'}"
fi
[[ "$_rate_display" != "remaining" ]] && _rate_display="used"
# Tiny mode marker ŌĆö empty in default "used", Ōåō in "remaining" (the number counts down).
# Appended to the rate-segment label so it's obvious at a glance which side is shown.
_rate_mark=""
[[ "$_rate_display" == "remaining" ]] && _rate_mark="Ōåō"

# Parse all fields in one jq call ŌĆö single process, max efficiency
# Delimiter: Unit Separator (0x1F) ŌĆö non-whitespace, so read won't collapse empty fields
_D=$'\x1f'
IFS="$_D" read -r model ctx_pct cost input_tok output_tok rate_5h rate_7d \
  duration_ms lines_add lines_rm ctx_size session_id reset_5h reset_7d \
  cache_read cache_create worktree_name agent_name model_id cwd \
  session_name worktree_branch api_duration_ms exceeds_200k \
  effort_level thinking_enabled workspace_git_worktree \
  workspace_project_dir worktree_original_cwd <<< "$(
  jq -r '[
    (.model.display_name // ""),
    (.context_window.used_percentage // "" | tostring),
    (.cost.total_cost_usd // "" | tostring),
    (.context_window.total_input_tokens // "" | tostring),
    (.context_window.total_output_tokens // "" | tostring),
    (.rate_limits.five_hour.used_percentage // "" | tostring),
    (.rate_limits.seven_day.used_percentage // "" | tostring),
    (.cost.total_duration_ms // "" | tostring),
    (.cost.total_lines_added // "" | tostring),
    (.cost.total_lines_removed // "" | tostring),
    (.context_window.context_window_size // "" | tostring),
    (.session_id // ""),
    (.rate_limits.five_hour.resets_at // "" | tostring),
    (.rate_limits.seven_day.resets_at // "" | tostring),
    (.context_window.current_usage.cache_read_input_tokens // "" | tostring),
    (.context_window.current_usage.cache_creation_input_tokens // "" | tostring),
    (.worktree.name // ""),
    (.agent.name // ""),
    (.model.id // ""),
    (.workspace.current_dir // .cwd // ""),
    (.session_name // ""),
    (.worktree.branch // ""),
    (.cost.total_api_duration_ms // "" | tostring),
    (.exceeds_200k_tokens // false | tostring),
    (.effort.level // ""),
    (.thinking.enabled // false | tostring),
    (.workspace.git_worktree // ""),
    (.workspace.project_dir // ""),
    (.worktree.original_cwd // "")
  ] | join("\u001f")' <<< "$json" 2>/dev/null || printf "${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}"
)"

# Cache hit percentage ŌĆö computed from cache_read vs input tokens
_cache_pct=""
if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
  _cr=${cache_read%.*}
  _ci=${input_tok%.*}
  if (( _ci + _cr > 0 )); then
    _cache_pct=$(( _cr * 100 / (_cr + _ci) ))
  fi
fi

# Read existing session cache once ŌĆö used for 7d/5h start values
_sid="${session_id:+${session_id:0:8}}"
_session_file="$_cache_dir/session-${_sid:-unknown}"
_existing_cache=""
[[ -f "$_session_file" ]] && { _existing_cache=$(<"$_session_file"); } 2>/dev/null
_ec_nl=$'\n'"$_existing_cache"

_rate_7d_start=""
if [[ -n "$rate_7d" && "$rate_7d" != "null" && "$rate_7d" != "" ]]; then
  if [[ "$_ec_nl" == *$'\n'rate_7d_start=* ]]; then
    _rate_7d_start="${_existing_cache#*rate_7d_start=}"
    _rate_7d_start="${_rate_7d_start%%$'\n'*}"
  fi
  [[ -z "$_rate_7d_start" ]] && _rate_7d_start="$rate_7d"
fi

_rate_5h_start=""
if [[ -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  if [[ "$_ec_nl" == *$'\n'rate_5h_start=* ]]; then
    _rate_5h_start="${_existing_cache#*rate_5h_start=}"
    _rate_5h_start="${_rate_5h_start%%$'\n'*}"
  fi
  [[ -z "$_rate_5h_start" ]] && _rate_5h_start="$rate_5h"
fi

# Vibemap delta: previous render's duration_ms, used to compute delta_ms.
# Stored back in session cache as last_duration_ms below.
_last_duration_ms=""
if [[ "$_ec_nl" == *$'\n'last_duration_ms=* ]]; then
  _last_duration_ms="${_existing_cache#*last_duration_ms=}"
  _last_duration_ms="${_last_duration_ms%%$'\n'*}"
fi

# Burn-rate ETA ŌĆö computed for dashboard cache, not rendered in sessionline
_burn_eta=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" && "$duration_ms" != "0" ]]; then
  _rate_5h_int=${rate_5h%.*}
  _session_min_int=$(( ${duration_ms%.*} / 60000 ))
  if [[ -n "$rate_5h" && "$rate_5h" != "null" && "$rate_5h" != "0" ]] && \
     (( _session_min_int >= 3 && _rate_5h_int > 0 )); then
    _burn_eta=$(awk -v dur="$duration_ms" -v rat="$rate_5h" \
      'BEGIN { m=dur/60000; r=rat+0; print (r>0)?int((100-r)/(r/m)+0.5):0 }')
  fi
fi

# Write per-session cache (key=value) ŌĆö RPROMPT + aliases read without jq
# Include ppid so dashboard can check if Claude process is still alive
# Atomic write: write to tmp then rename ŌĆö prevents RPROMPT from reading partial data
# Preserve pinned= flag from existing cache file if present
_ppid="${PPID:-}"
_tmp_session="${_session_file}.tmp.$$"
{ [[ -f "$_session_file" ]] && grep '^pinned=' "$_session_file" 2>/dev/null || true
  printf '%s\n' \
  "model=$model" "ctx_pct=$ctx_pct" "cost=$cost" \
  "rate_5h=$rate_5h" "rate_7d=$rate_7d" \
  "reset_5h=$reset_5h" "reset_7d=$reset_7d" \
  "session_id=$session_id" \
  "worktree=$worktree_name" \
  "agent=$agent_name" \
  "model_id=$model_id" \
  "burn_eta=$_burn_eta" \
  "cache_pct=$_cache_pct" \
  "ppid=$_ppid" \
  "rate_7d_start=$_rate_7d_start" \
  "rate_5h_start=$_rate_5h_start" \
  "last_duration_ms=$duration_ms" \
  "project_path=$cwd" \
  > "$_tmp_session" && mv -f "$_tmp_session" "$_session_file"; } 2>/dev/null || true

# Append to persistent history (Flight Recorder) ŌĆö one TSV line per update
# Monthly rotation: history-YYYY-MM.tsv (legacy history.tsv stays, readers glob both)
# Fields: timestamp, model, cost, ctx_pct, rate_5h, session_id, input_tok, output_tok, api_duration_ms
read -r _now _date_ym <<< "$(date '+%s %Y-%m')"
_history_file="$_cache_dir/history-${_date_ym}.tsv"
[[ -f "$_history_file" ]] || { touch "$_history_file"; chmod 0600 "$_history_file"; }
printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
  "$_now" "$model" "$cost" "$ctx_pct" "$rate_5h" "$session_id" \
  "${input_tok:-0}" "${output_tok:-0}" "${api_duration_ms:-0}" \
  >> "$_history_file" 2>/dev/null || true

_claudii_log debug "input: ${json:0:200}"
_claudii_log debug "parsed: model=${model} ctx=${ctx_pct} cost=${cost} in=${input_tok} out=${output_tok} 5h=${rate_5h} 7d=${rate_7d} dur=${duration_ms} +${lines_add} -${lines_rm} win=${ctx_size} sid=${session_id:0:8} r5h=${reset_5h} r7d=${reset_7d} cache_r=${cache_read} cache_c=${cache_create} wt=${worktree_name} agent=${agent_name} model_id=${model_id}"

# --- helpers ---

# Token formatter ŌĆö writes to _tok_result (no subshell, pure bash arithmetic)
# 999ŌåÆ"999"  1000ŌåÆ"1.0K"  1500ŌåÆ"1.5K"  1000000ŌåÆ"1.0M"
_tok_result=""
_tok() {
  local n=${1%.*}
  [[ -z "$n" || "$n" == "null" ]] && _tok_result="" && return
  (( n == 0 )) && _tok_result="" && return
  local _m _d
  if (( n >= 1000000 )); then
    _m=$(( n / 1000000 )); _d=$(( (n % 1000000 + 50000) / 100000 ))
    (( _d == 10 )) && { (( ++_m )); _d=0; }
    printf -v _tok_result '%d.%dM' "$_m" "$_d"
  elif (( n >= 1000 )); then
    _m=$(( n / 1000 )); _d=$(( (n % 1000 + 50) / 100 ))
    (( _d == 10 )) && { (( ++_m )); _d=0; }
    printf -v _tok_result '%d.%dK' "$_m" "$_d"
  else
    _tok_result="$n"
  fi
}

# Duration formatter ŌĆö writes to _dur_result (no subshell)
_dur_result=""
_dur() {
  local ms=$1
  [[ -z "$ms" || "$ms" == "null" ]] && _dur_result="" && return
  local sec=$(( ${ms%.*} / 1000 ))
  if   (( sec < 60 ));   then _dur_result="<1m"
  elif (( sec < 3600 )); then printf -v _dur_result '%dm' $(( sec / 60 ))
  else                        printf -v _dur_result '%dh%dm' $(( sec / 3600 )) $(( (sec % 3600) / 60 ))
  fi
}

# Color helpers ŌĆö write to _CLR to avoid command-substitution subshell overhead
_CLR=""
# Threshold: green <70, yellow 70-89, red 90+
_thr() {
  local pct=${1%.*}; [[ -z "$pct" ]] && pct=0
  if   (( pct >= 90 )); then _CLR=$'\033[31m'
  elif (( pct >= 70 )); then _CLR=$'\033[33m'
  else                       _CLR=$'\033[32m'; fi
}
# Rate-limit color (always keyed on the *used* %): green < 50, yellow 50-79, red 80+.
# Green chosen over cyan so "lots of headroom" reads consistently across modes ŌĆö in
# `remaining` display the number itself is high (e.g. 97%), and green matches the
# vibe of "plenty left".
_rlc() {
  local pct=${1%.*}; [[ -z "$pct" ]] && pct=0
  if   (( pct >= 80 )); then _CLR=$'\033[31m'
  elif (( pct >= 50 )); then _CLR=$'\033[33m'
  else                       _CLR=$'\033[32m'; fi
}

RST=$'\033[0m'
DIM=$'\033[2m'
BOLD=$'\033[1m'
BLINK=$'\033[5m'
BLINK2=$'\033[6m'
REVERSE=$'\033[7m'
UNDERLINE=$'\033[4m'
CYAN=$'\033[0;36m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
RED=$'\033[0;31m'
WHITE=$'\033[0;97m'
ACCENT=$'\033[38;5;213m'
SEP="${DIM}  Ōöé  ${RST}"

# --- segment pre-computation ---

# Model (bold) + effort level (colored by tier) + thinking indicator (Ō¢▓)
_seg_model=""
if [[ -n "$model" ]]; then
  _seg_model="${BOLD}${model}${RST}"
  if [[ -n "$effort_level" && "$effort_level" != "null" ]]; then
    case "$effort_level" in
      max)  _eff_clr="$ACCENT" ;;
      high) _eff_clr="$YELLOW" ;;
      *)    _eff_clr="$DIM"    ;;
    esac
    _seg_model+=" ${_eff_clr}${effort_level}${RST}"
  fi
  [[ "$thinking_enabled" == "true" ]] && _seg_model+=" ${ACCENT}Ō¢▓${RST}"
fi

# Context bar (10 chars) + usable percentage + ŌÜĪcache%
_seg_context=""
if [[ -n "$ctx_pct" && "$ctx_pct" != "null" ]]; then
  local_pct=${ctx_pct%.*}
  (( local_pct < 0 )) && local_pct=0
  (( local_pct > 100 )) && local_pct=100
  # Usable context %: raw_pct / 0.8 ŌĆö scales to the 80% practical usable window
  # Example: 76% raw ŌåÆ 76/0.8 = 95% usable. Bar and number both reflect usable %.
  (( _usable_pct = local_pct * 100 / 80 ))
  (( _usable_pct > 100 )) && _usable_pct=100
  filled=$(( _usable_pct / 10 ))
  empty=$(( 10 - filled ))
  bar=""
  (( filled > 0 )) && printf -v f "%${filled}s" "" && bar="${f// /Ō¢ł}"
  (( empty > 0 )) && printf -v e "%${empty}s" "" && bar="${bar}${e// /Ō¢æ}"
  # Context size indicator: >200k flag (current API call exceeded 200k tokens)
  # or 1M label when extended context window active
  win=""
  if [[ "$exceeds_200k" == "true" ]]; then
    win=" ${RED}>200k${RST}"
  elif [[ -n "$ctx_size" && "$ctx_size" != "null" && "$ctx_size" -ge 1000000 ]] 2>/dev/null; then
    win=" ${DIM}1M${RST}"
  fi
  _thr "$_usable_pct"; _seg_context="${_CLR}${bar}${RST} ${DIM}${_usable_pct}%${RST}${win}"
  # Cache hit ratio ŌĆö suffix to context segment
  if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
    if [[ -n "$_cache_pct" && "$_cache_pct" != "0" ]]; then
      if (( _cache_pct >= 60 )); then _cc="${GREEN}"
      elif (( _cache_pct < 30 )); then _cc="${YELLOW}"
      else _cc="${DIM}"; fi
      _seg_context+=" ${_cc}ŌÜĪ${_cache_pct}%${RST}"
    fi
  fi
fi

# Cost ŌĆö cyan $X.XX
_seg_cost=""
if [[ -n "$cost" && "$cost" != "null" && "$cost" != "0" ]]; then
  _seg_cost="${CYAN}\$$(printf '%.2f' "$cost")${RST}"
fi

# Rate limits ŌĆö 5h and 7d
# _fmt_reset(secs, pct) ŌĆö sets _reset_fmt (text) and _reset_color based on
# remaining seconds and the rate-limit percentage. Format:
#   < 60m: Xm     (e.g. 45m)
#   < 24h: XhYm   (e.g. 1h19m, or 3h when minutes are zero)
#   Ōēź 24h: XdYh   (e.g. 2d5h, or 2d when hours are zero)
# Color thresholds match the previous per-segment logic.
_fmt_reset() {
  local _secs="$1" _pct="$2" _m _h _d _rh
  _reset_fmt=""; _reset_color=""
  (( _secs <= 0 )) && return
  if (( _secs < 3600 )); then
    # Round to nearest minute; suppress < 30s (would render as Ōå║0m).
    _m=$(( (_secs + 30) / 60 ))
    (( _m <= 0 )) && return
    _reset_fmt="${_m}m"
  elif (( _secs < 86400 )); then
    _m=$(( _secs / 60 ))
    _h=$(( _secs / 3600 ))
    _rh=$(( (_secs % 3600) / 60 ))
    if (( _rh > 0 )); then _reset_fmt="${_h}h${_rh}m"
    else _reset_fmt="${_h}h"; fi
  else
    _d=$(( _secs / 86400 ))
    _h=$(( (_secs % 86400) / 3600 ))
    if (( _h > 0 )); then _reset_fmt="${_d}d${_h}h"
    else _reset_fmt="${_d}d"; fi
  fi
  if   (( _pct < 50 ));  then _reset_color="${DIM}"
  elif (( _m < 5 ));     then _reset_color="${GREEN}"
  elif (( _m < 60 ));    then _reset_color="${WHITE}"
  elif (( _m < 120 ));   then _reset_color=""
  else                        _reset_color="${DIM}"
  fi
}

# Rate display: "used" (default, e.g. 5h:62%) shows consumed budget; "remaining"
# (5h:38%) shows what's left. Coloring of segment + reset countdown is driven by
# the *used* percentage in both modes ŌĆö semantics ("close to limit" ŌåÆ red) stay
# stable, only the displayed number flips.
_seg_rate5h=""
if [[ -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _rate_5h_pct=${rate_5h%.*}
  _disp_5h=$_rate_5h_pct
  [[ "$_rate_display" == "remaining" ]] && _disp_5h=$(( 100 - _rate_5h_pct ))
  _rlc "$rate_5h"; _seg_rate5h="${_CLR}5h${_rate_mark}:${_disp_5h}%${RST}"
  if [[ -n "$reset_5h" && "$reset_5h" != "null" && "$reset_5h" != "" ]]; then
    reset_5h="${reset_5h%.*}"
    _fmt_reset $(( reset_5h - _now )) "$_rate_5h_pct"
    [[ -n "$_reset_fmt" ]] && _seg_rate5h+=" ${_reset_color}Ōå║${_reset_fmt}${RST}"
  fi
fi

_seg_rate7d=""
if [[ -n "$rate_7d" && "$rate_7d" != "null" ]]; then
  _rate_7d_pct=${rate_7d%.*}
  _disp_7d=$_rate_7d_pct
  [[ "$_rate_display" == "remaining" ]] && _disp_7d=$(( 100 - _rate_7d_pct ))
  _rlc "$rate_7d"; _seg_rate7d="${_CLR}7d${_rate_mark}:${_disp_7d}%${RST}"
  if [[ -n "$reset_7d" && "$reset_7d" != "null" && "$reset_7d" != "" ]]; then
    reset_7d="${reset_7d%.*}"
    _fmt_reset $(( reset_7d - _now )) "$_rate_7d_pct"
    [[ -n "$_reset_fmt" ]] && _seg_rate7d+=" ${_reset_color}Ōå║${_reset_fmt}${RST}"
  fi
fi

# Tokens: DIM XkŌåæ XkŌåō
_seg_tokens=""
if [[ -n "$input_tok" && "$input_tok" != "null" ]]; then
  _tok "$input_tok";  [[ -n "$_tok_result" ]] && _seg_tokens="${DIM}${_tok_result}Ōåæ${RST}"
  _tok "$output_tok"; [[ -n "$_tok_result" ]] && _seg_tokens+="${_seg_tokens:+ }${DIM}${_tok_result}Ōåō${RST}"
fi

# Lines changed: green +X red -X (only when > 0)
_seg_lines=""
if [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] || \
   [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]]; then
  [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] && _seg_lines+="${GREEN}+${lines_add}${RST}"
  [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]] && _seg_lines+=" ${RED}-${lines_rm}${RST}"
fi

# Duration: DIM Xm / Xh Xm
_seg_dur=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" ]]; then
  _dur "$duration_ms"; [[ -n "$_dur_result" ]] && _seg_dur="${DIM}ŌÅ▒ ${_dur_result}${RST}"
fi

# Burn-ETA: DIM ETA:Xm (only when _burn_eta set and > 0)
_seg_eta=""
if [[ -n "$_burn_eta" && "$_burn_eta" != "0" ]] 2>/dev/null; then
  _seg_eta="${DIM}ETA:${_burn_eta}m${RST}"
fi

# Clock with bedtime nudge ŌĆö escalates color/glyph as bedtime approaches and
# passes. Configurable via statusline.bedtime (default "23:00", local time).
# Phases: dim ŌśŠ ŌåÆ cyan ŌśŠ ŌåÆ yellow ŌśŠ ŌåÆ red ŌśŠ +Xm ŌåÆ red bold ­¤Æż +XhYm.
# Wrap-aware: if it's past midnight and bedtime is in the evening, the
# overdue counter rolls over correctly.
_seg_clock=""
_bedtime="${_cfg_bedtime:-23:00}"
if [[ "$_bedtime" =~ ^([0-9]{1,2}):([0-9]{2})$ ]]; then
  _bt_h="${BASH_REMATCH[1]#0}"; _bt_m="${BASH_REMATCH[2]#0}"
  _now_h=$(date +%H); _now_m=$(date +%M)
  _now_h="${_now_h#0}"; _now_m="${_now_m#0}"
  _now_min=$(( ${_now_h:-0} * 60 + ${_now_m:-0} ))
  _bt_min=$(( ${_bt_h:-0} * 60 + ${_bt_m:-0} ))
  _delta_min=$(( _now_min - _bt_min ))
  # Wrap: before 6am + bedtime in evening (>=18:00) ŌåÆ past midnight, still overdue
  if (( _now_min < 360 && _bt_min >= 1080 )); then
    _delta_min=$(( _delta_min + 1440 ))
  fi
  _hhmm=$(date +%H:%M)
  _ck_glyph="ŌśŠ"; _ck_color="$DIM"; _ck_suffix=""
  _ck_vibe=0
  if   (( _delta_min < -30 )); then : # default: dim
  elif (( _delta_min < -10 )); then _ck_color="$CYAN"
  elif (( _delta_min <   0 )); then _ck_color="$YELLOW"
  elif (( _delta_min <  60 )); then
    # Bedtime: blink red ŌĆö terminal handles the animation natively
    _ck_color="${RED}${BLINK}"
    _ck_suffix=" +${_delta_min}m"
  else
    # Vibe-coma: rainbow per char + random glyph + blink ŌĆö re-rolls every render
    _ck_vibe=1
    _ck_h=$(( _delta_min / 60 )); _ck_m=$(( _delta_min % 60 ))
    if (( _ck_m == 0 )); then _ck_suffix=" +${_ck_h}h"
    else _ck_suffix=" +${_ck_h}h${_ck_m}m"; fi
  fi
  if (( _ck_vibe )); then
    # Escalating shame display. Four modes based on how far past bedtime:
    #   mode 1: +1h  ŌĆö rainbow clock + blink + 1 glyph + shame message
    #   mode 2: +2h  ŌĆö double glyph bookends + underline rainbow + louder
    #   mode 3: +3h  ŌĆö triple glyph storm + reverse shame + panic
    #   mode 4: +4h  ŌĆö full chaos: emoji swarm, reverse+blink, reality leaves chat
    if   (( _delta_min < 120 )); then _vibe_mode=1
    elif (( _delta_min < 180 )); then _vibe_mode=2
    elif (( _delta_min < 240 )); then _vibe_mode=3
    else _vibe_mode=4; fi

    _ts=$(date +%s)
    _vibe_glyphs=("­¤Æż" "­¤īÖ" "­¤”ē" "Ō£©" "­¤īī" "­¤śĄ" "­¤öź" "­¤ÆĆ" "­¤½Ā" "­¤æ╗" "­¤¦Ā" "­¤øæ" "ŌÜĀ’ĖÅ" "­¤Ü©" "­¤īĆ")

    # Hue families ŌĆö shades within one hue so adjacent chars blend instead of clash.
    # Active family rotates every 90s so the color mood shifts without per-render chaos.
    _vibe_fam_pink=($'\033[38;5;219m' $'\033[38;5;213m' $'\033[38;5;207m' $'\033[38;5;201m' $'\033[38;5;165m' $'\033[38;5;129m')
    _vibe_fam_cyan=($'\033[38;5;195m' $'\033[38;5;159m' $'\033[38;5;123m' $'\033[38;5;87m' $'\033[38;5;51m' $'\033[38;5;45m')
    _vibe_fam_fire=($'\033[38;5;226m' $'\033[38;5;220m' $'\033[38;5;214m' $'\033[38;5;208m' $'\033[38;5;202m' $'\033[38;5;196m')
    _vibe_fam_purp=($'\033[38;5;183m' $'\033[38;5;147m' $'\033[38;5;111m' $'\033[38;5;105m' $'\033[38;5;99m' $'\033[38;5;93m')
    case $(( (_ts / 90) % 4 )) in
      0) _vibe_palette=("${_vibe_fam_pink[@]}") ;;
      1) _vibe_palette=("${_vibe_fam_cyan[@]}") ;;
      2) _vibe_palette=("${_vibe_fam_fire[@]}") ;;
      3) _vibe_palette=("${_vibe_fam_purp[@]}") ;;
    esac

    # Frame counter ŌĆö one increment per render, drives animation independently of time
    _vf="${_cache_dir}/vibe-frame"
    _frame=0
    { read -r _frame < "$_vf"; } 2>/dev/null || _frame=0
    (( ++_frame ))
    printf '%d\n' "$_frame" > "$_vf"

    # Glyph advances every 3 renders; gradient offset rolls 1 step per render
    _vg_idx=$(( (_frame / 3) % ${#_vibe_glyphs[@]} ))
    _ck_glyph="${_vibe_glyphs[$_vg_idx]}"
    _vibe_text="${_hhmm}${_ck_suffix}"
    _vibe_offset=$(( _frame % ${#_vibe_palette[@]} ))

    # Rainbow the clock text; modes 2+ add UNDERLINE per char
    _vibe_rainbow=""
    _vibe_char_prefix="${BLINK}"
    (( _vibe_mode >= 2 )) && _vibe_char_prefix="${BLINK}${UNDERLINE}"
    (( _vibe_mode >= 3 )) && _vibe_char_prefix="${BLINK}${UNDERLINE}${BOLD}"
    for (( _vi=0; _vi<${#_vibe_text}; _vi++ )); do
      _vc_idx=$(( (_vibe_offset + _vi) % ${#_vibe_palette[@]} ))
      _vibe_rainbow+="${_vibe_char_prefix}${_vibe_palette[$_vc_idx]}${_vibe_text:$_vi:1}${RST}"
    done

    # Shame messages ŌĆö tiered. Higher modes include all lower-tier messages.
    _vibe_msgs_1=(
      "GO TO BED"
      "SERIOUSLY?"
      "BED. NOW."
      "TOMORROW HURTS"
      "VIBE COMA"
      "TOUCH GRASS"
      "SAVE YOURSELF"
      "EYES = TIRED"
      "REST DEBT++"
      "PLEASE SLEEP"
      "CODE CAN WAIT"
      "FUTURE YOU SAYS NO"
      "BRAIN = MUSH"
      "PROD IS FINE"
      "SLEEP > VIBE"
      "NOT ANOTHER COMMIT"
      "PUT THE KEYBOARD DOWN"
      "THE BUG CAN WAIT"
      "YOU NEED SLEEP"
      "SCREEN = BAD"
      "JUST. STOP."
      "LOG OFF ALREADY"
      "CLOSE THE LAPTOP"
      "COMMIT AND SLEEP"
      "SHUTDOWN -h now"
      "TESTS CAN FAIL TOMORROW"
      "ONE MORE = MISTAKE"
      "ENOUGH FOR TODAY"
      "NOT YOUR BEST HOUR"
      "PLEASE. FOR YOURSELF."
    )
    _vibe_msgs_2=(
      "WHERE IS YOUR PILLOW"
      "YOUR BRAIN IS SOUP"
      "CTRL+ALT+SLEEP"
      "THE DIFF WILL STILL BE THERE"
      "ERROR: HUMAN_OVERHEATING"
      "YAWNING IS CONSENT"
      "SLEEP.EXE NOT FOUND"
      "WHO ARE YOU EVEN"
      "THE CURSOR IS MOCKING YOU"
      "MERGE THIS: BED INTO YOU"
      "LAST COMMIT: 3AM_MISTAKE"
      "REBASE YOUR SLEEP SCHEDULE"
      "DEPENDENCY: CONSCIOUSNESS"
      "NULL POINTER: YOUR PILLOW"
      "SEGFAULT IN YOUR EYES"
      "GIT PUSH YOURSELF TO BED"
      "THIS IS TECH DEBT"
      "STACK OVERFLOW: IN YOUR HEAD"
      "UNDEFINED BEHAVIOR AHEAD"
      "YOUR CIRCADIAN RHYTHM DIED"
      "YOUR GIT BLAME IS TIRED"
      "THE LINTER WEEPS"
      "RUBBER DUCK HAS LEFT"
      "// TODO: sleep"
      "try { sleep() } finally {}"
      "HOTFIX: YOUR SCHEDULE"
      "ASYNC AWAIT YOUR SLEEP"
      "STANDUPS WILL HURT TOMORROW"
      "MERGE CONFLICT: YOU VS. BED"
      "WHO APPROVED THIS PR HOUR"
      "THE CLOCK IS NOT LYING"
      "DARK MODE IS NOT ENOUGH"
    )
    _vibe_msgs_3=(
      "WHAT YEAR IS IT"
      "BUGS AREN'T REAL AT 3AM"
      "THE CODE IS ALIVE"
      "I CAN'T FEEL MY FACE"
      "WHO WROTE THIS? (YOU. AT 3AM.)"
      "THE FUNCTION RETURNS NOTHING"
      "LIKE YOUR SLEEP SCHEDULE"
      "HALLUCINATING: YOU OR THE AI?"
      "SYS: HUMAN_CORE_DUMP"
      "429: TOO MANY KEYSTROKES"
      "MEMORY LEAK: YOUR BRAIN"
      "FATAL: SLEEP_NOT_FOUND"
      "KERNEL PANIC ŌĆö YOU"
      "THE SEMICOLON WAS FINE"
      "IT WAS NEVER THE SEMICOLON"
      "CONSCIOUSNESS DEPRECATED"
      "REBOOT REQUIRED: YOUR FACE"
      "sudo sleep --force"
      "YOUR UPTIME IS A CRIME"
      "EXIT CODE 1: STUBBORNNESS"
      "IS THE KEYBOARD REAL"
      "WHAT IS MAIN() EVEN"
      "YOU HAVE BECOME THE SPAGHETTI"
