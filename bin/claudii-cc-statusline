#!/bin/bash
# claudii-sessionline — Claude Code statusLine handler
# Reads JSON session metrics from stdin, outputs a configurable multi-line status.
# Configure in settings.json:
#   "statusLine": { "type": "command", "command": "claudii-sessionline" }

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
# shellcheck source=lib/log.sh
source "$CLAUDII_HOME/lib/log.sh"
# shellcheck source=lib/vibemap.sh
source "$CLAUDII_HOME/lib/vibemap.sh"

command -v jq >/dev/null 2>&1 || { printf 'claudii-sessionline: jq not found — install jq\n' >&2; exit 1; }

read -r json

# Write session data to cache (key=value) — RPROMPT reads this without jq
_cache_dir="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
[[ -d "$_cache_dir" ]] || { mkdir -p "$_cache_dir"; chmod 0700 "$_cache_dir"; }

# ── User config (statusline.* keys) — single jq call, available everywhere ──
# Field separator: US (0x1F). Inside .statusline.lines: RS (0x1E), restored to
# \n after split. Reading early so _rate_display (used by rate segments) is set.
_config_file="${XDG_CONFIG_HOME:-$HOME/.config}/claudii/config.json"
_from_cfg=""
_sc_models_cfg=""
_cfg_omlx=""
_rate_display=""
_cfg_bedtime=""
_cfg_vibemap_enabled=""
_cfg_vibemap_path=""
if [[ -f "$_config_file" ]]; then
  IFS=$'\x1f' read -r _from_cfg _sc_models_cfg _cfg_omlx _rate_display _cfg_bedtime _cfg_vibemap_enabled _cfg_vibemap_path < <(
    jq -r '[
      (if .statusline.lines then (.statusline.lines | map(join(",")) | join("")) else "" end),
      (.statusline.models // ""),
      (.statusline.omlx_active_path // ""),
      (.statusline.rate_display // ""),
      (.statusline.bedtime // ""),
      (.vibemap.enabled // false | tostring),
      (.vibemap.path // "")
    ] | join("")' "$_config_file" 2>/dev/null
  )
  _from_cfg="${_from_cfg//$'\x1e'/$'\n'}"
fi
[[ "$_rate_display" != "remaining" ]] && _rate_display="used"
# Tiny mode marker — empty in default "used", ↓ in "remaining" (the number counts down).
# Appended to the rate-segment label so it's obvious at a glance which side is shown.
_rate_mark=""
[[ "$_rate_display" == "remaining" ]] && _rate_mark="↓"

# Vibe feature toggles — separate call to avoid join("") issue in main config read
_cfg_shame="true"
_cfg_motivation="true"
_cfg_rainbow="true"
_cfg_insomnii="auto"
if [[ -f "$_config_file" ]]; then
  IFS=$'\x1f' read -r _cfg_shame _cfg_motivation _cfg_rainbow _cfg_insomnii < <(
    jq -r '[
      (.statusline.shame // true | tostring),
      (.statusline.motivation // true | tostring),
      (.statusline.rainbow // true | tostring),
      (.statusline.insomnii // "auto")
    ] | join("")' "$_config_file" 2>/dev/null
  )
fi
[[ "$_cfg_insomnii" != "off" && "$_cfg_insomnii" != "on" ]] && _cfg_insomnii="auto"

# insomnii detection — delegate clock segment to the standalone insomnii(1)
# plugin when installed (and not explicitly off). Bedtime/shame/motivation/
# rainbow keys are passed through as env so users configure once, here.
_use_insomnii=0
if [[ "$_cfg_insomnii" != "off" ]] && command -v cc-insomnii >/dev/null 2>&1; then
  _use_insomnii=1
fi

# Double-render guard: when invoked via `cc-insomnii --after=claudii-cc-statusline`,
# cc-insomnii has already rendered its line at the top. Any `clock` segment in
# the user's layout would duplicate it — detect that case and skip the segment.
_wrapped_by_insomnii=0
_parent_cmd=$(ps -o comm= -p "${PPID:-0}" 2>/dev/null | tr -d ' ')
[[ "$_parent_cmd" == *cc-insomnii* ]] && _wrapped_by_insomnii=1

# Parse all fields in one jq call — single process, max efficiency
# Delimiter: Unit Separator (0x1F) — non-whitespace, so read won't collapse empty fields
_D=$'\x1f'
IFS="$_D" read -r model ctx_pct cost input_tok output_tok rate_5h rate_7d \
  duration_ms lines_add lines_rm ctx_size session_id reset_5h reset_7d \
  cache_read cache_create worktree_name agent_name model_id cwd \
  session_name worktree_branch api_duration_ms exceeds_200k \
  effort_level thinking_enabled workspace_git_worktree \
  workspace_project_dir worktree_original_cwd <<< "$(
  jq -r '[
    (.model.display_name // ""),
    (.context_window.used_percentage // "" | tostring),
    (.cost.total_cost_usd // "" | tostring),
    (.context_window.total_input_tokens // "" | tostring),
    (.context_window.total_output_tokens // "" | tostring),
    (.rate_limits.five_hour.used_percentage // "" | tostring),
    (.rate_limits.seven_day.used_percentage // "" | tostring),
    (.cost.total_duration_ms // "" | tostring),
    (.cost.total_lines_added // "" | tostring),
    (.cost.total_lines_removed // "" | tostring),
    (.context_window.context_window_size // "" | tostring),
    (.session_id // ""),
    (.rate_limits.five_hour.resets_at // "" | tostring),
    (.rate_limits.seven_day.resets_at // "" | tostring),
    (.context_window.current_usage.cache_read_input_tokens // "" | tostring),
    (.context_window.current_usage.cache_creation_input_tokens // "" | tostring),
    (.worktree.name // ""),
    (.agent.name // ""),
    (.model.id // ""),
    (.workspace.current_dir // .cwd // ""),
    (.session_name // ""),
    (.worktree.branch // ""),
    (.cost.total_api_duration_ms // "" | tostring),
    (.exceeds_200k_tokens // false | tostring),
    (.effort.level // ""),
    (.thinking.enabled // false | tostring),
    (.workspace.git_worktree // ""),
    (.workspace.project_dir // ""),
    (.worktree.original_cwd // "")
  ] | join("\u001f")' <<< "$json" 2>/dev/null || printf "${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}${_D}"
)"

# Cache hit percentage — computed from cache_read vs input tokens
_cache_pct=""
if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
  _cr=${cache_read%.*}
  _ci=${input_tok%.*}
  if (( _ci + _cr > 0 )); then
    _cache_pct=$(( _cr * 100 / (_cr + _ci) ))
  fi
fi

# Read existing session cache once — used for 7d/5h start values
_sid="${session_id:+${session_id:0:8}}"
_session_file="$_cache_dir/session-${_sid:-unknown}"
_existing_cache=""
[[ -f "$_session_file" ]] && { _existing_cache=$(<"$_session_file"); } 2>/dev/null
_ec_nl=$'\n'"$_existing_cache"

_rate_7d_start=""
if [[ -n "$rate_7d" && "$rate_7d" != "null" && "$rate_7d" != "" ]]; then
  if [[ "$_ec_nl" == *$'\n'rate_7d_start=* ]]; then
    _rate_7d_start="${_existing_cache#*rate_7d_start=}"
    _rate_7d_start="${_rate_7d_start%%$'\n'*}"
  fi
  [[ -z "$_rate_7d_start" ]] && _rate_7d_start="$rate_7d"
fi

_rate_5h_start=""
if [[ -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  if [[ "$_ec_nl" == *$'\n'rate_5h_start=* ]]; then
    _rate_5h_start="${_existing_cache#*rate_5h_start=}"
    _rate_5h_start="${_rate_5h_start%%$'\n'*}"
  fi
  [[ -z "$_rate_5h_start" ]] && _rate_5h_start="$rate_5h"
fi

# Vibemap delta: previous render's duration_ms, used to compute delta_ms.
# Stored back in session cache as last_duration_ms below.
_last_duration_ms=""
if [[ "$_ec_nl" == *$'\n'last_duration_ms=* ]]; then
  _last_duration_ms="${_existing_cache#*last_duration_ms=}"
  _last_duration_ms="${_last_duration_ms%%$'\n'*}"
fi

# Burn-rate ETA — computed for dashboard cache, not rendered in sessionline
_burn_eta=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" && "$duration_ms" != "0" ]]; then
  _rate_5h_int=${rate_5h%.*}
  _session_min_int=$(( ${duration_ms%.*} / 60000 ))
  if [[ -n "$rate_5h" && "$rate_5h" != "null" && "$rate_5h" != "0" ]] && \
     (( _session_min_int >= 3 && _rate_5h_int > 0 )); then
    _burn_eta=$(awk -v dur="$duration_ms" -v rat="$rate_5h" \
      'BEGIN { m=dur/60000; r=rat+0; print (r>0)?int((100-r)/(r/m)+0.5):0 }')
  fi
fi

# Write per-session cache (key=value) — RPROMPT + aliases read without jq
# Include ppid so dashboard can check if Claude process is still alive
# Atomic write: write to tmp then rename — prevents RPROMPT from reading partial data
# Preserve pinned= flag from existing cache file if present
_ppid="${PPID:-}"
_tmp_session="${_session_file}.tmp.$$"
{ [[ -f "$_session_file" ]] && grep '^pinned=' "$_session_file" 2>/dev/null || true
  printf '%s\n' \
  "model=$model" "ctx_pct=$ctx_pct" "cost=$cost" \
  "rate_5h=$rate_5h" "rate_7d=$rate_7d" \
  "reset_5h=$reset_5h" "reset_7d=$reset_7d" \
  "session_id=$session_id" \
  "worktree=$worktree_name" \
  "agent=$agent_name" \
  "model_id=$model_id" \
  "burn_eta=$_burn_eta" \
  "cache_pct=$_cache_pct" \
  "ppid=$_ppid" \
  "rate_7d_start=$_rate_7d_start" \
  "rate_5h_start=$_rate_5h_start" \
  "last_duration_ms=$duration_ms" \
  "project_path=$cwd" \
  > "$_tmp_session" && mv -f "$_tmp_session" "$_session_file"; } 2>/dev/null || true

# Append to persistent history (Flight Recorder) — one TSV line per update
# Monthly rotation: history-YYYY-MM.tsv (legacy history.tsv stays, readers glob both)
# Fields: timestamp, model, cost, ctx_pct, rate_5h, session_id, input_tok, output_tok, api_duration_ms
read -r _now _date_ym <<< "$(date '+%s %Y-%m')"
_history_file="$_cache_dir/history-${_date_ym}.tsv"
[[ -f "$_history_file" ]] || { touch "$_history_file"; chmod 0600 "$_history_file"; }
printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
  "$_now" "$model" "$cost" "$ctx_pct" "$rate_5h" "$session_id" \
  "${input_tok:-0}" "${output_tok:-0}" "${api_duration_ms:-0}" \
  >> "$_history_file" 2>/dev/null || true

_claudii_log debug "input: ${json:0:200}"
_claudii_log debug "parsed: model=${model} ctx=${ctx_pct} cost=${cost} in=${input_tok} out=${output_tok} 5h=${rate_5h} 7d=${rate_7d} dur=${duration_ms} +${lines_add} -${lines_rm} win=${ctx_size} sid=${session_id:0:8} r5h=${reset_5h} r7d=${reset_7d} cache_r=${cache_read} cache_c=${cache_create} wt=${worktree_name} agent=${agent_name} model_id=${model_id}"

# --- helpers ---

# Token formatter — writes to _tok_result (no subshell, pure bash arithmetic)
# 999→"999"  1000→"1.0K"  1500→"1.5K"  1000000→"1.0M"
_tok_result=""
_tok() {
  local n=${1%.*}
  [[ -z "$n" || "$n" == "null" ]] && _tok_result="" && return
  (( n == 0 )) && _tok_result="" && return
  local _m _d
  if (( n >= 1000000 )); then
    _m=$(( n / 1000000 )); _d=$(( (n % 1000000 + 50000) / 100000 ))
    (( _d == 10 )) && { (( ++_m )); _d=0; }
    printf -v _tok_result '%d.%dM' "$_m" "$_d"
  elif (( n >= 1000 )); then
    _m=$(( n / 1000 )); _d=$(( (n % 1000 + 50) / 100 ))
    (( _d == 10 )) && { (( ++_m )); _d=0; }
    printf -v _tok_result '%d.%dK' "$_m" "$_d"
  else
    _tok_result="$n"
  fi
}

# Duration formatter — writes to _dur_result (no subshell)
_dur_result=""
_dur() {
  local ms=$1
  [[ -z "$ms" || "$ms" == "null" ]] && _dur_result="" && return
  local sec=$(( ${ms%.*} / 1000 ))
  if   (( sec < 60 ));   then _dur_result="<1m"
  elif (( sec < 3600 )); then printf -v _dur_result '%dm' $(( sec / 60 ))
  else                        printf -v _dur_result '%dh%dm' $(( sec / 3600 )) $(( (sec % 3600) / 60 ))
  fi
}

# Color helpers — write to _CLR to avoid command-substitution subshell overhead
_CLR=""
# Threshold: green <70, yellow 70-89, red 90+
_thr() {
  local pct=${1%.*}; [[ -z "$pct" ]] && pct=0
  if   (( pct >= 90 )); then _CLR=$'\033[31m'
  elif (( pct >= 70 )); then _CLR=$'\033[33m'
  else                       _CLR=$'\033[32m'; fi
}
# Rate-limit color (always keyed on the *used* %): green < 50, yellow 50-79, red 80+.
# Green chosen over cyan so "lots of headroom" reads consistently across modes — in
# `remaining` display the number itself is high (e.g. 97%), and green matches the
# vibe of "plenty left".
_rlc() {
  local pct=${1%.*}; [[ -z "$pct" ]] && pct=0
  if   (( pct >= 80 )); then _CLR=$'\033[31m'
  elif (( pct >= 50 )); then _CLR=$'\033[33m'
  else                       _CLR=$'\033[32m'; fi
}

RST=$'\033[0m'
DIM=$'\033[2m'
BOLD=$'\033[1m'
CYAN=$'\033[0;36m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
RED=$'\033[0;31m'
WHITE=$'\033[0;97m'
ACCENT=$'\033[38;5;213m'
SEP="${DIM}  │  ${RST}"

# --- segment pre-computation ---

# Model (bold) + effort level (colored by tier) + thinking indicator (▲)
_seg_model=""
if [[ -n "$model" ]]; then
  _seg_model="${BOLD}${model}${RST}"
  if [[ -n "$effort_level" && "$effort_level" != "null" ]]; then
    case "$effort_level" in
      max)  _eff_clr="$ACCENT" ;;
      high) _eff_clr="$YELLOW" ;;
      *)    _eff_clr="$DIM"    ;;
    esac
    _seg_model+=" ${_eff_clr}${effort_level}${RST}"
  fi
  [[ "$thinking_enabled" == "true" ]] && _seg_model+=" ${ACCENT}▲${RST}"
fi

# Context bar (10 chars) + usable percentage + ⚡cache%
_seg_context=""
if [[ -n "$ctx_pct" && "$ctx_pct" != "null" ]]; then
  local_pct=${ctx_pct%.*}
  (( local_pct < 0 )) && local_pct=0
  (( local_pct > 100 )) && local_pct=100
  # Usable context %: raw_pct / 0.8 — scales to the 80% practical usable window
  # Example: 76% raw → 76/0.8 = 95% usable. Bar and number both reflect usable %.
  (( _usable_pct = local_pct * 100 / 80 ))
  (( _usable_pct > 100 )) && _usable_pct=100
  filled=$(( _usable_pct / 10 ))
  empty=$(( 10 - filled ))
  bar=""
  (( filled > 0 )) && printf -v f "%${filled}s" "" && bar="${f// /█}"
  (( empty > 0 )) && printf -v e "%${empty}s" "" && bar="${bar}${e// /░}"
  # Context size indicator: >200k flag (current API call exceeded 200k tokens)
  # or 1M label when extended context window active
  win=""
  if [[ "$exceeds_200k" == "true" ]]; then
    win=" ${RED}>200k${RST}"
  elif [[ -n "$ctx_size" && "$ctx_size" != "null" && "$ctx_size" -ge 1000000 ]] 2>/dev/null; then
    win=" ${DIM}1M${RST}"
  fi
  _thr "$_usable_pct"; _seg_context="${_CLR}${bar}${RST} ${DIM}${_usable_pct}%${RST}${win}"
  # Cache hit ratio — suffix to context segment
  if [[ -n "$cache_read" && "$cache_read" != "null" && "$cache_read" != "0" && "$cache_read" != "" ]]; then
    if [[ -n "$_cache_pct" && "$_cache_pct" != "0" ]]; then
      if (( _cache_pct >= 60 )); then _cc="${GREEN}"
      elif (( _cache_pct < 30 )); then _cc="${YELLOW}"
      else _cc="${DIM}"; fi
      _seg_context+=" ${_cc}⚡${_cache_pct}%${RST}"
    fi
  fi
fi

# Cost — cyan $X.XX
_seg_cost=""
if [[ -n "$cost" && "$cost" != "null" && "$cost" != "0" ]]; then
  _seg_cost="${CYAN}\$$(printf '%.2f' "$cost")${RST}"
fi

# Rate limits — 5h and 7d
# _fmt_reset(secs, pct) — sets _reset_fmt (text) and _reset_color based on
# remaining seconds and the rate-limit percentage. Format:
#   < 60m: Xm     (e.g. 45m)
#   < 24h: XhYm   (e.g. 1h19m, or 3h when minutes are zero)
#   ≥ 24h: XdYh   (e.g. 2d5h, or 2d when hours are zero)
# Color thresholds match the previous per-segment logic.
_fmt_reset() {
  local _secs="$1" _pct="$2" _m _h _d _rh
  _reset_fmt=""; _reset_color=""
  (( _secs <= 0 )) && return
  if (( _secs < 3600 )); then
    # Round to nearest minute; suppress < 30s (would render as ↺0m).
    _m=$(( (_secs + 30) / 60 ))
    (( _m <= 0 )) && return
    _reset_fmt="${_m}m"
  elif (( _secs < 86400 )); then
    _m=$(( _secs / 60 ))
    _h=$(( _secs / 3600 ))
    _rh=$(( (_secs % 3600) / 60 ))
    if (( _rh > 0 )); then _reset_fmt="${_h}h${_rh}m"
    else _reset_fmt="${_h}h"; fi
  else
    _d=$(( _secs / 86400 ))
    _h=$(( (_secs % 86400) / 3600 ))
    if (( _h > 0 )); then _reset_fmt="${_d}d${_h}h"
    else _reset_fmt="${_d}d"; fi
  fi
  if   (( _pct < 50 ));  then _reset_color="${DIM}"
  elif (( _m < 5 ));     then _reset_color="${GREEN}"
  elif (( _m < 60 ));    then _reset_color="${WHITE}"
  elif (( _m < 120 ));   then _reset_color=""
  else                        _reset_color="${DIM}"
  fi
}

# Rate display: "used" (default, e.g. 5h:62%) shows consumed budget; "remaining"
# (5h:38%) shows what's left. Coloring of segment + reset countdown is driven by
# the *used* percentage in both modes — semantics ("close to limit" → red) stay
# stable, only the displayed number flips.
_seg_rate5h=""
if [[ -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _rate_5h_pct=${rate_5h%.*}
  _disp_5h=$_rate_5h_pct
  [[ "$_rate_display" == "remaining" ]] && _disp_5h=$(( 100 - _rate_5h_pct ))
  _rlc "$rate_5h"; _seg_rate5h="${_CLR}5h${_rate_mark}:${_disp_5h}%${RST}"
  if [[ -n "$reset_5h" && "$reset_5h" != "null" && "$reset_5h" != "" ]]; then
    reset_5h="${reset_5h%.*}"
    _fmt_reset $(( reset_5h - _now )) "$_rate_5h_pct"
    [[ -n "$_reset_fmt" ]] && _seg_rate5h+=" ${_reset_color}↺${_reset_fmt}${RST}"
  fi
fi

_seg_rate7d=""
if [[ -n "$rate_7d" && "$rate_7d" != "null" ]]; then
  _rate_7d_pct=${rate_7d%.*}
  _disp_7d=$_rate_7d_pct
  [[ "$_rate_display" == "remaining" ]] && _disp_7d=$(( 100 - _rate_7d_pct ))
  _rlc "$rate_7d"; _seg_rate7d="${_CLR}7d${_rate_mark}:${_disp_7d}%${RST}"
  if [[ -n "$reset_7d" && "$reset_7d" != "null" && "$reset_7d" != "" ]]; then
    reset_7d="${reset_7d%.*}"
    _fmt_reset $(( reset_7d - _now )) "$_rate_7d_pct"
    [[ -n "$_reset_fmt" ]] && _seg_rate7d+=" ${_reset_color}↺${_reset_fmt}${RST}"
  fi
fi

# Tokens: DIM Xk↑ Xk↓
_seg_tokens=""
if [[ -n "$input_tok" && "$input_tok" != "null" ]]; then
  _tok "$input_tok";  [[ -n "$_tok_result" ]] && _seg_tokens="${DIM}${_tok_result}↑${RST}"
  _tok "$output_tok"; [[ -n "$_tok_result" ]] && _seg_tokens+="${_seg_tokens:+ }${DIM}${_tok_result}↓${RST}"
fi

# Lines changed: green +X red -X (only when > 0)
_seg_lines=""
if [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] || \
   [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]]; then
  [[ -n "$lines_add" && "$lines_add" != "null" && "$lines_add" != "0" ]] && _seg_lines+="${GREEN}+${lines_add}${RST}"
  [[ -n "$lines_rm" && "$lines_rm" != "null" && "$lines_rm" != "0" ]] && _seg_lines+=" ${RED}-${lines_rm}${RST}"
fi

# Duration: DIM Xm / Xh Xm
_seg_dur=""
if [[ -n "$duration_ms" && "$duration_ms" != "null" ]]; then
  _dur "$duration_ms"; [[ -n "$_dur_result" ]] && _seg_dur="${DIM}⏱ ${_dur_result}${RST}"
fi

# Burn-ETA: DIM ETA:Xm (only when _burn_eta set and > 0)
_seg_eta=""
if [[ -n "$_burn_eta" && "$_burn_eta" != "0" ]] 2>/dev/null; then
  _seg_eta="${DIM}ETA:${_burn_eta}m${RST}"
fi

# Clock segment — fully delegated to insomnii(1). When the binary is on
# PATH and `statusline.insomnii` is not "off", claudii pipes the upstream
# JSON to insomnii and uses its single-line output. When absent, the
# segment is empty and the layout silently skips it.
# Bedtime/shame/motivation/rainbow are forwarded as INSOMNII_* env so users
# configure once in `~/.config/claudii/config.json` (or directly in
# `~/.config/insomnii/config.json` — both work).
_seg_clock=""
if (( _use_insomnii && ! _wrapped_by_insomnii )); then
  _seg_clock=$(
    CC_INSOMNII_BEDTIME="${_cfg_bedtime:-23:00}" \
    CC_INSOMNII_SHAME="$_cfg_shame" \
    CC_INSOMNII_MOTIVATION="$_cfg_motivation" \
    CC_INSOMNII_RAINBOW="$_cfg_rainbow" \
    cc-insomnii <<< "$json" 2>/dev/null
  )
fi

# Worktree: name + branch. Falls back to workspace.git_worktree for plain git worktrees.
_seg_worktree=""
_wt_name="${worktree_name:-$workspace_git_worktree}"
if [[ -n "$_wt_name" ]]; then
  _seg_worktree="${DIM}${_wt_name}${RST}"
  [[ -n "$worktree_name" && -n "$worktree_branch" ]] && _seg_worktree+=" ${DIM}⎇ ${worktree_branch}${RST}"
fi

# Agent: DIM @name — uses agent.name (CC sub-agents) with session_name as fallback
# (claudii_agent_launch passes --name <alias> so session_name carries the alias)
_seg_agent=""
_agent_display="${agent_name:-$session_name}"
if [[ -n "$_agent_display" ]]; then
  _seg_agent="${DIM}@${RST}${ACCENT}${_agent_display}${RST}"
fi

# Session name: custom name set via /rename or --name (only when set)
_seg_session_name=""
if [[ -n "$session_name" ]]; then
  _seg_session_name="${DIM}${session_name}${RST}"
fi

# API duration: time actually spent waiting for Claude (vs. total wall-clock)
_seg_api_dur=""
if [[ -n "$api_duration_ms" && "$api_duration_ms" != "null" ]]; then
  _dur "$api_duration_ms"; [[ -n "$_dur_result" ]] && _seg_api_dur="${DIM}api:${_dur_result}${RST}"
fi

# Session deltas: only the change since session start (current rate is already on line 1).
# In "remaining" mode the sign flips: usage +12% becomes remaining −12% (same magnitude,
# opposite direction). Color logic still keys off the underlying usage delta.
_seg_delta5h=""
if [[ -n "$_rate_5h_start" && "$_rate_5h_start" != "null" && -n "$rate_5h" && "$rate_5h" != "null" ]]; then
  _d5=$(( ${rate_5h%.*} - ${_rate_5h_start%.*} ))
  _d5_disp=$_d5
  [[ "$_rate_display" == "remaining" ]] && _d5_disp=$(( -_d5 ))
  if (( _d5 > 0 )); then
    _rlc "$rate_5h"; _seg_delta5h="${DIM}Δ5h:${RST}${_CLR}$( (( _d5_disp > 0 )) && echo "+")${_d5_disp}%${RST}"
  elif (( _d5 < 0 )); then
    _seg_delta5h="${DIM}Δ5h:${RST}${GREEN}$( (( _d5_disp > 0 )) && echo "+")${_d5_disp}%${RST}"
  fi
fi

_seg_delta7d=""
if [[ -n "$_rate_7d_start" && "$_rate_7d_start" != "null" && -n "$rate_7d" && "$rate_7d" != "null" ]]; then
  _d7=$(( ${rate_7d%.*} - ${_rate_7d_start%.*} ))
  _d7_disp=$_d7
  [[ "$_rate_display" == "remaining" ]] && _d7_disp=$(( -_d7 ))
  if (( _d7 > 0 )); then
    _rlc "$rate_7d"; _seg_delta7d="${DIM}Δ7d:${RST}${_CLR}$( (( _d7_disp > 0 )) && echo "+")${_d7_disp}%${RST}"
  elif (( _d7 < 0 )); then
    _seg_delta7d="${DIM}Δ7d:${RST}${GREEN}$( (( _d7_disp > 0 )) && echo "+")${_d7_disp}%${RST}"
  fi
fi

# Cache writes: tokens written INTO cache this session (costs extra vs cache reads)
# Distinct from ⚡cache-pct (hit ratio) — this shows write volume
_seg_cache_create=""
if [[ -n "$cache_create" && "$cache_create" != "null" && "$cache_create" != "0" ]]; then
  _tok "$cache_create"; [[ -n "$_tok_result" ]] && _seg_cache_create="${DIM}✎${_tok_result}${RST}"
fi

# Working directory: basename of project_dir (with worktree.original_cwd as fallback for --worktree sessions)
_seg_dir=""
_dir_path="${worktree_original_cwd:-${workspace_project_dir:-$cwd}}"
if [[ -n "$_dir_path" && "$_dir_path" != "null" ]]; then
  _dir_name="${_dir_path##*/}"
  [[ -n "$_dir_name" ]] && _seg_dir="${DIM}⌂${RST} ${YELLOW}${_dir_name}${RST}"
fi

# Terminal width — used by ruler segment to fill remaining space
# COLUMNS (exported by parent shell) is more reliable than tput cols in piped context
_term_cols=""
[[ -n "$COLUMNS" ]] && (( COLUMNS > 20 )) && _term_cols="$COLUMNS"
[[ -z "$_term_cols" ]] && _term_cols=$(tput cols 2>/dev/null)
# If width unknown or implausible: set to 0 — ruler will silently skip
(( _term_cols > 20 )) || _term_cols=0

# --- layout config ---

_DEFAULT_LINES="model,tokens,cache-create
rate-5h,rate-7d,burn-eta,lines-changed
api-duration,duration,worktree,dir
omlx,proxy,cost,context-bar
claude-status,vpn"

_lines_raw="$_DEFAULT_LINES"
[[ -n "$_from_cfg" ]] && _lines_raw="$_from_cfg"

# ClaudeStatus — model health indicators from status-models cache
_seg_claude_status=""
_status_cache="${_cache_dir}/status-models"
if [[ -f "$_status_cache" ]]; then
  _sc=""
  { _sc=$(<"$_status_cache"); } 2>/dev/null
  if [[ -n "$_sc" ]]; then
    _sc_models=("opus" "sonnet" "haiku")
    if [[ -n "$_sc_models_cfg" ]]; then
      IFS=',' read -ra _sc_models <<< "$_sc_models_cfg"
    fi
    for _scm in "${_sc_models[@]}"; do
      _scm="${_scm// /}"
      [[ -z "$_scm" ]] && continue
      case "$_scm" in
        opus)   _scm_lbl="Opus"   ;;
        sonnet) _scm_lbl="Sonnet" ;;
        haiku)  _scm_lbl="Haiku"  ;;
        *)      _scm_lbl="$_scm"  ;;
      esac
      if [[ $'\n'"$_sc" == *$'\n'"${_scm}=down"* ]]; then
        _scm_icon="${RED}↓${RST}"; _sc_worst="down"
      elif [[ $'\n'"$_sc" == *$'\n'"${_scm}=degraded"* ]]; then
        _scm_icon="${YELLOW}~${RST}"; [[ "${_sc_worst:-}" != "down" ]] && _sc_worst="degraded"
      else
        _scm_icon="${GREEN}✓${RST}"
      fi
      [[ -n "$_seg_claude_status" ]] && _seg_claude_status+=" "
      _seg_claude_status+="${DIM}${_scm_lbl}${RST} ${_scm_icon}"
    done

    # Wrap the model glyphs in brackets — matches the zsh RPROMPT format
    # `[Opus ✓ Sonnet ✓ Haiku ✓] <age> <flag>`. Age + incident sym live
    # OUTSIDE the brackets; that way the flag visually trails the models
    # segment without being mistaken for a VPN/proxy indicator on its right.
    _seg_claude_status="${DIM}[${RST}${_seg_claude_status}${DIM}]${RST}"

    # Cache age — mtime of status-models (how stale the freshness check is)
    _sc_mtime=$(stat -f%m "$_status_cache" 2>/dev/null || stat -c%Y "$_status_cache" 2>/dev/null || echo 0)
    if [[ "$_sc_mtime" =~ ^[0-9]+$ ]] && (( _sc_mtime > 0 )); then
      _sc_age_sec=$(( _now - _sc_mtime ))
      (( _sc_age_sec < 0 )) && _sc_age_sec=0
      if   (( _sc_age_sec < 60 ));    then _sc_age_str="${_sc_age_sec}s"
      elif (( _sc_age_sec < 3600 ));  then printf -v _sc_age_str '%dm' $(( _sc_age_sec / 60 ))
      elif (( _sc_age_sec < 86400 )); then printf -v _sc_age_str '%dh' $(( _sc_age_sec / 3600 ))
      else                                 printf -v _sc_age_str '%dd' $(( _sc_age_sec / 86400 ))
      fi
      _seg_claude_status+=" ${DIM}${_sc_age_str}${RST}"
    fi

    # Incident sym — same precedence as RPROMPT (lib/statusline.zsh)
    if [[ $'\n'"$_sc" == *$'\n'"_incident=investigating"* ]]; then
      _seg_claude_status+=" ${RED}‼${RST}"
    elif [[ $'\n'"$_sc" == *$'\n'"_incident=identified"* ]]; then
      _seg_claude_status+=" ${YELLOW}⚐${RST}"
    elif [[ $'\n'"$_sc" == *$'\n'"_incident=monitoring"* ]]; then
      _seg_claude_status+=" ${CYAN}◎${RST}"
    elif [[ "${_sc_worst:-}" == "down" ]]; then
      _seg_claude_status+=" ${RED}⚠${RST}"
    elif [[ "${_sc_worst:-}" == "degraded" ]]; then
      _seg_claude_status+=" ${YELLOW}⚠${RST}"
    fi
  fi
fi

# omlx local-agent indicator — read by gateii's scripts/agent (and agent-bench)
# from data/agents/active.json. Empty when no agent active or file missing,
# so users without gateii get no impact. Stale-guard: ignore entries older
# than 300 s (crash leftovers).
# Override the path via env CLAUDII_OMLX_ACTIVE or config:
#   .statusline.omlx_active_path
_seg_omlx=""
_omlx_active_path="${CLAUDII_OMLX_ACTIVE:-}"
[[ -z "$_omlx_active_path" && -n "$_cfg_omlx" ]] && _omlx_active_path="$_cfg_omlx"
[[ -z "$_omlx_active_path" ]] && _omlx_active_path="$HOME/offline_coding/gateii/data/agents/active.json"
if [[ -f "$_omlx_active_path" ]]; then
  IFS=$'\x1f' read -r _omlx_started _omlx_task _omlx_model_short <<< "$(
    jq -r '[
      (.started_epoch // 0 | tostring),
      (.task // "?"),
      (.model // "?" | gsub("-MLX-4bit$";"") | gsub("-A3B-4bit$";"-A3B") | gsub("-a4b-it-4bit$";"") | gsub("-it-4bit$";""))
    ] | join("\u001f")' "$_omlx_active_path" 2>/dev/null
  )"
  if [[ -n "$_omlx_started" && "$_omlx_started" != "0" ]]; then
    _omlx_age=$(( _now - _omlx_started ))
    if (( _omlx_age >= 0 && _omlx_age < 300 )); then
      _seg_omlx="${ACCENT}⚡${RST} ${BOLD}${_omlx_task}${RST} ${DIM}${_omlx_model_short} ${_omlx_age}s${RST}"
    fi
  fi
fi

# VPN indicators — WireGuard via vpnii state file (wg-quick PostUp/PreDown),
# Tailscale via interface scan for CGNAT range 100.64.0.0/10. Both can be
# active at once (split-routing) — render side by side with two-space gap.
_seg_vpn=""
_vpn_state="${_cache_dir}/vpnii"
if [[ -f "$_vpn_state" ]]; then
  _vpn_tunnel=$(<"$_vpn_state")
  [[ -n "$_vpn_tunnel" ]] && _seg_vpn="${GREEN}⬡${RST} ${DIM}${_vpn_tunnel}${RST}"
fi
# Tailscale: any utun with an IPv4 in 100.64.0.0/10 (RFC 6598 CGNAT, what
# Tailscale assigns). Single ifconfig call, no daemon dependency, no name
# lookup (would need `tailscale status` — too slow per render).
if ifconfig 2>/dev/null | grep -qE 'inet 100\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\.'; then
  [[ -n "$_seg_vpn" ]] && _seg_vpn+="  "
  _seg_vpn+="${GREEN}⬢${RST} ${DIM}ts${RST}"
fi

# Proxy indicator — shows when ANTHROPIC_BASE_URL is set in .claude/settings.local.json.
# Empty when routing direct to Anthropic (the default — no noise needed).
_seg_proxy=""
_proxy_settings="${workspace_project_dir:+${workspace_project_dir}/.claude/settings.local.json}"
[[ -z "$_proxy_settings" || ! -f "$_proxy_settings" ]] && _proxy_settings="${cwd:+${cwd}/.claude/settings.local.json}"
[[ -z "$_proxy_settings" || ! -f "$_proxy_settings" ]] && _proxy_settings=".claude/settings.local.json"
if [[ -f "$_proxy_settings" ]]; then
  _proxy_url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$_proxy_settings" 2>/dev/null)
  if [[ -n "$_proxy_url" ]]; then
    if [[ "$_proxy_url" == "http://localhost:8888" ]]; then
      _proxy_label="gateii"
    else
      _proxy_label="${_proxy_url#http://}"; _proxy_label="${_proxy_label#https://}"; _proxy_label="${_proxy_label%%/*}"
    fi
    _seg_proxy="${CYAN}⇄${RST} ${YELLOW}${_proxy_label}${RST}"
  else
    _seg_proxy="${DIM}→ api${RST}"
  fi
fi

# --- layout loop ---

while IFS= read -r _line_segs; do
  [[ -z "$_line_segs" ]] && continue
  _line_out=""; _first=1
  IFS=',' read -ra _segs <<< "$_line_segs"
  for _seg in "${_segs[@]}"; do
    case "$_seg" in
      model)         _val="$_seg_model"    ;;
      context-bar)   _val="$_seg_context"  ;;
      cost)          _val="$_seg_cost"     ;;
      rate-5h)       _val="$_seg_rate5h"   ;;
      rate-7d)       _val="$_seg_rate7d"   ;;
      tokens)        _val="$_seg_tokens"   ;;
      lines-changed) _val="$_seg_lines"    ;;
      duration)      _val="$_seg_dur"      ;;
      burn-eta)      _val="$_seg_eta"      ;;
      worktree)      _val="$_seg_worktree"       ;;
      agent)         _val="$_seg_agent"         ;;
      session-name)  _val="$_seg_session_name"  ;;
      api-duration)  _val="$_seg_api_dur"       ;;
      delta-5h)      _val="$_seg_delta5h"       ;;
      delta-7d)      _val="$_seg_delta7d"       ;;
      cache-create)    _val="$_seg_cache_create"    ;;
      dir)             _val="$_seg_dir"             ;;
      claude-status)   _val="$_seg_claude_status"   ;;
      vpn)             _val="$_seg_vpn"             ;;
      omlx)            _val="$_seg_omlx"            ;;
      proxy)           _val="$_seg_proxy"           ;;
      clock)           _val="$_seg_clock"           ;;
      ruler)
        # Fill remaining terminal width with ─
        # Falls back to 60 cols when COLUMNS/tput unavailable (CC piped context)
        _val=""
        _ruler_cols=$(( _term_cols > 0 ? _term_cols : 60 ))
        if (( _first )); then
          _used=0
        else
          _vis=$(printf '%s' "$_line_out" | sed $'s/\033\\[[0-9;]*m//g')
          _used=$(( ${#_vis} + 5 ))  # +5 for the "  │  " separator to be prepended
        fi
        _fill=$(( _ruler_cols - _used ))
        if (( _fill > 1 )); then
          printf -v _v "%${_fill}s" ""
          _val="${DIM}${_v// /─}${RST}"
        fi
        ;;
      *)             _val=""               ;;
    esac
    if [[ -n "$_val" ]]; then
      if (( _first )); then _line_out="$_val"; _first=0
      else _line_out+="${SEP}${_val}"; fi
    fi
  done
  [[ -n "$_line_out" ]] && printf '%s\n' "${RST}${_line_out}" || true
done <<< "$_lines_raw"

# Vibemap append — opt-in, single fire-and-forget. Errors are silent: the
# logger never gates the statusline render. Compute delta_ms vs the previous
# render's stored duration_ms (zero on first render of a session).
if [[ "$_cfg_vibemap_enabled" == "true" ]]; then
  _vm_delta=0
  if [[ "$_last_duration_ms" =~ ^[0-9]+$ && "$duration_ms" =~ ^[0-9]+$ ]]; then
    _vm_delta=$(( duration_ms - _last_duration_ms ))
    (( _vm_delta < 0 )) && _vm_delta=0
  fi
  _vm_path=$(_vibemap_resolve_path "$_cfg_vibemap_path")
  _vibemap_append "$_vm_path" "$model" "$session_id" "$_vm_delta" 2>/dev/null || true
fi

true
