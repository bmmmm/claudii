_DEFAULT_LINES="model,tokens,cache-create
rate-5h,rate-7d,burn-eta,lines-changed
api-duration,duration,worktree,dir
omlx,proxy,cost,context-bar
claude-status,vpn"

_lines_raw="$_DEFAULT_LINES"
[[ -n "$_from_cfg" ]] && _lines_raw="$_from_cfg"

# ClaudeStatus ŌĆö model health indicators from status-models cache
_seg_claude_status=""
_status_cache="${_cache_dir}/status-models"
if [[ -f "$_status_cache" ]]; then
  _sc=""
  { _sc=$(<"$_status_cache"); } 2>/dev/null
  if [[ -n "$_sc" ]]; then
    _sc_models=("opus" "sonnet" "haiku")
    if [[ -n "$_sc_models_cfg" ]]; then
      IFS=',' read -ra _sc_models <<< "$_sc_models_cfg"
    fi
    for _scm in "${_sc_models[@]}"; do
      _scm="${_scm// /}"
      [[ -z "$_scm" ]] && continue
      case "$_scm" in
        opus)   _scm_lbl="Opus"   ;;
        sonnet) _scm_lbl="Sonnet" ;;
        haiku)  _scm_lbl="Haiku"  ;;
        *)      _scm_lbl="$_scm"  ;;
      esac
      if [[ $'\n'"$_sc" == *$'\n'"${_scm}=down"* ]]; then
        _scm_icon="${RED}Ōåō${RST}"; _sc_worst="down"
      elif [[ $'\n'"$_sc" == *$'\n'"${_scm}=degraded"* ]]; then
        _scm_icon="${YELLOW}~${RST}"; [[ "${_sc_worst:-}" != "down" ]] && _sc_worst="degraded"
      else
        _scm_icon="${GREEN}Ō£ō${RST}"
      fi
      [[ -n "$_seg_claude_status" ]] && _seg_claude_status+=" "
      _seg_claude_status+="${DIM}${_scm_lbl}${RST} ${_scm_icon}"
    done

    # Wrap the model glyphs in brackets ŌĆö matches the zsh RPROMPT format
    # `[Opus Ō£ō Sonnet Ō£ō Haiku Ō£ō] <age> <flag>`. Age + incident sym live
    # OUTSIDE the brackets; that way the flag visually trails the models
    # segment without being mistaken for a VPN/proxy indicator on its right.
    _seg_claude_status="${DIM}[${RST}${_seg_claude_status}${DIM}]${RST}"

    # Cache age ŌĆö mtime of status-models (how stale the freshness check is)
    _sc_mtime=$(stat -f%m "$_status_cache" 2>/dev/null || stat -c%Y "$_status_cache" 2>/dev/null || echo 0)
    if [[ "$_sc_mtime" =~ ^[0-9]+$ ]] && (( _sc_mtime > 0 )); then
      _sc_age_sec=$(( _now - _sc_mtime ))
      (( _sc_age_sec < 0 )) && _sc_age_sec=0
      if   (( _sc_age_sec < 60 ));    then _sc_age_str="${_sc_age_sec}s"
      elif (( _sc_age_sec < 3600 ));  then printf -v _sc_age_str '%dm' $(( _sc_age_sec / 60 ))
      elif (( _sc_age_sec < 86400 )); then printf -v _sc_age_str '%dh' $(( _sc_age_sec / 3600 ))
      else                                 printf -v _sc_age_str '%dd' $(( _sc_age_sec / 86400 ))
      fi
      _seg_claude_status+=" ${DIM}${_sc_age_str}${RST}"
    fi

    # Incident sym ŌĆö same precedence as RPROMPT (lib/statusline.zsh)
    if [[ $'\n'"$_sc" == *$'\n'"_incident=investigating"* ]]; then
      _seg_claude_status+=" ${RED}ŌĆ╝${RST}"
    elif [[ $'\n'"$_sc" == *$'\n'"_incident=identified"* ]]; then
      _seg_claude_status+=" ${YELLOW}ŌÜÉ${RST}"
    elif [[ $'\n'"$_sc" == *$'\n'"_incident=monitoring"* ]]; then
      _seg_claude_status+=" ${CYAN}ŌŚÄ${RST}"
    elif [[ "${_sc_worst:-}" == "down" ]]; then
      _seg_claude_status+=" ${RED}ŌÜĀ${RST}"
    elif [[ "${_sc_worst:-}" == "degraded" ]]; then
      _seg_claude_status+=" ${YELLOW}ŌÜĀ${RST}"
    fi
  fi
fi

# omlx local-agent indicator ŌĆö read by gateii's scripts/agent (and agent-bench)
# from data/agents/active.json. Empty when no agent active or file missing,
# so users without gateii get no impact. Stale-guard: ignore entries older
# than 300 s (crash leftovers).
# Override the path via env CLAUDII_OMLX_ACTIVE or config:
#   .statusline.omlx_active_path
_seg_omlx=""
_omlx_active_path="${CLAUDII_OMLX_ACTIVE:-}"
[[ -z "$_omlx_active_path" && -n "$_cfg_omlx" ]] && _omlx_active_path="$_cfg_omlx"
[[ -z "$_omlx_active_path" ]] && _omlx_active_path="$HOME/offline_coding/gateii/data/agents/active.json"
if [[ -f "$_omlx_active_path" ]]; then
  IFS=$'\x1f' read -r _omlx_started _omlx_task _omlx_model_short <<< "$(
    jq -r '[
      (.started_epoch // 0 | tostring),
      (.task // "?"),
      (.model // "?" | gsub("-MLX-4bit$";"") | gsub("-A3B-4bit$";"-A3B") | gsub("-a4b-it-4bit$";"") | gsub("-it-4bit$";""))
    ] | join("\u001f")' "$_omlx_active_path" 2>/dev/null
  )"
  if [[ -n "$_omlx_started" && "$_omlx_started" != "0" ]]; then
    _omlx_age=$(( _now - _omlx_started ))
    if (( _omlx_age >= 0 && _omlx_age < 300 )); then
      _seg_omlx="${ACCENT}ŌÜĪ${RST} ${BOLD}${_omlx_task}${RST} ${DIM}${_omlx_model_short} ${_omlx_age}s${RST}"
    fi
  fi
fi

# VPN indicators ŌĆö WireGuard via vpnii state file (wg-quick PostUp/PreDown),
# Tailscale via interface scan for CGNAT range 100.64.0.0/10. Both can be
# active at once (split-routing) ŌĆö render side by side with two-space gap.
_seg_vpn=""
_vpn_state="${_cache_dir}/vpnii"
if [[ -f "$_vpn_state" ]]; then
  _vpn_tunnel=$(<"$_vpn_state")
  [[ -n "$_vpn_tunnel" ]] && _seg_vpn="${GREEN}Ō¼Ī${RST} ${DIM}${_vpn_tunnel}${RST}"
fi
# Tailscale: any utun with an IPv4 in 100.64.0.0/10 (RFC 6598 CGNAT, what
# Tailscale assigns). Single ifconfig call, no daemon dependency, no name
# lookup (would need `tailscale status` ŌĆö too slow per render).
if ifconfig 2>/dev/null | grep -qE 'inet 100\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\.'; then
  [[ -n "$_seg_vpn" ]] && _seg_vpn+="  "
  _seg_vpn+="${GREEN}Ō¼ó${RST} ${DIM}ts${RST}"
fi

# Proxy indicator ŌĆö shows when ANTHROPIC_BASE_URL is set in .claude/settings.local.json.
# Empty when routing direct to Anthropic (the default ŌĆö no noise needed).
_seg_proxy=""
_proxy_settings="${workspace_project_dir:+${workspace_project_dir}/.claude/settings.local.json}"
[[ -z "$_proxy_settings" || ! -f "$_proxy_settings" ]] && _proxy_settings="${cwd:+${cwd}/.claude/settings.local.json}"
[[ -z "$_proxy_settings" || ! -f "$_proxy_settings" ]] && _proxy_settings=".claude/settings.local.json"
if [[ -f "$_proxy_settings" ]]; then
  _proxy_url=$(jq -r '.env.ANTHROPIC_BASE_URL // ""' "$_proxy_settings" 2>/dev/null)
  if [[ -n "$_proxy_url" ]]; then
    if [[ "$_proxy_url" == "http://localhost:8888" ]]; then
      _proxy_label="gateii"
    else
      _proxy_label="${_proxy_url#http://}"; _proxy_label="${_proxy_label#https://}"; _proxy_label="${_proxy_label%%/*}"
    fi
    _seg_proxy="${CYAN}Ōćä${RST} ${YELLOW}${_proxy_label}${RST}"
  else
    _seg_proxy="${DIM}ŌåÆ api${RST}"
  fi
fi

# --- layout loop ---

while IFS= read -r _line_segs; do
  [[ -z "$_line_segs" ]] && continue
  _line_out=""; _first=1
  IFS=',' read -ra _segs <<< "$_line_segs"
  for _seg in "${_segs[@]}"; do
    case "$_seg" in
      model)         _val="$_seg_model"    ;;
      context-bar)   _val="$_seg_context"  ;;
      cost)          _val="$_seg_cost"     ;;
      rate-5h)       _val="$_seg_rate5h"   ;;
      rate-7d)       _val="$_seg_rate7d"   ;;
      tokens)        _val="$_seg_tokens"   ;;
      lines-changed) _val="$_seg_lines"    ;;
      duration)      _val="$_seg_dur"      ;;
      burn-eta)      _val="$_seg_eta"      ;;
      worktree)      _val="$_seg_worktree"       ;;
      agent)         _val="$_seg_agent"         ;;
      session-name)  _val="$_seg_session_name"  ;;
      api-duration)  _val="$_seg_api_dur"       ;;
      delta-5h)      _val="$_seg_delta5h"       ;;
      delta-7d)      _val="$_seg_delta7d"       ;;
      cache-create)    _val="$_seg_cache_create"    ;;
      dir)             _val="$_seg_dir"             ;;
      claude-status)   _val="$_seg_claude_status"   ;;
      vpn)             _val="$_seg_vpn"             ;;
      omlx)            _val="$_seg_omlx"            ;;
      proxy)           _val="$_seg_proxy"           ;;
      clock)           _val="$_seg_clock"           ;;
      ruler)
        # Fill remaining terminal width with ŌöĆ
        # Falls back to 60 cols when COLUMNS/tput unavailable (CC piped context)
        _val=""
        _ruler_cols=$(( _term_cols > 0 ? _term_cols : 60 ))
        if (( _first )); then
          _used=0
        else
          _vis=$(printf '%s' "$_line_out" | sed $'s/\033\\[[0-9;]*m//g')
          _used=$(( ${#_vis} + 5 ))  # +5 for the "  Ōöé  " separator to be prepended
        fi
        _fill=$(( _ruler_cols - _used ))
        if (( _fill > 1 )); then
          printf -v _v "%${_fill}s" ""
          _val="${DIM}${_v// /ŌöĆ}${RST}"
        fi
        ;;
      *)             _val=""               ;;
    esac
    if [[ -n "$_val" ]]; then
      if (( _first )); then _line_out="$_val"; _first=0
      else _line_out+="${SEP}${_val}"; fi
    fi
  done
  [[ -n "$_line_out" ]] && printf '%s\n' "${RST}${_line_out}" || true
done <<< "$_lines_raw"

# Vibemap append ŌĆö opt-in, single fire-and-forget. Errors are silent: the
# logger never gates the statusline render. Compute delta_ms vs the previous
# render's stored duration_ms (zero on first render of a session).
if [[ "$_cfg_vibemap_enabled" == "true" ]]; then
  _vm_delta=0
  if [[ "$_last_duration_ms" =~ ^[0-9]+$ && "$duration_ms" =~ ^[0-9]+$ ]]; then
    _vm_delta=$(( duration_ms - _last_duration_ms ))
    (( _vm_delta < 0 )) && _vm_delta=0
  fi
  _vm_path=$(_vibemap_resolve_path "$_cfg_vibemap_path")
  _vibemap_append "$_vm_path" "$model" "$session_id" "$_vm_delta" 2>/dev/null || true
fi

true
