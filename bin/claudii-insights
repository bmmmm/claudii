#!/bin/bash
# claudii-insights — aggregates Claude Code JSONL transcripts to per-session JSON cache
#
# Each session JSONL gets a corresponding cache file at:
#   $CACHE_DIR/insights/<session-id>.json
#
# Cache is mtime-invalidated against the source JSONL. First run for a fresh
# cache iterates all sessions (~5-30s for typical histories); subsequent runs
# only reprocess sessions whose JSONL has been touched since the last cache.
#
# Usage:
#   claudii-insights aggregate         # refresh all stale caches (default)
#   claudii-insights aggregate --force # rebuild every cache
#   claudii-insights aggregate <jsonl> # refresh one specific file
#   claudii-insights cache-dir         # print insights cache directory
#   claudii-insights merge [--days N] [--project PATH]
#                                      # stream merged stats to stdout (jq-able)
#                                      # includes per-skill, per-plugin and per-MCP-tool attribution

set -uo pipefail

export CLAUDII_HOME="${CLAUDII_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
command -v jq >/dev/null 2>&1 || { printf 'claudii-insights: jq not found — install jq\n' >&2; exit 1; }

PROJECTS_DIR="${CLAUDE_PROJECTS_DIR:-$HOME/.claude/projects}"
CACHE_BASE="${CLAUDII_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/claudii}"
CACHE_DIR="$CACHE_BASE/insights"
JQ_PROGRAM="$CLAUDII_HOME/lib/insights.jq"

mkdir -p "$CACHE_DIR" && chmod 0700 "$CACHE_DIR"

[[ -f "$JQ_PROGRAM" ]] || { printf 'claudii-insights: missing %s\n' "$JQ_PROGRAM" >&2; exit 1; }

_mtime() { stat -f%m "$1" 2>/dev/null || stat -c%Y "$1" 2>/dev/null || echo 0; }

# List a session's subagent transcripts (<proj>/<sid>/subagents/*.jsonl).
# Prints nothing when the session has none.
_subagent_files() {
  local jsonl="$1"
  local sdir="${jsonl%.jsonl}/subagents"
  [[ -d "$sdir" ]] || return 0
  local f
  for f in "$sdir"/*.jsonl; do
    [[ -f "$f" ]] && printf '%s\n' "$f"
  done
}

# Aggregate one JSONL into its cache file. Returns 0 on success.
# Subagent transcripts are appended after the parent file so insights.jq has
# the agentId→skill map complete before subagent lines stream in.
_aggregate_one() {
  local jsonl="$1"
  local sid; sid="$(basename "$jsonl" .jsonl)"
  local out="$CACHE_DIR/$sid.json"
  local files=("$jsonl")
  while IFS= read -r sub; do
    [[ -n "$sub" ]] && files+=("$sub")
  done < <(_subagent_files "$jsonl")
  local tmp; tmp=$(mktemp "$out.XXXXXX") || return 1
  if jq -R -n --arg sid "$sid" -f "$JQ_PROGRAM" "${files[@]}" > "$tmp" 2>/dev/null; then
    mv -f "$tmp" "$out"
    return 0
  else
    rm -f "$tmp"
    return 1
  fi
}

# Decide whether a JSONL needs reaggregation. Subagent transcripts count:
# a session is stale when its parent OR any subagent file outdates the cache.
_is_stale() {
  local jsonl="$1" force="$2"
  local sid; sid="$(basename "$jsonl" .jsonl)"
  local cache="$CACHE_DIR/$sid.json"
  [[ "$force" == "1" ]] && return 0
  [[ ! -s "$cache" ]] && return 0
  local jm cm sub
  jm=$(_mtime "$jsonl"); cm=$(_mtime "$cache")
  (( jm > cm )) && return 0
  while IFS= read -r sub; do
    [[ -z "$sub" ]] && continue
    (( $(_mtime "$sub") > cm )) && return 0
  done < <(_subagent_files "$jsonl")
  return 1
}

SCHEMA_VERSION=4

# Schema gate: compare the .schema marker written after the last successful
# rebuild. The previous approach (min schema_version across ALL cache files)
# looped forever once orphaned caches existed — sessions whose JSONL Claude
# Code already deleted can never be re-aggregated, so their old version kept
# forcing a full rebuild on every run. Orphans are tolerated at merge time
# (missing keys default via // 0 and // {}).
_schema_ok() {
  [[ "$(cat "$CACHE_DIR/.schema" 2>/dev/null)" == "$SCHEMA_VERSION" ]]
}

_cmd_aggregate() {
  local force=0 target=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f) force=1 ;;
      *) target="$1" ;;
    esac
    shift
  done

  if [[ -n "$target" ]]; then
    [[ -f "$target" ]] || { printf 'not found: %s\n' "$target" >&2; exit 1; }
    _aggregate_one "$target"
    return $?
  fi

  # Schema bump → force a full rebuild so commands never read stale shapes.
  if (( ! force )) && ! _schema_ok; then
    printf 'insights: schema bump → rebuilding all caches\n' >&2
    force=1
  fi

  # Use a marker file to skip the per-file stat loop. find -newer is O(1) for
  # the unchanged majority. On --force or first run, scan all files.
  # maxdepth 4 reaches <proj>/<sid>/subagents/agent-*.jsonl — those map back
  # to their parent session file (sort -u dedups multi-agent sessions) so a
  # subagent-only update still re-aggregates the parent.
  local marker="$CACHE_DIR/.last-scan"
  local find_args=("$PROJECTS_DIR" -maxdepth 4 -name "*.jsonl" -type f)
  if [[ "$force" != "1" && -f "$marker" ]]; then
    find_args+=(-newer "$marker")
  fi

  # Touch marker BEFORE scan so any writes during scan get picked up next time.
  : > "$marker.next"

  local processed=0 failed=0
  while IFS= read -r jsonl; do
    [[ -z "$jsonl" ]] && continue
    [[ -f "$jsonl" ]] || continue   # mapped parent of orphaned subagent dir
    # When using -newer the file is by definition stale — still check cache
    # absence for the first-run case (no marker yet, every file is "new").
    local sid; sid="$(basename "$jsonl" .jsonl)"
    if [[ "$force" == "1" || ! -s "$CACHE_DIR/$sid.json" ]] || _is_stale "$jsonl" "$force"; then
      if _aggregate_one "$jsonl"; then
        (( ++processed ))
      else
        (( ++failed ))
      fi
    fi
  done < <(find "${find_args[@]}" 2>/dev/null \
             | sed 's|/subagents/[^/]*\.jsonl$|.jsonl|' | sort -u)

  mv -f "$marker.next" "$marker"
  printf '%s\n' "$SCHEMA_VERSION" > "$CACHE_DIR/.schema"

  shopt -s nullglob
  local cached_total=("$CACHE_DIR"/*.json)
  shopt -u nullglob
  printf 'insights: %d processed · %d cached · %d failed\n' "$processed" "$((${#cached_total[@]} - processed))" "$failed" >&2
}

# Merge all (or filtered) cache files into one aggregated JSON on stdout.
# Filters:
#   --days N         only include sessions whose last_seen is within N days
#   --project PATH   only include sessions for that project working dir
_cmd_merge() {
  local days="" project=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --days)    shift; days="${1:-}" ;;
      --project) shift; project="${1:-}" ;;
    esac
    shift
  done

  # --days, when given, must be a positive integer. A non-numeric value makes the
  # `date -v "-${days}d"` below fail → empty cutoff → silently "no cutoff" (all sessions).
  # Validate BEFORE the empty-cache early-return so the error fires regardless of cache
  # state. Sibling guard already shipped in lib/cmd/skills-cost.sh.
  if [[ -n "$days" ]] && { ! [[ "$days" =~ ^[0-9]+$ ]] || [[ "$days" -lt 1 ]]; }; then
    printf 'merge: --days must be a positive integer (got: %s)\n' "$days" >&2
    exit 1
  fi

  shopt -s nullglob
  local files=("$CACHE_DIR"/*.json)
  shopt -u nullglob
  if (( ${#files[@]} == 0 )); then
    printf '{}\n'
    return 0
  fi

  local cutoff_iso=""
  if [[ -n "$days" ]]; then
    # ISO 8601 cutoff in UTC. Use python-free date math.
    if date -v -1d +%Y-%m-%d >/dev/null 2>&1; then
      cutoff_iso=$(date -u -v "-${days}d" +%Y-%m-%dT%H:%M:%SZ)
    else
      cutoff_iso=$(date -u -d "${days} days ago" +%Y-%m-%dT%H:%M:%SZ)
    fi
  fi

  jq -n \
    --arg cutoff "$cutoff_iso" \
    --arg project "$project" \
    '
      def add_obj(a; b): reduce (b // {} | to_entries[]) as $e (a; .[$e.key] = ((.[$e.key] // 0) + $e.value));
      def add_obj_nested(a; b):
        reduce (b // {} | to_entries[]) as $e (a;
          .[$e.key] = (
            reduce ($e.value | to_entries[]) as $f ((.[$e.key] // {}); .[$f.key] = ((.[$f.key] // 0) + $f.value))
          )
        );

      [inputs
        | select(($cutoff == "") or ((.last_seen // "") >= $cutoff))
      ] as $all
      | reduce $all[] as $s (
          {
            sessions: 0,
            messages: 0,
            assistant_messages: 0,
            sidechain_msgs: 0,
            thinking_blocks: 0,
            limit_hits: [],
            snapshots: 0,
            first_seen: null,
            last_seen: null,
            days: {},
            models: {},
            tools: {},
            tool_errors: {},
            stop_reasons: {},
            subagent_types: {},
            permission_modes: {},
            service_tier: {},
            attribution_skills: {},
            attribution_plugins: {},
            attribution_mcp: {},
            attribution_models: {}
          };
          .sessions += 1
          | .messages += ($s.messages // 0)
          | .assistant_messages += ($s.assistant_messages // 0)
          | .sidechain_msgs += ($s.sidechain_msgs // 0)
          | .thinking_blocks += ($s.thinking_blocks // 0)
          | .limit_hits += [ ($s.limit_hits // [])[] | . + {sessionId: $s.sessionId} ]
          | .snapshots += ($s.snapshots // 0)
          | (if $s.first_seen and (.first_seen == null or $s.first_seen < .first_seen) then .first_seen = $s.first_seen else . end)
          | (if $s.last_seen  and (.last_seen  == null or $s.last_seen  > .last_seen)  then .last_seen  = $s.last_seen  else . end)
          | .days = add_obj_nested(.days; $s.days)
          | .models = add_obj_nested(.models; $s.models)
          | .tools = add_obj(.tools; $s.tools)
          | .tool_errors = add_obj(.tool_errors; $s.tool_errors)
          | .stop_reasons = add_obj(.stop_reasons; $s.stop_reasons)
          | .subagent_types = add_obj(.subagent_types; $s.subagent_types)
          | .permission_modes = add_obj(.permission_modes; $s.permission_modes)
          | .service_tier = add_obj(.service_tier; $s.service_tier)
          | .attribution_skills = add_obj_nested(.attribution_skills; $s.attribution_skills)
          | .attribution_plugins = add_obj_nested(.attribution_plugins; $s.attribution_plugins)
          | .attribution_mcp = add_obj_nested(.attribution_mcp; $s.attribution_mcp)
          | .attribution_models = add_obj(.attribution_models; $s.attribution_models)
        )
    ' "${files[@]}"
}

cmd="${1:-aggregate}"; shift || true
case "$cmd" in
  aggregate) _cmd_aggregate "$@" ;;
  merge)     _cmd_merge "$@" ;;
  cache-dir) printf '%s\n' "$CACHE_DIR" ;;
  -h|--help|help)
    cat <<'EOF'
claudii-insights — aggregate JSONL transcripts to JSON cache

Usage:
  claudii-insights aggregate [--force | <jsonl>]
  claudii-insights merge [--days N] [--project PATH]
                         # includes per-skill, per-plugin and per-MCP-tool attribution
  claudii-insights cache-dir
EOF
    ;;
  *) printf 'claudii-insights: unknown command: %s\n' "$cmd" >&2; exit 1 ;;
esac
